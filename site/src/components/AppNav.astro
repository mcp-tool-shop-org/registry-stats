---
const {
  active = "dashboard",
  hasSnapshot = false,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const dashboardHref = hasSnapshot ? `${base}/dashboard/` : `${base}/setup/?notice=no-snapshot`;
const repoUrl = "https://github.com/mcp-tool-shop-org/registry-stats";
---

<nav class="border-b border-edge">
  <div class="mx-auto max-w-6xl px-6 py-3 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="h-7 w-7 rounded bg-surface-strong flex items-center justify-center text-xs font-semibold text-heading" id="nav-badge">RP</div>
      <div class="text-sm font-semibold text-heading" id="nav-brand">Registry Pulse</div>
    </div>

    <div class="flex items-center gap-2 text-sm">
      <a
        href={dashboardHref}
        aria-disabled={!hasSnapshot ? "true" : undefined}
        class:list={[
          "px-3 py-1.5 rounded-md transition-colors",
          active === "dashboard" ? "bg-surface-strong text-heading" : "text-muted hover:text-heading hover:bg-surface-strong/40",
          !hasSnapshot && "opacity-60 cursor-not-allowed"
        ]}
      >
        Dashboard
      </a>
      <a
        href={`${base}/setup/`}
        class:list={[
          "px-3 py-1.5 rounded-md transition-colors",
          active === "setup" ? "bg-surface-strong text-heading" : "text-muted hover:text-heading hover:bg-surface-strong/40",
        ]}
      >
        Setup
      </a>
    </div>

    <div class="flex items-center gap-3 text-sm">
      <!-- Export dropdown (dashboard only) -->
      {active === "dashboard" && (
        <div class="export-wrap relative">
          <button
            id="export-btn"
            class="text-muted hover:text-heading transition-colors flex items-center gap-1 text-[13px]"
            title="Export current report"
          >
            Export
            <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div id="export-menu" class="hidden absolute right-0 top-8 z-50 rounded border border-edge bg-surface-raised py-1 min-w-[200px] shadow-lg">
            <button data-export="pdf" class="export-item block w-full text-left px-3 py-2 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">
              <span class="mr-1.5">{"\uD83D\uDCC4"}</span> Exec — PDF
            </button>
            <button data-export="jsonl" class="export-item block w-full text-left px-3 py-2 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">
              <span class="mr-1.5">{"\uD83E\uDD16"}</span> LLM — JSONL
            </button>
            <button data-export="md" class="export-item block w-full text-left px-3 py-2 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">
              <span class="mr-1.5">{"\uD83D\uDCDD"}</span> Dev — Markdown
            </button>
          </div>
        </div>
        <span class="text-dim/20">|</span>
      )}

      <!-- Theme dropdown -->
      <div class="relative" id="theme-menu">
        <button id="btn-theme" class="text-muted hover:text-heading transition-colors flex items-center gap-1 text-[13px]">
          <span id="theme-label">Theme</span>
          <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div id="theme-dropdown" class="hidden absolute right-0 top-8 z-50 rounded border border-edge bg-surface-raised py-1 min-w-[100px] shadow-lg">
          <button data-theme-choice="system" class="block w-full text-left px-3 py-1.5 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">System</button>
          <button data-theme-choice="light" class="block w-full text-left px-3 py-1.5 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">Light</button>
          <button data-theme-choice="dark" class="block w-full text-left px-3 py-1.5 text-[13px] text-dim hover:text-heading hover:bg-surface-strong transition-colors">Dark</button>
        </div>
      </div>

      <span class="text-dim/20">|</span>
      <button type="button" id="helpBtn" class="text-muted hover:text-heading transition-colors">Help</button>
      <a href={repoUrl} target="_blank" rel="noreferrer" class="text-muted hover:text-heading transition-colors">GitHub</a>
    </div>
  </div>
</nav>

<!-- Help modal -->
<div id="helpModal" class="hidden fixed inset-0 z-50">
  <div class="absolute inset-0 bg-black/60" id="helpBackdrop"></div>
  <div class="relative mx-auto mt-24 max-w-2xl rounded-xl border border-edge bg-surface p-6 shadow-xl">
    <div class="flex items-start justify-between gap-4">
      <div>
        <div class="text-sm font-semibold text-heading">Help</div>
        <div class="mt-1 text-sm text-dim">
          Registry Pulse is a local, file-based dashboard for multi-registry package metrics.
        </div>
      </div>
      <button id="helpClose" class="text-dim hover:text-heading transition-colors text-sm">Close</button>
    </div>

    <div class="mt-4 text-sm text-body space-y-3">
      <div><span class="font-medium text-heading">Setup:</span> define portfolio, generate snapshot.</div>
      <div><span class="font-medium text-heading">Dashboard:</span> view summary, breakdown, leaderboard.</div>
      <div><span class="font-medium text-heading">Data:</span> stored locally on Desktop; static JSON on web.</div>
      <div><span class="font-medium text-heading">Registries:</span> npm, PyPI, NuGet, VS Code Marketplace, Docker Hub.</div>
      <div><span class="font-medium text-heading">Privacy:</span> no telemetry, no accounts, no cloud storage. All data remains on this device.</div>
    </div>
  </div>
</div>

<script is:inline>
  // Help modal
  (function() {
    var btn = document.getElementById("helpBtn");
    var modal = document.getElementById("helpModal");
    var close = document.getElementById("helpClose");
    var backdrop = document.getElementById("helpBackdrop");

    function open() { if (modal) modal.classList.remove("hidden"); }
    function shut() { if (modal) modal.classList.add("hidden"); }

    if (btn) btn.addEventListener("click", open);
    if (close) close.addEventListener("click", shut);
    if (backdrop) backdrop.addEventListener("click", shut);
    window.addEventListener("keydown", function(e) {
      if (e.key === "Escape") shut();
    });
  })();

  // Theme toggle
  (function() {
    var themeDropdown = document.getElementById("theme-dropdown");
    var btnTheme = document.getElementById("btn-theme");
    var themeLabel = document.getElementById("theme-label");

    function getThemePref() {
      return localStorage.getItem('rp-theme') || 'system';
    }

    function applyTheme(pref) {
      localStorage.setItem('rp-theme', pref);
      var resolved = pref;
      if (pref === 'system') {
        resolved = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      if (resolved === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }

      var labels = { system: 'System', light: 'Light', dark: 'Dark' };
      if (themeLabel) themeLabel.textContent = labels[pref] || 'Theme';

      document.querySelectorAll('[data-theme-choice]').forEach(function(btn) {
        var isActive = btn.getAttribute('data-theme-choice') === pref;
        btn.classList.toggle('text-heading', isActive);
        btn.classList.toggle('text-dim', !isActive);
      });
    }

    if (btnTheme) {
      btnTheme.addEventListener('click', function(e) {
        e.stopPropagation();
        if (themeDropdown) themeDropdown.classList.toggle('hidden');
      });
    }

    document.querySelectorAll('[data-theme-choice]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        applyTheme(btn.getAttribute('data-theme-choice'));
        if (themeDropdown) themeDropdown.classList.add('hidden');
      });
    });

    document.addEventListener('click', function() {
      if (themeDropdown) themeDropdown.classList.add('hidden');
    });

    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', function() {
      if (getThemePref() === 'system') applyTheme('system');
    });

    applyTheme(getThemePref());
  })();
</script>
