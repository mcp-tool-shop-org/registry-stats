---
import AppShell from '../components/AppShell.astro';
import AppNav from '../components/AppNav.astro';

let data = null;
let missing = false;

try {
  data = (await import('../data/stats.json')).default;
} catch {
  missing = true;
}

const base = import.meta.env.BASE_URL;
const fmt = new Intl.NumberFormat('en-US');
const fmtCompact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });

function registryLabel(key: string) {
  return ({ npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' } as Record<string, string>)[key] ?? key;
}

function trendBadge(pct: number | null) {
  if (pct === null || pct === undefined) return { text: '\u2014', cls: 'text-dim' };
  const rounded = Math.round(pct * 10) / 10;
  if (rounded > 0) return { text: `\u25B2 ${rounded}%`, cls: 'text-emerald-400' };
  if (rounded < 0) return { text: `\u25BC ${Math.abs(rounded)}%`, cls: 'text-rose-400' };
  return { text: '0%', cls: 'text-dim' };
}

function relativeTime(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60_000);
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

function confidenceBadge(conf: string) {
  if (conf === 'ok') return '\u2705';
  if (conf === 'partial') return '\u26A0\uFE0F';
  return '\u26D4';
}

const totals = data?.totals;
const registryTotals = data?.registryTotals ?? {};
const leaderboard = data?.leaderboard ?? [];
const sparkline30 = data?.sparkline30 ?? [];
const movers = data?.movers;

const maxBar = Math.max(1, ...Object.values(registryTotals).map((r: any) => Number(r?.week ?? 0)));
const sparkMax = Math.max(1, ...sparkline30.map((n: number) => Number(n ?? 0)));

const gainers = movers?.topGainers ?? [];
const decliners = movers?.topDecliners ?? [];
const awakening = movers?.newlyActive ?? [];
const concentrationPct = Math.round(movers?.concentrationTop5Pct ?? 0);
---

<AppShell
  title="Dashboard — Registry Pulse"
  description="Live download statistics across npm, PyPI, NuGet, VS Code Marketplace, and Docker Hub"
>
  <AppNav active="dashboard" hasSnapshot={!missing} />

  <div class="mx-auto max-w-6xl px-4">
    {/* ── Guard panel — no snapshot ── */}
    {missing && (
      <div class="py-10">
        <div class="rounded-xl border border-edge bg-surface-raised p-6">
          <div class="text-sm font-semibold text-heading">No snapshot available</div>
          <div class="mt-1 text-sm text-dim">
            Configure your portfolio and generate a snapshot in Setup.
          </div>
          <div class="mt-4">
            <a
              class="inline-block px-4 py-2 rounded-md bg-action text-action-text text-sm font-medium hover:bg-action-hover transition-colors"
              href={`${base}/setup/`}
            >
              Go to Setup
            </a>
          </div>
        </div>
      </div>
    )}

    <div id="dashboard-content" class:list={[{ hidden: missing || !data }]}>
      {/* ── Title ── */}
      <div class="mt-8 mb-6">
        <h1 class="text-3xl font-semibold tracking-tight text-heading">Dashboard</h1>
        <p class="mt-2 text-dim">
          Weekly + monthly stats across registries.
          {!missing && data && (
            <span
              id="updated-at"
              class="ml-2 text-muted cursor-help"
              title={new Date(data.fetchedAt).toUTCString()}
              data-fetched={data.fetchedAt}
            >
              Updated {relativeTime(data.fetchedAt)}.
            </span>
          )}
        </p>
      </div>

      {/* ── Executive Snapshot ── */}
      <div id="exec-snapshot" class:list={["mb-8 rounded-2xl border border-edge bg-surface-raised/50 p-5", { hidden: missing || !(data?.narrativeLines || data?.narrative) }]}>
        <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
          <div class="text-xs font-medium tracking-wide uppercase text-dim">Executive snapshot</div>
          <div id="exec-meta" class="text-xs text-dim whitespace-nowrap text-right">
            {!missing && data && (<>Source: build-time fetch<br />{new Date(data.fetchedAt).toUTCString()}</>)}
          </div>
        </div>
        <div id="exec-lines" class="space-y-2.5">
          {data?.narrativeLines ? data.narrativeLines.map((line: { icon: string; label: string; text: string }) => (
            <div class="flex items-start gap-3">
              <span class="text-lg leading-6 shrink-0">{line.icon}</span>
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide text-accent">{line.label}</span>
                <span class="text-sm text-heading ml-2">{line.text}</span>
              </div>
            </div>
          )) : data?.narrative ? (
            <div class="text-base font-medium text-heading">{data.narrative}</div>
          ) : null}
        </div>
      </div>

      {/* ── Summary cards ── */}
      <section id="summary" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Summary</h2>
        <p class="mt-1 text-sm text-dim">Grand totals across all registries.</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Total packages</div>
            <div id="stat-packages" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmt.format(totals.packages) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Weekly downloads</div>
            <div id="stat-weekly" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmtCompact.format(totals.week) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Monthly downloads</div>
            <div id="stat-monthly" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmtCompact.format(totals.month) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Top-5 concentration</div>
            <div id="stat-concentration" class="mt-2 text-3xl font-semibold text-heading">{concentrationPct}%</div>
            <div class="mt-1 text-xs text-dim">of weekly downloads</div>
          </div>
        </div>
      </section>

      {/* ── Growth Pulse + Data Health ── */}
      <section id="pulse" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Pulse</h2>
        <p class="mt-1 text-sm text-dim">Growth signals and data reliability at a glance.</p>
        <div class="mt-4 grid gap-6 lg:grid-cols-2">

          {/* Growth Pulse */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Growth Pulse</h3>
              <div class="text-sm text-dim">
                Top-5: <span id="pulse-conc" class="font-medium text-muted">{concentrationPct}%</span> of weekly
              </div>
            </div>

            <div class="mt-5 grid gap-4 sm:grid-cols-3">
              <div class="rounded-xl border border-edge p-4">
                <div class="text-xs font-semibold text-emerald-400 flex items-center gap-1">
                  <span>{'\u25B2'}</span> Top Gainers
                </div>
                <ul id="pulse-gainers" class="mt-2 space-y-2">
                  {gainers.length > 0 ? gainers.map((r: any) => (
                    <li class="flex items-center justify-between gap-2 text-sm">
                      <span class="truncate text-heading">{r.name.replace('@mcptoolshop/', '')}</span>
                      <span class="text-emerald-400 tabular-nums whitespace-nowrap">{'\u25B2'} {Math.round((r.trendPct ?? 0) * 10) / 10}%</span>
                    </li>
                  )) : (
                    <li class="text-xs text-dim">No gainers this week</li>
                  )}
                </ul>
              </div>

              <div class="rounded-xl border border-edge p-4">
                <div class="text-xs font-semibold text-rose-400 flex items-center gap-1">
                  <span>{'\u25BC'}</span> Decliners
                </div>
                <ul id="pulse-decliners" class="mt-2 space-y-2">
                  {decliners.length > 0 ? decliners.map((r: any) => (
                    <li class="flex items-center justify-between gap-2 text-sm">
                      <span class="truncate text-heading">{r.name.replace('@mcptoolshop/', '')}</span>
                      <span class="text-rose-400 tabular-nums whitespace-nowrap">{'\u25BC'} {Math.round(Math.abs(r.trendPct ?? 0) * 10) / 10}%</span>
                    </li>
                  )) : (
                    <li class="text-xs text-dim">No decliners this week</li>
                  )}
                </ul>
              </div>

              <div class="rounded-xl border border-edge p-4">
                <div class="text-xs font-semibold text-amber-400 flex items-center gap-1">
                  <span>{'\u2728'}</span> Newly Active
                </div>
                <ul id="pulse-new" class="mt-2 space-y-2">
                  {awakening.length > 0 ? awakening.map((r: any) => (
                    <li class="flex items-center justify-between gap-2 text-sm">
                      <span class="truncate text-heading">{r.name.replace('@mcptoolshop/', '')}</span>
                      <span class="text-amber-400 tabular-nums whitespace-nowrap">{fmt.format(r.week)}/wk</span>
                    </li>
                  )) : (
                    <li class="text-xs text-dim">No new activity</li>
                  )}
                </ul>
              </div>
            </div>

            <div class="mt-4 text-xs text-dim">
              Movers computed from npm 30-day ranges (last 7 vs prior 7).
            </div>
          </div>

          {/* Data Health */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Data Health</h3>
              <div id="health-error-count" class="text-sm text-dim">
                Errors: <span class="font-medium text-muted">{data?.errors?.length ?? 0}</span>
              </div>
            </div>

            <div id="health-rows" class="mt-5 space-y-3">
              {data && Object.entries(data.manifestCounts ?? {}).map(([reg, expected]: [string, any]) => {
                const fetched = (data.fetchedCounts as any)?.[reg] ?? 0;
                const conf = (data.confidence as any)?.[reg] ?? 'missing';
                const badge = confidenceBadge(conf);
                const regErrors = (data.errorsByRegistry as any)?.[reg] ?? 0;
                return (
                  <div class="flex items-center justify-between gap-3 rounded-xl border border-edge px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span>{badge}</span>
                      <span class="font-medium text-heading">{registryLabel(reg)}</span>
                    </div>
                    <div class="text-sm text-dim tabular-nums">
                      {fetched}/{expected} fetched
                      {regErrors > 0 && (
                        <span class="ml-2 text-amber-400">({regErrors} issues)</span>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>

            <div id="health-errors-detail">
              {data && (data.errors?.length ?? 0) > 0 && (
                <details class="mt-4 rounded-xl border border-edge p-4">
                  <summary class="cursor-pointer text-sm font-medium text-heading">View fetch issues</summary>
                  <ul class="mt-3 space-y-2 text-xs text-dim">
                    {(data.errors as any[]).slice(0, 12).map((e: any) => (
                      <li class="flex gap-2">
                        <code class="text-muted shrink-0">{e.scope}</code>
                        <span class="truncate">{e.message}</span>
                      </li>
                    ))}
                  </ul>
                  {(data.errors as any[]).length > 12 && (
                    <div class="mt-2 text-xs text-dim">Showing first 12. See stats.json for full list.</div>
                  )}
                </details>
              )}
            </div>

            <div id="health-freshness" class="mt-4 text-xs text-dim">
              {data && (<>Freshness: updated {relativeTime(data.fetchedAt)} &bull; {Object.values(data.confidence ?? {}).filter((c: any) => c === 'ok').length}/{Object.keys(data.confidence ?? {}).length} registries OK</>)}
            </div>
          </div>

        </div>
      </section>

      {/* ── Registry breakdown + sparkline ── */}
      <section id="breakdown" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Breakdown</h2>
        <p class="mt-1 text-sm text-dim">Per-registry weekly downloads and 30-day activity.</p>
        <div class="mt-4 grid gap-6 lg:grid-cols-3">
          <div class="lg:col-span-2 rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Per-registry (weekly)</h3>
              <div id="breakdown-max" class="text-sm text-dim">
                Max: <span class="font-medium text-muted">{fmtCompact.format(maxBar)}</span>
              </div>
            </div>

            <div id="breakdown-bars" class="mt-5 space-y-4">
              {Object.entries(registryTotals).map(([key, r]: [string, any]) => (
                <div>
                  <div class="flex items-center justify-between text-sm">
                    <div class="font-medium text-heading">
                      {registryLabel(key)}
                      {(key === 'vscode' || key === 'nuget') && (
                        <span class="ml-1.5 text-xs text-dim font-normal">(all-time installs)</span>
                      )}
                      {key === 'docker' && (
                        <span class="ml-1.5 text-xs text-dim font-normal">(all-time pulls)</span>
                      )}
                    </div>
                    <div class="text-dim">
                      <span class="text-muted font-medium">{fmtCompact.format(
                        ['vscode','nuget','docker'].includes(key) ? (r.total ?? r.week) : r.week
                      )}</span>
                      <span class="mx-2 text-edge">&bull;</span>
                      {fmt.format(r.packages)} pkg
                    </div>
                  </div>
                  <div class="mt-2 h-2 rounded-full bg-surface-strong overflow-hidden">
                    <div
                      class="h-2 rounded-full bg-accent"
                      style={`width:${Math.round((Number(
                        ['vscode','nuget','docker'].includes(key) ? (r.total ?? r.week) : r.week
                      ) / maxBar) * 100)}%`}
                    />
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <h3 class="text-lg font-semibold text-heading">30-day activity</h3>
            <p class="mt-1 text-sm text-dim">
              Aggregate npm daily downloads.
            </p>

            <div id="sparkline-agg" class="sparkline mt-5" aria-label="30-day sparkline">
              {sparkline30.map((n: number) => (
                <span
                  class="spark"
                  style={`height:${Math.max(2, Math.round((Number(n) / sparkMax) * 100))}%`}
                  title={`${fmt.format(n)} downloads`}
                />
              ))}
            </div>
          </div>
        </div>
      </section>

      {/* ── Leaderboard ── */}
      <section id="leaderboard" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Leaderboard</h2>
        <p class="mt-1 text-sm text-dim">Sorted by weekly downloads. Trend = last 7 vs prior 7 (npm only).</p>
        <div class="mt-4 rounded-2xl border border-edge overflow-hidden">
          <div class="p-4 flex items-center justify-between gap-4 flex-wrap bg-surface-raised">
            <div class="text-sm text-dim">
              Showing <span id="leaderboard-count" class="font-medium text-muted">{leaderboard.length}</span> packages
            </div>
            <div class="text-xs text-dim">
              npm/PyPI = last 7d &bull; VS Code/NuGet/Docker = all-time
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="bg-surface-strong text-dim">
                <tr>
                  <th class="text-left font-medium px-5 py-3">#</th>
                  <th class="text-left font-medium px-5 py-3">Package</th>
                  <th class="text-left font-medium px-5 py-3">Registry</th>
                  <th class="text-right font-medium px-5 py-3">Week</th>
                  <th class="text-right font-medium px-5 py-3">Month</th>
                  <th class="text-center font-medium px-3 py-3">30d</th>
                  <th class="text-right font-medium px-5 py-3">Trend</th>
                </tr>
              </thead>
              <tbody id="leaderboard-body">
                {leaderboard.map((row: any, i: number) => {
                  const t = trendBadge(row.trendPct);
                  const hasSparkline = row.range30 && row.range30.length === 30;
                  const rowSparkMax = hasSparkline ? Math.max(1, ...row.range30) : 1;
                  return (
                    <tr class="border-t border-edge-subtle hover:bg-surface-raised/50">
                      <td class="px-5 py-3 text-dim tabular-nums">{i + 1}</td>
                      <td class="px-5 py-3 font-medium text-heading">{row.name}</td>
                      <td class="px-5 py-3 text-dim">{registryLabel(row.registry)}</td>
                      <td class="px-5 py-3 text-right tabular-nums text-body">{fmt.format(row.week)}</td>
                      <td class="px-5 py-3 text-right tabular-nums text-body">{fmt.format(row.month)}</td>
                      <td class="px-3 py-3">
                        {hasSparkline ? (
                          <div class="row-spark" title={`Peak: ${fmt.format(rowSparkMax)}/day`}>
                            {row.range30.map((n: number) => (
                              <span
                                class="rs"
                                style={`height:${Math.max(1, Math.round((n / rowSparkMax) * 100))}%`}
                              />
                            ))}
                          </div>
                        ) : (
                          <span class="text-dim text-xs">{'\u2014'}</span>
                        )}
                      </td>
                      <td class={`px-5 py-3 text-right tabular-nums ${t.cls}`}>{t.text}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <div id="leaderboard-footer">
            {data && (data.errors?.length ?? 0) > 0 && (
              <div class="border-t border-edge bg-surface-raised px-5 py-3 text-xs text-dim">
                Some sources failed to fetch ({data.errors.length}). Data may be partial.
              </div>
            )}
          </div>
        </div>
      </section>
    </div>
  </div>
</AppShell>

<style>
  .sparkline {
    height: 88px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    padding: 10px;
    border-radius: 16px;
    background: var(--color-surface-strong);
    border: 1px solid var(--color-edge);
  }
  .spark {
    width: 100%;
    max-width: 10px;
    flex: 1 1 0;
    border-radius: 999px;
    background: var(--color-accent);
    opacity: 0.85;
    transition: transform 140ms ease, opacity 140ms ease;
  }
  .spark:hover {
    transform: translateY(-2px);
    opacity: 1;
  }
  .row-spark {
    display: inline-flex;
    align-items: flex-end;
    gap: 1px;
    height: 20px;
    width: 60px;
    vertical-align: middle;
  }
  .rs {
    flex: 1 1 0;
    min-width: 1px;
    border-radius: 1px;
    background: var(--color-accent);
    opacity: 0.7;
  }
</style>

<script is:inline>
  // Runtime data loading: fetches /data/stats.json and re-renders the dashboard.
  // On web (GitHub Pages) this is a harmless re-render with the same build-time data.
  // On desktop (MAUI WebView2) this loads fresh cached data, enabling startup refresh.
  (function () {
    var fmt = new Intl.NumberFormat('en-US');
    var fmtCompact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });

    var REG_LABELS = { npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' };
    function regLabel(k) { return REG_LABELS[k] || k; }

    function trendBadge(pct) {
      if (pct === null || pct === undefined) return { text: '\u2014', cls: 'text-dim' };
      var r = Math.round(pct * 10) / 10;
      if (r > 0) return { text: '\u25B2 ' + r + '%', cls: 'text-emerald-400' };
      if (r < 0) return { text: '\u25BC ' + Math.abs(r) + '%', cls: 'text-rose-400' };
      return { text: '0%', cls: 'text-dim' };
    }

    function relTime(iso) {
      var d = Date.now() - new Date(iso).getTime();
      var m = Math.floor(d / 60000);
      if (m < 60) return m + 'm ago';
      var h = Math.floor(m / 60);
      if (h < 24) return h + 'h ago';
      return Math.floor(h / 24) + 'd ago';
    }

    function confBadge(c) {
      if (c === 'ok') return '\u2705';
      if (c === 'partial') return '\u26A0\uFE0F';
      return '\u26D4';
    }

    // Safe DOM builder: creates element with optional class and children (strings become text nodes)
    function el(tag, cls, children) {
      var e = document.createElement(tag);
      if (cls) e.className = cls;
      if (children != null) {
        var list = Array.isArray(children) ? children : [children];
        for (var i = 0; i < list.length; i++) {
          var c = list[i];
          e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
        }
      }
      return e;
    }

    var CUMULATIVE = ['vscode', 'nuget', 'docker'];
    function regDisplayVal(key, r) {
      return CUMULATIVE.indexOf(key) !== -1 ? Number(r.total || r.week || 0) : Number(r.week || 0);
    }

    // Lightweight schema check — rejects clearly malformed payloads
    function validateStats(data) {
      if (!data || typeof data !== 'object') return false;
      if (!data.totals || typeof data.totals !== 'object') return false;
      if (typeof data.totals.packages !== 'number') return false;
      if (typeof data.totals.week !== 'number') return false;
      if (typeof data.fetchedAt !== 'string') return false;
      if (data.leaderboard && !Array.isArray(data.leaderboard)) return false;
      if (data.sparkline30 && !Array.isArray(data.sparkline30)) return false;
      return true;
    }

    function renderDashboard(data) {
      if (!data || !data.totals) return;
      var t = data.totals;
      var movers = data.movers || {};
      var concPct = Math.round(movers.concentrationTop5Pct || 0);

      var upd = document.getElementById('updated-at');
      if (upd) {
        upd.title = new Date(data.fetchedAt).toUTCString();
        upd.setAttribute('data-fetched', data.fetchedAt);
        upd.textContent = 'Updated ' + relTime(data.fetchedAt) + '.';
      }

      var e;
      e = document.getElementById('stat-packages'); if (e) e.textContent = fmt.format(t.packages);
      e = document.getElementById('stat-weekly'); if (e) e.textContent = fmtCompact.format(t.week);
      e = document.getElementById('stat-monthly'); if (e) e.textContent = fmtCompact.format(t.month);
      e = document.getElementById('stat-concentration'); if (e) e.textContent = concPct + '%';
      e = document.getElementById('pulse-conc'); if (e) e.textContent = concPct + '%';

      // Executive snapshot
      var snap = document.getElementById('exec-snapshot');
      if (snap) snap.classList.remove('hidden');
      var meta = document.getElementById('exec-meta');
      if (meta) {
        meta.textContent = '';
        meta.appendChild(document.createTextNode('Source: build-time fetch'));
        meta.appendChild(document.createElement('br'));
        meta.appendChild(document.createTextNode(new Date(data.fetchedAt).toUTCString()));
      }
      var lines = document.getElementById('exec-lines');
      if (lines && data.narrativeLines) {
        lines.textContent = '';
        data.narrativeLines.forEach(function (ln) {
          lines.appendChild(el('div', 'flex items-start gap-3', [
            el('span', 'text-lg leading-6 shrink-0', String(ln.icon)),
            el('div', '', [
              el('span', 'text-xs font-semibold uppercase tracking-wide text-accent', String(ln.label)),
              el('span', 'text-sm text-heading ml-2', String(ln.text))
            ])
          ]));
        });
      } else if (lines && data.narrative) {
        lines.textContent = '';
        lines.appendChild(el('div', 'text-base font-medium text-heading', String(data.narrative)));
      }

      var content = document.getElementById('dashboard-content');
      if (content) content.classList.remove('hidden');

      function renderMoverList(id, items, colorCls, arrow, suffix) {
        var ul = document.getElementById(id);
        if (!ul) return;
        ul.textContent = '';
        if (!items || items.length === 0) {
          ul.appendChild(el('li', 'text-xs text-dim', 'No data this week'));
          return;
        }
        items.forEach(function (r) {
          var name = String(r.name || '').replace('@mcptoolshop/', '');
          var val = suffix === '/wk'
            ? fmt.format(r.week) + '/wk'
            : arrow + ' ' + (Math.round(Math.abs(r.trendPct || 0) * 10) / 10) + '%';
          ul.appendChild(el('li', 'flex items-center justify-between gap-2 text-sm', [
            el('span', 'truncate text-heading', name),
            el('span', colorCls + ' tabular-nums whitespace-nowrap', val)
          ]));
        });
      }
      renderMoverList('pulse-gainers', movers.topGainers, 'text-emerald-400', '\u25B2', '%');
      renderMoverList('pulse-decliners', movers.topDecliners, 'text-rose-400', '\u25BC', '%');
      renderMoverList('pulse-new', movers.newlyActive, 'text-amber-400', '', '/wk');

      var healthRows = document.getElementById('health-rows');
      if (healthRows && data.manifestCounts) {
        healthRows.textContent = '';
        Object.keys(data.manifestCounts).forEach(function (reg) {
          var expected = data.manifestCounts[reg] || 0;
          var fetched = (data.fetchedCounts || {})[reg] || 0;
          var conf = (data.confidence || {})[reg] || 'missing';
          var regErr = (data.errorsByRegistry || {})[reg] || 0;
          var badge = confBadge(conf);
          var infoChildren = [document.createTextNode(fetched + '/' + expected + ' fetched')];
          if (regErr > 0) {
            infoChildren.push(document.createTextNode(' '));
            infoChildren.push(el('span', 'ml-2 text-amber-400', '(' + regErr + ' issues)'));
          }
          healthRows.appendChild(el('div', 'flex items-center justify-between gap-3 rounded-xl border border-edge px-4 py-3', [
            el('div', 'flex items-center gap-2', [
              el('span', '', badge),
              el('span', 'font-medium text-heading', regLabel(reg))
            ]),
            el('div', 'text-sm text-dim tabular-nums', infoChildren)
          ]));
        });
      }
      var errCount = document.getElementById('health-error-count');
      if (errCount) {
        errCount.textContent = '';
        errCount.appendChild(document.createTextNode('Errors: '));
        errCount.appendChild(el('span', 'font-medium text-muted', String(data.errors ? data.errors.length : 0)));
      }
      var freshness = document.getElementById('health-freshness');
      if (freshness && data.confidence) {
        var ok = Object.values(data.confidence).filter(function (c) { return c === 'ok'; }).length;
        var total = Object.keys(data.confidence).length;
        freshness.textContent = 'Freshness: updated ' + relTime(data.fetchedAt) + ' \u2022 ' + ok + '/' + total + ' registries OK';
      }

      // Registry breakdown — uses total for cumulative registries (Docker/VS Code/NuGet)
      var regTotals = data.registryTotals || {};
      var maxB = 1;
      Object.keys(regTotals).forEach(function (k) {
        var v = regDisplayVal(k, regTotals[k]);
        if (v > maxB) maxB = v;
      });
      var bars = document.getElementById('breakdown-bars');
      if (bars) {
        bars.textContent = '';
        Object.keys(regTotals).forEach(function (key) {
          var r = regTotals[key];
          var displayVal = regDisplayVal(key, r);
          var pct = Math.round((displayVal / maxB) * 100);
          var labelChildren = [document.createTextNode(regLabel(key))];
          if (key === 'vscode' || key === 'nuget') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time installs)'));
          } else if (key === 'docker') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time pulls)'));
          }
          var barInner = document.createElement('div');
          barInner.className = 'h-2 rounded-full bg-accent';
          barInner.style.width = pct + '%';
          bars.appendChild(el('div', '', [
            el('div', 'flex items-center justify-between text-sm', [
              el('div', 'font-medium text-heading', labelChildren),
              el('div', 'text-dim', [
                el('span', 'text-muted font-medium', fmtCompact.format(displayVal)),
                el('span', 'mx-2 text-edge', '\u2022'),
                document.createTextNode(fmt.format(r.packages) + ' pkg')
              ])
            ]),
            el('div', 'mt-2 h-2 rounded-full bg-surface-strong overflow-hidden', [barInner])
          ]));
        });
      }
      var bmax = document.getElementById('breakdown-max');
      if (bmax) {
        bmax.textContent = '';
        bmax.appendChild(document.createTextNode('Max: '));
        bmax.appendChild(el('span', 'font-medium text-muted', fmtCompact.format(maxB)));
      }

      var sp30 = data.sparkline30 || [];
      var spMax = 1;
      for (var si = 0; si < sp30.length; si++) { var sv = Number(sp30[si]); if (sv > spMax) spMax = sv; }
      var spEl = document.getElementById('sparkline-agg');
      if (spEl) {
        spEl.textContent = '';
        sp30.forEach(function (n) {
          var h = Math.max(2, Math.round((Number(n) / spMax) * 100));
          var s = document.createElement('span');
          s.className = 'spark';
          s.style.height = h + '%';
          s.title = fmt.format(n) + ' downloads';
          spEl.appendChild(s);
        });
      }

      var lb = data.leaderboard || [];
      var lbCount = document.getElementById('leaderboard-count');
      if (lbCount) lbCount.textContent = String(lb.length);
      var tbody = document.getElementById('leaderboard-body');
      if (tbody) {
        tbody.textContent = '';
        lb.forEach(function (row, i) {
          var tb = trendBadge(row.trendPct);
          var has30 = row.range30 && row.range30.length === 30;
          var sparkCell;
          if (has30) {
            var rm = 1;
            for (var ri = 0; ri < row.range30.length; ri++) { if (row.range30[ri] > rm) rm = row.range30[ri]; }
            sparkCell = document.createElement('div');
            sparkCell.className = 'row-spark';
            sparkCell.title = 'Peak: ' + fmt.format(rm) + '/day';
            row.range30.forEach(function (n) {
              var s = document.createElement('span');
              s.className = 'rs';
              s.style.height = Math.max(1, Math.round((n / rm) * 100)) + '%';
              sparkCell.appendChild(s);
            });
          } else {
            sparkCell = el('span', 'text-dim text-xs', '\u2014');
          }
          function td(cls, child) {
            var c = document.createElement('td');
            c.className = cls;
            c.appendChild(typeof child === 'string' ? document.createTextNode(child) : child);
            return c;
          }
          var tr = document.createElement('tr');
          tr.className = 'border-t border-edge-subtle hover:bg-surface-raised/50';
          tr.appendChild(td('px-5 py-3 text-dim tabular-nums', String(i + 1)));
          tr.appendChild(td('px-5 py-3 font-medium text-heading', String(row.name)));
          tr.appendChild(td('px-5 py-3 text-dim', regLabel(row.registry)));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(row.week)));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(row.month)));
          tr.appendChild(td('px-3 py-3', sparkCell));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums ' + tb.cls, tb.text));
          tbody.appendChild(tr);
        });
      }

      // Leaderboard footer
      var lbFoot = document.getElementById('leaderboard-footer');
      if (lbFoot) {
        lbFoot.textContent = '';
        if (data.errors && data.errors.length > 0) {
          lbFoot.appendChild(el('div', 'border-t border-edge bg-surface-raised px-5 py-3 text-xs text-dim',
            'Some sources failed to fetch (' + data.errors.length + '). Data may be partial.'));
        }
      }
    }

    // Read base path from meta tag set by AppShell (avoids hardcoded path)
    var baseMeta = document.querySelector('meta[name="base-url"]');
    var basePath = (baseMeta ? baseMeta.getAttribute('content') : '/registry-stats') + '/';
    var statsUrl = basePath + 'data/stats.json';

    fetch(statsUrl).then(function (res) {
      if (!res.ok) throw new Error(res.status);
      return res.json();
    }).then(function (data) {
      if (!validateStats(data)) return;
      var existing = document.getElementById('updated-at');
      var buildTime = existing ? existing.getAttribute('data-fetched') : null;
      if (buildTime && data.fetchedAt === buildTime) return;
      renderDashboard(data);
    }).catch(function () {
      // Runtime fetch failed — build-time data is still displayed. Silent fallback.
    });
  })();
</script>
