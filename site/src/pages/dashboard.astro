        }

        // Reusable section heading
        function heading(text, size) {
          checkPage(12);
          doc.setFontSize(size || 13);
          doc.setFont('helvetica', 'bold');
          doc.setTextColor(30, 30, 30);
          doc.text(text, M, y);
          y += 7;
        }

        // Table header row
        function tableHeader(labels, positions) {
          doc.setFontSize(8);
          doc.setFont('helvetica', 'bold');
          doc.setTextColor(100, 100, 100);
          labels.forEach(function (lbl, i) { doc.text(lbl, positions[i], y); });
          y += 1.5;
          doc.setDrawColor(180, 180, 180);
          doc.setLineWidth(0.3);
          doc.line(M, y, W - M, y);
          y += 3.5;
        }

        // ── Header ──
        doc.setFontSize(20);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(25, 25, 25);
        doc.text('Registry Stats Report', M, y);
        y += 7;
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(130, 130, 130);
        doc.text('Generated ' + new Date().toUTCString(), M, y);
        y += 4;
        if (d.fetchedAt) {
          doc.text('Data as of ' + new Date(d.fetchedAt).toUTCString(), M, y);
          y += 4;
        }
        doc.text(fi(t.packages) + ' packages across ' + (t.activeRegistries || Object.keys(rt).length) + ' registries', M, y);
        y += 2;
        doc.setDrawColor(200, 200, 200);
        doc.setLineWidth(0.3);
        doc.line(M, y, W - M, y);
        y += 7;

        // ── Executive Summary ──
        heading('Executive Summary');
        doc.setFontSize(9);
        // Bullet colour per narrative type
        var bulletColors = { 'Registry Lead': [59, 130, 246], 'Top Package': [234, 179, 8], 'Top Mover': [16, 185, 129], 'Data Source': [107, 114, 128] };
        if (narr.length > 0) {
          narr.forEach(function (n) {
            checkPage(7);
            var label = safe(n.label || '');
            var text = safe(n.text || '');
            var bc = bulletColors[label] || [107, 114, 128];
            // Coloured bullet dot
            doc.setFillColor(bc[0], bc[1], bc[2]);
            doc.circle(M + 1.5, y - 1.2, 1.2, 'F');
            // Bold label
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(40, 40, 40);
            doc.text(label + ':', M + 5, y);
            var labelW = doc.getTextWidth(label + ': ');
            // Normal text
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(70, 70, 70);
            var remaining = CW - 5 - labelW;
            if (remaining < 40) remaining = CW - 5;
            var split = doc.splitTextToSize(text, remaining);
            doc.text(split[0], M + 5 + labelW, y);
            for (var si = 1; si < split.length; si++) {
              y += 4;
              doc.text(split[si], M + 5, y);
            }
            y += 5.5;
          });
        } else if (d.narrative) {
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(70, 70, 70);
          var split = doc.splitTextToSize(safe(d.narrative), CW);
          doc.text(split, M, y);
          y += split.length * 4 + 2;
        }
        y += 3;

        // ── KPI Cards ──
        checkPage(24);
        heading('Key Metrics');
        var kpis = [
          { label: 'Weekly Downloads', value: fc(t.week) },
          { label: 'Monthly Downloads', value: fc(t.month) },
          { label: 'Packages', value: fi(t.packages) },
          { label: 'Top-5 Concentration', value: Math.round(movers.concentrationTop5Pct || 0) + '%' },
        ];
        var boxW = (CW - 9) / 4;
        kpis.forEach(function (kpi, i) {
          var bx = M + i * (boxW + 3);
          doc.setFillColor(244, 244, 249);
          doc.roundedRect(bx, y, boxW, 16, 2, 2, 'F');
          doc.setFontSize(15);
          doc.setFont('helvetica', 'bold');
          doc.setTextColor(25, 25, 25);
          doc.text(kpi.value, bx + boxW / 2, y + 7.5, { align: 'center' });
          doc.setFontSize(7);
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(130, 130, 130);
          doc.text(kpi.label, bx + boxW / 2, y + 13, { align: 'center' });
        });
        y += 22;

        // ── Registry Breakdown ──
        heading('Per-Registry Breakdown');
        var cols = [M, M + 32, M + 55, M + 80, M + 110];
        tableHeader(['Registry', 'Packages', 'Weekly', 'Monthly', 'Status'], cols);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        Object.keys(rt).forEach(function (reg) {
          checkPage(5);
          var r = rt[reg];
          doc.setTextColor(50, 50, 50);
          doc.text(regL(reg), cols[0], y);
          doc.setTextColor(80, 80, 80);
          doc.text(fi(r.packages), cols[1], y);
          doc.text(fi(r.week), cols[2], y);
          doc.text(fi(r.month), cols[3], y);
          var status = (d.confidence || {})[reg] || '?';
          doc.setTextColor(status === 'ok' ? 34 : 150, status === 'ok' ? 139 : 80, status === 'ok' ? 34 : 80);
          doc.text(status, cols[4], y);
          y += 5;
        });
        y += 5;

        // ── Top Gainers ──
        var tg = movers.topGainers || [];
        if (tg.length > 0) {
          heading('Top Gainers');
          var gc = [M, M + 50, M + 75, M + 100];
          tableHeader(['Package', 'Weekly', 'Change (7d)', 'WoW %'], gc);
          doc.setFontSize(8);
          doc.setFont('helvetica', 'normal');
          tg.forEach(function (r) {
            checkPage(5);
            var name = safe(String(r.name || '').replace('@mcptoolshop/', ''));
            doc.setTextColor(50, 50, 50);
            doc.text(name.length > 30 ? name.slice(0, 28) + '...' : name, gc[0], y);
            doc.setTextColor(80, 80, 80);
            doc.text(fi(r.week), gc[1], y);
            doc.setTextColor(r.delta7 >= 0 ? 22 : 200, r.delta7 >= 0 ? 163 : 50, r.delta7 >= 0 ? 74 : 50);
            doc.text((r.delta7 >= 0 ? '+' : '') + fi(r.delta7), gc[2], y);
            doc.setTextColor(80, 80, 80);
            doc.text(pct(r.trendPct), gc[3], y);
            y += 4.5;
          });
          y += 5;
        }

        // ── Leaderboard (Top 25) ──
        checkPage(20);
        heading('Leaderboard (Top 25)');
        var lc = [M, M + 8, M + 55, M + 78, M + 100, M + 125, M + 148];
        tableHeader(['#', 'Package', 'Registry', 'Weekly', 'Monthly', 'WoW %', 'Trend'], lc);
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        lb.slice(0, 25).forEach(function (r, i) {
          checkPage(5);
          var name = safe(String(r.name || '').replace('@mcptoolshop/', ''));
          // Zebra stripe
          if (i % 2 === 0) {
            doc.setFillColor(248, 248, 252);
            doc.rect(M, y - 3.2, CW, 4.5, 'F');
          }
          doc.setTextColor(140, 140, 140);
          doc.text(String(i + 1), lc[0], y);
          doc.setTextColor(40, 40, 40);
          doc.setFont('helvetica', 'bold');
          doc.text(name.length > 26 ? name.slice(0, 24) + '...' : name, lc[1], y);
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(100, 100, 100);
          doc.text(regL(r.registry), lc[2], y);
          doc.setTextColor(60, 60, 60);
          doc.text(fi(r.week), lc[3], y);
          doc.text(fi(r.month), lc[4], y);
          // Colour-coded trend
          var tp = r.trendPct;
          if (tp !== null && tp !== undefined) {
            doc.setTextColor(tp >= 0 ? 22 : 200, tp >= 0 ? 163 : 50, tp >= 0 ? 74 : 50);
            doc.text((tp >= 0 ? '+' : '') + pct(tp), lc[5], y);
            // Simple arrow
            doc.setTextColor(tp >= 0 ? 22 : 200, tp >= 0 ? 163 : 50, tp >= 0 ? 74 : 50);
            doc.text(tp >= 50 ? 'Rising fast' : tp >= 10 ? 'Up' : tp >= -10 ? 'Steady' : tp >= -50 ? 'Down' : 'Falling', lc[6], y);
          } else {
            doc.setTextColor(170, 170, 170);
            doc.text('New', lc[5], y);
            doc.text('--', lc[6], y);
          }
          y += 4.5;
        });
        y += 4;

        // ── Footer on every page ──
        var pages = doc.internal.getNumberOfPages();
        for (var p = 1; p <= pages; p++) {
          doc.setPage(p);
          doc.setFontSize(7);
          doc.setFont('helvetica', 'normal');
          doc.setTextColor(170, 170, 170);
          doc.text('MCP Tool Shop  |  Registry Stats Dashboard  |  ' + new Date().toISOString().slice(0, 10), M, 290);
          doc.text('Page ' + p + ' of ' + pages, W - M, 290, { align: 'right' });
        }

        doc.save('registry-stats-' + dateStamp() + '.pdf');
      });
    }

    // Dispatch export clicks
    exportMenu.querySelectorAll('[data-export]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var type = btn.getAttribute('data-export');
        exportMenu.classList.add('hidden');
        if (type === 'pdf') exportPDF();
        else if (type === 'jsonl') exportJSONL();
        else if (type === 'md') exportMarkdown();
      });
    });
  })();
</script>