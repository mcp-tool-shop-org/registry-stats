---
import AppShell from '../components/AppShell.astro';
import AppNav from '../components/AppNav.astro';

let data = null;
let missing = false;

try {
  data = (await import('../data/stats.json')).default;
} catch {
  missing = true;
}

const base = import.meta.env.BASE_URL;
const fmt = new Intl.NumberFormat('en-US');
const fmtCompact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });

function registryLabel(key: string) {
  return ({ npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' } as Record<string, string>)[key] ?? key;
}

// Smart growth display — handles small-denominator distortion
const BASELINE_THRESHOLD = 20; // minimum prev downloads to show raw %
const PCT_CAP = 500;           // visual cap for giant percentages

function smartGrowth(pct: number | null | undefined, prev: number | null | undefined, curr: number | null | undefined): { text: string; cls: string; isEmerging: boolean } {
  if (pct === null || pct === undefined) {
    // No percentage available — check if it's a brand-new/emerging package
    if ((prev === 0 || prev === null || prev === undefined) && (curr ?? 0) > 0) {
      return { text: `\uD83D\uDE80 New (+${fmtCompact.format(curr ?? 0)})`, cls: 'text-amber-400', isEmerging: true };
    }
    return { text: '\u2014', cls: 'text-dim', isEmerging: false };
  }
  const absDelta = (curr ?? 0) - (prev ?? 0);
  // Small-base packages: show absolute change with emerging badge
  if ((prev ?? 0) < BASELINE_THRESHOLD) {
    return { text: `\uD83D\uDE80 Emerging (+${fmtCompact.format(Math.max(0, absDelta))})`, cls: 'text-amber-400', isEmerging: true };
  }
  const rounded = Math.round(pct * 10) / 10;
  const arrow = rounded > 0 ? '\u25B2' : rounded < 0 ? '\u25BC' : '';
  const absR = Math.abs(rounded);
  if (absR > PCT_CAP) {
    // Cap display, show real delta
    const cap = rounded > 0 ? `${arrow} ${PCT_CAP}%+` : `${arrow} ${PCT_CAP}%+`;
    return { text: `${cap} (+${fmtCompact.format(Math.abs(absDelta))})`, cls: rounded > 0 ? 'text-emerald-400' : 'text-rose-400', isEmerging: false };
  }
  if (rounded > 0) return { text: `${arrow} ${absR}%`, cls: 'text-emerald-400', isEmerging: false };
  if (rounded < 0) return { text: `${arrow} ${absR}%`, cls: 'text-rose-400', isEmerging: false };
  return { text: '0%', cls: 'text-dim', isEmerging: false };
}

// Backwards-compatible wrapper for leaderboard table where we only have pct
function trendBadge(pct: number | null, prev?: number | null, curr?: number | null) {
  const sg = smartGrowth(pct, prev, curr);
  return { text: sg.text, cls: sg.cls };
}

function relativeTime(iso: string) {
  const diff = Date.now() - new Date(iso).getTime();
  const mins = Math.floor(diff / 60_000);
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  return `${days}d ago`;
}

function confidenceBadge(conf: string) {
  if (conf === 'ok') return '\u2705';
  if (conf === 'partial') return '\u26A0\uFE0F';
  return '\u26D4';
}

const totals = data?.totals;
const registryTotals = data?.registryTotals ?? {};
const leaderboard = data?.leaderboard ?? [];
const sparkline30 = data?.sparkline30 ?? [];
const movers = data?.movers;

const maxBar = Math.max(1, ...Object.entries(registryTotals).map(([k, r]: [string, any]) => ['vscode','nuget','docker'].includes(k) ? Number(r?.total ?? r?.week ?? 0) : Number(r?.week ?? 0)));
const sparkMax = Math.max(1, ...sparkline30.map((n: number) => Number(n ?? 0)));

const gainers = movers?.topGainers ?? [];
const decliners = movers?.topDecliners ?? [];
const awakening = movers?.newlyActive ?? [];
const concentrationPct = Math.round(movers?.concentrationTop5Pct ?? 0);

// ── Categorize movers: Established (prev ≥ 50) vs Emerging (prev < 50) ──
const ESTABLISHED_FLOOR = 50;
function moverPrev(r: any): number { return r.delta7 !== undefined ? (r.week ?? 0) - r.delta7 : 0; }
function moverCurr(r: any): number { return r.week ?? 0; }
const establishedGainers = gainers.filter((r: any) => moverPrev(r) >= ESTABLISHED_FLOOR);
const emergingGainers = gainers.filter((r: any) => moverPrev(r) < ESTABLISHED_FLOOR);
// Merge newly-active into emerging pool for display
const emergingAll = [...emergingGainers, ...awakening.filter((a: any) => !emergingGainers.some((g: any) => g.name === a.name))].sort((a: any, b: any) => (b.week ?? 0) - (a.week ?? 0)).slice(0, 5);
const establishedDecliners = decliners.filter((r: any) => moverPrev(r) >= ESTABLISHED_FLOOR);
const emergingDecliners = decliners.filter((r: any) => moverPrev(r) < ESTABLISHED_FLOOR);

// Summary line
const accelCount = gainers.filter((r: any) => (r.trendPct ?? 0) > 10).length;
const stabilCount = gainers.length - accelCount;
const pulseSummary = `Top 5 packages drive ${concentrationPct}% of weekly downloads. ${accelCount} accelerating, ${stabilCount > 0 ? stabilCount + ' stabilizing' : '0 stabilizing'}.`;

// Mini sparkline SVG helper (7-day from range30)
function miniSparkSvg(range30: number[] | null): string {
  if (!range30 || range30.length < 7) return '';
  const vals = range30.slice(-7);
  const mx = Math.max(1, ...vals);
  const pts = vals.map((v, i) => `${(i / 6) * 48},${16 - (v / mx) * 14}`).join(' ');
  return `<svg viewBox="0 0 48 18" class="inline-block w-12 h-4 ml-1 align-middle" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="${pts}" /></svg>`;
}

// ── Expanded executive metrics ──
const npmLast7 = sparkline30.slice(-7).reduce((a: number, b: number) => a + Number(b), 0);
const npmPrev7 = sparkline30.slice(-14, -7).reduce((a: number, b: number) => a + Number(b), 0);
const weekDelta = npmLast7 - npmPrev7;
const weekDeltaPct = npmPrev7 > 0 ? ((npmLast7 - npmPrev7) / npmPrev7 * 100) : 0;

const okRegistries = data ? Object.values(data.confidence ?? {}).filter((c: any) => c === 'ok').length : 0;
const totalRegistries = data ? Object.keys(data.confidence ?? {}).length : 0;

const regWeeks = Object.values(registryTotals).map((r: any) => Number(r?.week ?? 0)).filter((v: number) => v > 0);
const totalWeekAll = regWeeks.reduce((a: number, b: number) => a + b, 0);
const shannonH = totalWeekAll > 0 ? -regWeeks.reduce((h: number, w: number) => { const p = w / totalWeekAll; return h + (p > 0 ? p * Math.log2(p) : 0); }, 0) : 0;
const maxEntropy = regWeeks.length > 1 ? Math.log2(regWeeks.length) : 1;
const diversityIndex = maxEntropy > 0 ? shannonH / maxEntropy : 0;

const coveragePts = totalRegistries > 0 ? (okRegistries / totalRegistries) * 40 : 0;
const errorPts = Math.min(30, (data?.errors?.length ?? 0) * 5);
const growthPts = weekDeltaPct > 5 ? 20 : weekDeltaPct > 0 ? 10 : weekDeltaPct > -5 ? 5 : 0;
const diversityPts = diversityIndex * 10;
const healthScore = Math.round(Math.max(0, Math.min(100, coveragePts - errorPts + growthPts + diversityPts)));

// ── Derived analytics metrics ──
// Per-registry daily breakdown (synthesize from npm range30 + proportional split)
const npmDailyByPkg = (leaderboard as any[])
  .filter((r: any) => r.registry === 'npm' && r.range30?.length === 30);
const perRegistryDaily: Record<string, number[]> = {};
for (const reg of Object.keys(registryTotals)) {
  if (reg === 'npm') {
    // Aggregate all npm package range30 arrays
    const agg = new Array(30).fill(0);
    npmDailyByPkg.forEach((r: any) => r.range30.forEach((v: number, i: number) => agg[i] += Number(v)));
    perRegistryDaily.npm = agg;
  } else {
    // Estimate daily from weekly total (flat distribution — best available)
    const weekVal = Number((registryTotals as any)[reg]?.week ?? 0);
    perRegistryDaily[reg] = new Array(30).fill(Math.round(weekVal / 7));
  }
}

// Top 5 per-package daily overlay
const top5Daily = npmDailyByPkg
  .sort((a: any, b: any) => (b.week ?? 0) - (a.week ?? 0))
  .slice(0, 5)
  .map((r: any) => ({ name: (r.name ?? '').replace('@mcptoolshop/', ''), range30: r.range30 }));

// Z-score anomaly detection on aggregate sparkline
const spMean = sparkline30.length > 0 ? sparkline30.reduce((a: number, b: number) => a + Number(b), 0) / sparkline30.length : 0;
const spStdDev = sparkline30.length > 1 ? Math.sqrt(sparkline30.reduce((s: number, v: number) => s + Math.pow(Number(v) - spMean, 2), 0) / sparkline30.length) : 1;
const anomalies = sparkline30.map((v: number, i: number) => {
  const z = spStdDev > 0 ? (Number(v) - spMean) / spStdDev : 0;
  return Math.abs(z) >= 2 ? { day: i, value: Number(v), z: Math.round(z * 10) / 10 } : null;
}).filter(Boolean);

// 30-day vs prior 30-day % change
const last30Sum = sparkline30.reduce((a: number, b: number) => a + Number(b), 0);
const monthOverMonthPct = npmPrev7 > 0 ? Math.round(weekDeltaPct * 10) / 10 : 0;

// Gini coefficient for portfolio concentration
const weeklyDownloads = (leaderboard as any[]).map((r: any) => Number(r.week ?? 0)).sort((a: number, b: number) => a - b);
const n = weeklyDownloads.length;
const totalDl = weeklyDownloads.reduce((a: number, b: number) => a + b, 0);
let giniNum = 0;
weeklyDownloads.forEach((x: number, i: number) => { giniNum += (2 * (i + 1) - n - 1) * x; });
const gini = n > 1 && totalDl > 0 ? Math.round((giniNum / (n * totalDl)) * 100) / 100 : 0;

// Median and P90
const sortedWeeks = [...weeklyDownloads];
const median = n > 0 ? sortedWeeks[Math.floor(n / 2)] : 0;
const p90 = n > 0 ? sortedWeeks[Math.floor(n * 0.9)] : 0;
const top3Pct = totalDl > 0 ? Math.round(weeklyDownloads.slice(-3).reduce((a: number, b: number) => a + b, 0) / totalDl * 100) : 0;

// Velocity scores — damped formula to avoid small-denominator distortion
// velocity = (curr - prev) / sqrt(prev + k) — rewards real growth, penalizes tiny bases
const VELOCITY_K = 10; // damping constant
const velocityBoard = (leaderboard as any[]).slice(0, 30).map((r: any) => {
  const name = (r.name ?? '').replace('@mcptoolshop/', '');
  let velocity: number | null = null;
  let prevWeek: number | null = null;
  let isEmerging = false;
  if (r.range30?.length === 30) {
    prevWeek = r.range30.slice(-14, -7).reduce((a: number, b: number) => a + Number(b), 0);
    const currWeek = r.range30.slice(-7).reduce((a: number, b: number) => a + Number(b), 0);
    if (prevWeek < BASELINE_THRESHOLD) {
      isEmerging = true;
      velocity = null; // don't compute misleading % for tiny bases
    } else {
      velocity = Math.round((currWeek - prevWeek) / Math.sqrt(prevWeek + VELOCITY_K) * 10) / 10;
    }
  }
  const absDelta = r.range30?.length === 30
    ? r.range30.slice(-7).reduce((a: number, b: number) => a + Number(b), 0) -
      r.range30.slice(-14, -7).reduce((a: number, b: number) => a + Number(b), 0)
    : null;
  return { name, registry: r.registry, week: r.week, month: r.month, trendPct: r.trendPct, prevWeek, absDelta, range30: r.range30, velocity, isEmerging };
});

// Packages needing attention (declining 3+ weeks or stale)
const attentionPkgs = (leaderboard as any[])
  .filter((r: any) => {
    if (!r.range30 || r.range30.length !== 30) return (r.trendPct ?? 0) < -15;
    const w1 = r.range30.slice(0, 10).reduce((a: number, b: number) => a + Number(b), 0);
    const w2 = r.range30.slice(10, 20).reduce((a: number, b: number) => a + Number(b), 0);
    const w3 = r.range30.slice(20, 30).reduce((a: number, b: number) => a + Number(b), 0);
    return (w3 < w2 && w2 < w1) || w3 === 0;
  })
  .slice(0, 5)
  .map((r: any) => {
    const prev = r.range30?.length === 30 ? r.range30.slice(-14, -7).reduce((a: number, b: number) => a + Number(b), 0) : null;
    const curr = r.range30?.length === 30 ? r.range30.slice(-7).reduce((a: number, b: number) => a + Number(b), 0) : r.week;
    const sg = smartGrowth(r.trendPct, prev, curr);
    return { name: (r.name ?? '').replace('@mcptoolshop/', ''), trendPct: r.trendPct, week: r.week, growthText: sg.text, growthCls: sg.cls };
  });

// Auto-generated insights
const insights: { icon: string; text: string; type: string }[] = [];
if (weekDeltaPct > 0) insights.push({ icon: '\uD83D\uDCC8', text: `Portfolio grew ${Math.round(weekDeltaPct * 10) / 10}% week-over-week (${fmtCompact.format(npmLast7)} downloads)`, type: 'positive' });
if (weekDeltaPct < -5) insights.push({ icon: '\u26A0\uFE0F', text: `Portfolio declined ${Math.abs(Math.round(weekDeltaPct * 10) / 10)}% week-over-week`, type: 'warning' });
if (top3Pct > 60) insights.push({ icon: '\uD83E\uDDF1', text: `${top3Pct}% of downloads come from top 3 packages — high concentration risk`, type: 'warning' });
if (gini > 0.7) insights.push({ icon: '\u26A0\uFE0F', text: `Gini coefficient ${gini.toFixed(2)} — portfolio heavily skewed toward few packages`, type: 'warning' });
if (anomalies.length > 0) {
  const spikeCount = anomalies.filter((a: any) => a.z > 0).length;
  const dropCount = anomalies.filter((a: any) => a.z < 0).length;
  if (spikeCount > 0) insights.push({ icon: '\uD83D\uDE80', text: `${spikeCount} download spike${spikeCount > 1 ? 's' : ''} detected in the last 30 days (>2σ above mean)`, type: 'positive' });
  if (dropCount > 0) insights.push({ icon: '\uD83D\uDCC9', text: `${dropCount} unusual drop${dropCount > 1 ? 's' : ''} detected in the last 30 days (>2σ below mean)`, type: 'warning' });
}
const topGainer = gainers[0];
if (topGainer) {
  const gName = (topGainer.name ?? '').replace('@mcptoolshop/', '');
  const gCurr = topGainer.week ?? 0;
  const gPrev = topGainer.delta7 !== undefined ? gCurr - topGainer.delta7 : null;
  if ((gPrev ?? 0) < BASELINE_THRESHOLD) {
    insights.push({ icon: '\uD83D\uDE80', text: `${gName} emerged with +${fmtCompact.format(topGainer.delta7 ?? gCurr)} downloads \u2014 fastest growing package (new)`, type: 'positive' });
  } else {
    const cappedPct = Math.min(PCT_CAP, Math.abs(Math.round(topGainer.trendPct ?? 0)));
    insights.push({ icon: '\uD83D\uDE80', text: `${gName} surged ${cappedPct}${Math.abs(topGainer.trendPct ?? 0) > PCT_CAP ? '+' : ''}% (+${fmtCompact.format(Math.abs(topGainer.delta7 ?? 0))}) \u2014 fastest growing package`, type: 'positive' });
  }
}
const topDecliner = decliners[0];
if (topDecliner) {
  const dName = (topDecliner.name ?? '').replace('@mcptoolshop/', '');
  const dPct = Math.abs(Math.round(topDecliner.trendPct ?? 0));
  insights.push({ icon: '\u26A0\uFE0F', text: `${dName} declining ${Math.min(dPct, PCT_CAP)}${dPct > PCT_CAP ? '+' : ''}% for consecutive periods`, type: 'warning' });
}
if (attentionPkgs.length > 0) insights.push({ icon: '\uD83D\uDD0D', text: `${attentionPkgs.length} package${attentionPkgs.length > 1 ? 's' : ''} showing sustained decline \u2014 may need attention`, type: 'warning' });

// Registry dependency
const npmPctOfTotal = totalWeekAll > 0 ? Math.round(Number((registryTotals as any).npm?.week ?? 0) / totalWeekAll * 100) : 0;
if (npmPctOfTotal > 70) insights.push({ icon: '\uD83C\uDFAF', text: `${npmPctOfTotal}% of downloads from npm — consider diversifying to PyPI/NuGet`, type: 'info' });

const chartPayload = !missing && data ? JSON.stringify({
  sparkline30,
  registryTotals,
  perRegistryDaily,
  top5Daily,
  anomalies,
  monthOverMonthPct,
  gini,
  median,
  p90,
  top3Pct,
  insights,
  attentionPkgs,
  npmPctOfTotal,
  leaderboard: velocityBoard,
}) : null;

const chatContext = !missing && data ? JSON.stringify({
  totals: data.totals,
  registryTotals,
  sparkline30,
  movers: data.movers,
  narrative: data.narrative,
  narrativeLines: data.narrativeLines,
  healthScore,
  weekDelta,
  weekDeltaPct: Math.round(weekDeltaPct * 10) / 10,
  diversityIndex: parseFloat(diversityIndex.toFixed(2)),
  registryCoverage: okRegistries + '/' + totalRegistries,
  errorCount: (data.errors || []).length,
  fetchedAt: data.fetchedAt,
  leaderboard: (leaderboard as any[]).slice(0, 30).map((r: any) => ({
    name: (r.name ?? '').replace('@mcptoolshop/', ''),
    registry: r.registry,
    week: r.week,
    month: r.month,
    trendPct: r.trendPct,
  })),
}) : null;
---

<AppShell
  title="Dashboard — Registry Pulse"
  description="Live download statistics across npm, PyPI, NuGet, VS Code Marketplace, and Docker Hub"
>
  <AppNav active="dashboard" hasSnapshot={!missing} />

  <div class="mx-auto max-w-6xl px-4">
    {/* ── Guard panel — no snapshot ── */}
    {missing && (
      <div class="py-10">
        <div class="rounded-xl border border-edge bg-surface-raised p-6">
          <div class="text-sm font-semibold text-heading">No snapshot available</div>
          <div class="mt-1 text-sm text-dim">
            Configure your portfolio and generate a snapshot in Setup.
          </div>
          <div class="mt-4">
            <a
              class="inline-block px-4 py-2 rounded-md bg-action text-action-text text-sm font-medium hover:bg-action-hover transition-colors"
              href={`${base}/setup/`}
            >
              Go to Setup
            </a>
          </div>
        </div>
      </div>
    )}

    <div id="dashboard-content" class:list={[{ hidden: missing || !data }]}>
      {/* ── Title ── */}
      <div class="mt-8 mb-6">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <h1 class="text-3xl font-semibold tracking-tight text-heading">Dashboard</h1>
            <p class="mt-2 text-dim">
              Weekly + monthly stats across registries.
              {!missing && data && (
                <span
                  id="updated-at"
                  class="ml-2 text-muted cursor-help"
                  title={new Date(data.fetchedAt).toUTCString()}
                  data-fetched={data.fetchedAt}
                >
                  Updated {relativeTime(data.fetchedAt)}.
                </span>
              )}
            </p>
          </div>
        </div>
      </div>

      {/* ── Tab bar ── */}
      <nav class="flex gap-1 border-b border-edge mb-6" role="tablist" id="tab-bar">
        <button role="tab" data-tab="home" class="tab-btn tab-active" aria-selected="true">Home</button>
        <button role="tab" data-tab="analytics" class="tab-btn" aria-selected="false">Analytics</button>
        <button role="tab" data-tab="leaderboard" class="tab-btn" aria-selected="false">Leaderboard</button>
        <button role="tab" data-tab="help" class="tab-btn" aria-selected="false">Help</button>
      </nav>

      {/* ── Tab: Home ── */}
      <div id="tab-home" class="tab-panel" role="tabpanel">

      {/* ── Ollama Chat ── */}
      <section id="chat-section" class="mb-8">
        <div class="rounded-2xl border border-edge bg-surface-raised/50 p-5">
          <div class="flex items-center justify-between gap-3 flex-wrap mb-4">
            <div>
              <h2 class="text-lg font-semibold text-heading flex items-center gap-2">
                <span class="text-xl">{"\uD83E\uDD99"}</span> Pulse
              </h2>
              <p class="mt-0.5 text-xs text-dim">Your registry co-pilot &bull; Powered by Ollama</p>
            </div>
            <div class="flex items-center gap-3">
              <div id="ollama-status" class="flex items-center gap-1.5 text-xs">
                <span id="ollama-dot" class="inline-block w-2 h-2 rounded-full bg-zinc-500"></span>
                <span id="ollama-label" class="text-dim">Checking…</span>
              </div>
              <select id="ollama-model" class="rounded-lg border border-edge bg-surface px-2.5 py-1.5 text-xs text-heading disabled:opacity-50" disabled>
                <option>No models</option>
              </select>
              <button id="chat-clear" class="text-xs text-dim hover:text-heading transition-colors" title="Clear history">Clear</button>
              <div id="voice-controls" class="hidden flex items-center gap-1.5">
                <span id="voice-dot" class="inline-block w-2 h-2 rounded-full bg-emerald-400"></span>
                <select id="voice-select" class="rounded-lg border border-edge bg-surface px-2 py-1 text-xs text-heading">
                  <option value="bm_george">George (Narrator)</option>
                  <option value="af_bella">Bella (Assistant)</option>
                  <option value="bf_emma">Emma (Storyteller)</option>
                  <option value="am_michael">Michael (Announcer)</option>
                </select>
                <button id="voice-auto-btn" class="text-dim hover:text-heading transition-colors" title="Toggle auto-speak">
                  <svg id="voice-auto-on" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M11 5L6 9H2v6h4l5 4V5z"></path></svg>
                  <svg id="voice-auto-off" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.586 15H2v-6h4l5-4v14l-3.29-2.71M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg>
                </button>
              </div>
              <button id="chat-settings-btn" class="text-dim hover:text-heading transition-colors" title="Data connectors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><circle cx="12" cy="12" r="3"></circle></svg>
              </button>
              <button id="chat-fullscreen-btn" class="text-dim hover:text-heading transition-colors" title="Toggle fullscreen">
                <svg id="chat-expand-icon" class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4h4M20 8V4h-4M4 16v4h4M20 16v4h-4"></path></svg>
                <svg id="chat-collapse-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 4v4H4M15 4v4h5M9 20v-4H4M15 20v-4h5"></path></svg>
              </button>
            </div>
          </div>

          <!-- Settings panel -->
          <div id="chat-settings-panel" class="hidden mb-4 rounded-xl border border-edge bg-surface p-4">
            <div class="flex items-center justify-between mb-3">
              <div class="text-sm font-semibold text-heading">Data Connectors</div>
              <button id="chat-settings-close" class="text-xs text-dim hover:text-heading transition-colors">Close</button>
            </div>
            <div class="space-y-4">
              <!-- Voice Server -->
              <div>
                <label class="block text-xs font-medium text-heading mb-1">Voice Server</label>
                <div class="flex items-center gap-2">
                  <span id="voice-status-dot" class="inline-block w-2 h-2 rounded-full bg-zinc-500"></span>
                  <span id="voice-status-label" class="text-xs text-dim">Checking…</span>
                  <button id="voice-check-btn" class="ml-auto rounded-lg border border-edge px-3 py-1.5 text-xs text-heading hover:bg-surface-strong transition-colors">Check</button>
                </div>
                <div id="voice-install-hint" class="hidden mt-2 rounded-lg border border-amber-500/30 bg-amber-500/10 p-2.5 text-[11px] text-dim">
                  <p class="font-medium text-heading mb-1">Voice server not detected</p>
                  <p class="mb-1.5">To enable voice, run this once:</p>
                  <code class="block bg-surface-strong rounded px-2 py-1 text-[11px] text-heading select-all">PORT=11435 npx @mcptoolshop/voice-soundboard-mcp</code>
                  <p class="mt-1.5">It auto-downloads the TTS model (~310 MB) on first run. After that, add it to startup for hands-free operation.</p>
                </div>
              </div>
              <!-- GitHub PAT -->
              <div>
                <label class="block text-xs font-medium text-heading mb-1">GitHub Personal Access Token</label>
                <div class="flex gap-2">
                  <input id="gh-pat-input" type="password" placeholder="ghp_..."
                    class="flex-1 rounded-lg border border-edge bg-surface-strong px-3 py-1.5 text-xs text-heading placeholder:text-dim focus:outline-none focus:ring-2 focus:ring-accent/40" />
                  <button id="gh-pat-save" class="rounded-lg bg-action text-action-text px-3 py-1.5 text-xs font-medium hover:bg-action-hover transition-colors">Save &amp; Test</button>
                </div>
                <div id="gh-pat-status" class="mt-1.5 text-xs text-dim"></div>
                <p class="mt-1 text-[11px] text-dim">Read-only token for <code class="text-heading">mcp-tool-shop-org</code>. Stored locally, never sent anywhere except GitHub API.</p>
              </div>
            </div>
          </div>

          <div id="chat-messages" class="rounded-xl border border-edge bg-surface p-4 min-h-[180px] max-h-[420px] overflow-y-auto space-y-3">
            <div class="text-sm text-dim text-center py-8">Hey — ask me anything about your numbers, trends, or what to ship next.</div>
          </div>

          <div id="chat-progress" class="mt-2 hidden">
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-dim flex items-center gap-1.5">
                <svg class="chat-spinner" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
                  <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
                </svg>
                <span id="chat-progress-label">Thinking…</span>
              </span>
              <span id="chat-elapsed" class="text-xs text-dim tabular-nums">0.0s</span>
            </div>
            <div class="h-1 rounded-full bg-surface-strong overflow-hidden">
              <div id="chat-progress-bar" class="h-1 rounded-full bg-accent chat-progress-bar"></div>
            </div>
          </div>

          <!-- Voice banner — visible when server is offline -->
          <div id="voice-banner" class="mt-3 rounded-xl border border-amber-500/30 bg-amber-500/10 px-4 py-2.5 flex items-center justify-between gap-3">
            <div class="flex items-center gap-2 text-xs text-dim">
              <svg class="w-4 h-4 text-amber-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M11 5L6 9H2v6h4l5 4V5z"></path></svg>
              <span>Voice is available but the server isn't running.</span>
            </div>
            <button id="voice-banner-help" class="flex-shrink-0 rounded-lg border border-edge px-3 py-1 text-xs text-heading hover:bg-surface-strong transition-colors">How to start</button>
          </div>

          <div class="mt-3 flex gap-2">
            <input id="chat-input" type="text" placeholder="What's on your mind?"
              class="flex-1 rounded-xl border border-edge bg-surface px-4 py-2.5 text-sm text-heading placeholder:text-dim focus:outline-none focus:ring-2 focus:ring-accent/40 disabled:opacity-50"
              disabled />
            <button id="chat-send" class="rounded-xl bg-action text-action-text px-5 py-2.5 text-sm font-medium hover:bg-action-hover transition-colors disabled:opacity-50 flex items-center gap-2" disabled>
              <svg id="send-spinner" class="chat-spinner hidden" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <circle cx="12" cy="12" r="10" stroke-opacity="0.25"/>
                <path d="M12 2a10 10 0 0 1 10 10" stroke-linecap="round"/>
              </svg>
              <span id="send-label">Send</span>
            </button>
          </div>
        </div>
      </section>

      {/* ── Summary cards ── */}
      <section id="summary" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Summary</h2>
        <p class="mt-1 text-sm text-dim">Grand totals across all registries.</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Total packages</div>
            <div id="stat-packages" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmt.format(totals.packages) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Weekly downloads</div>
            <div id="stat-weekly" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmtCompact.format(totals.week) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Monthly downloads</div>
            <div id="stat-monthly" class="mt-2 text-3xl font-semibold text-heading">{totals ? fmtCompact.format(totals.month) : '\u2014'}</div>
          </div>
          <div class="rounded-2xl border border-edge bg-surface-raised p-5">
            <div class="text-sm text-dim">Top-5 concentration</div>
            <div id="stat-concentration" class="mt-2 text-3xl font-semibold text-heading">{concentrationPct}%</div>
            <div class="mt-1 text-xs text-dim">of weekly downloads</div>
          </div>
        </div>
      </section>

      {/* ── Growth Pulse + Data Health ── */}
      <section id="pulse" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Pulse</h2>
        <p class="mt-1 text-sm text-dim">Growth signals and data reliability at a glance.</p>
        <div class="mt-4 grid gap-6 lg:grid-cols-2">

          {/* Growth Pulse — redesigned for clarity */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Growth Pulse</h3>
            </div>

            {/* One-line executive summary */}
            <p id="pulse-summary" class="mt-2 text-sm text-muted leading-relaxed">
              <span id="pulse-conc" data-value={concentrationPct} class="hidden">{concentrationPct}</span>
              {pulseSummary}
            </p>

            <div class="mt-5 grid gap-5 sm:grid-cols-2">
              {/* ── Column A: Established Movers (prev ≥ 50) ── */}
              <div>
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-semibold uppercase tracking-wider text-emerald-400">Established Movers</span>
                  <span class="text-[10px] text-dim">(prev &ge; 50/wk)</span>
                </div>

                <ul id="pulse-established" class="space-y-3">
                  {establishedGainers.length > 0 ? establishedGainers.map((r: any) => {
                    const curr = moverCurr(r); const prev = moverPrev(r);
                    const delta = curr - prev; const pct = r.trendPct;
                    const name = (r.name ?? '').replace('@mcptoolshop/', '');
                    const dispName = name.length > 22 ? name.slice(0, 20) + '\u2026' : name;
                    const pctR = pct !== null && pct !== undefined ? Math.round(Math.min(Math.abs(pct), PCT_CAP) * 10) / 10 : null;
                    const arrow = delta >= 0 ? '\u25B2' : '\u25BC';
                    const color = delta >= 0 ? 'text-emerald-400' : 'text-rose-400';
                    // Find range30 from leaderboard for sparkline
                    const lb = leaderboard.find((x: any) => x.name === r.name);
                    const spark = lb?.range30 ? miniSparkSvg(lb.range30) : '';
                    return (
                    <li class="pulse-row">
                      <div class="flex items-center justify-between gap-2">
                        <span class="pulse-name text-heading" title={r.name}>{dispName}</span>
                        <span class={`pulse-delta tabular-nums font-semibold ${color}`}>
                          {delta >= 0 ? '+' : ''}{fmt.format(delta)}
                        </span>
                      </div>
                      <div class="flex items-center justify-between gap-2 mt-0.5">
                        <span class="text-[11px] text-dim tabular-nums">
                          {pctR !== null ? `${arrow} ${pctR}${Math.abs(pct ?? 0) > PCT_CAP ? '+' : ''}% vs prior week` : ''}
                        </span>
                        <span class="text-[11px] text-dim tabular-nums">
                          {fmt.format(prev)} &rarr; {fmt.format(curr)}
                          <Fragment set:html={spark} />
                        </span>
                      </div>
                    </li>
                    );
                  }) : (
                    <li class="text-xs text-dim">No established gainers this week</li>
                  )}
                </ul>

                {/* Established decliners */}
                {establishedDecliners.length > 0 && (
                  <div class="mt-4">
                    <div class="text-xs font-semibold text-rose-400 mb-2 flex items-center gap-1">
                      <span>{'\u25BC'}</span> Decliners
                    </div>
                    <ul id="pulse-decliners" class="space-y-3">
                      {establishedDecliners.map((r: any) => {
                        const curr = moverCurr(r); const prev = moverPrev(r);
                        const delta = curr - prev;
                        const pctR = r.trendPct !== null && r.trendPct !== undefined ? Math.round(Math.min(Math.abs(r.trendPct), PCT_CAP) * 10) / 10 : null;
                        const name = (r.name ?? '').replace('@mcptoolshop/', '');
                        const dispName = name.length > 22 ? name.slice(0, 20) + '\u2026' : name;
                        const lb = leaderboard.find((x: any) => x.name === r.name);
                        const spark = lb?.range30 ? miniSparkSvg(lb.range30) : '';
                        return (
                        <li class="pulse-row">
                          <div class="flex items-center justify-between gap-2">
                            <span class="pulse-name text-heading" title={r.name}>{dispName}</span>
                            <span class="pulse-delta tabular-nums font-semibold text-rose-400">
                              {fmt.format(delta)}
                            </span>
                          </div>
                          <div class="flex items-center justify-between gap-2 mt-0.5">
                            <span class="text-[11px] text-dim tabular-nums">
                              {pctR !== null ? `\u25BC ${pctR}% vs prior week` : ''}
                            </span>
                            <span class="text-[11px] text-dim tabular-nums">
                              {fmt.format(prev)} &rarr; {fmt.format(curr)}
                              <Fragment set:html={spark} />
                            </span>
                          </div>
                        </li>
                        );
                      })}
                    </ul>
                  </div>
                )}
              </div>

              {/* ── Column B: Emerging + Newly Active ── */}
              <div>
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-xs font-semibold uppercase tracking-wider text-amber-400">Emerging &amp; New</span>
                  <span class="text-[10px] text-dim">(prev &lt; 50 or first week)</span>
                </div>

                <ul id="pulse-emerging" class="space-y-3">
                  {emergingAll.length > 0 ? emergingAll.map((r: any) => {
                    const curr = moverCurr(r); const prev = moverPrev(r);
                    const delta = curr - prev;
                    const isNew = r.trendPct === null && prev === 0 && curr > 0;
                    const name = (r.name ?? '').replace('@mcptoolshop/', '');
                    const dispName = name.length > 22 ? name.slice(0, 20) + '\u2026' : name;
                    const lb = leaderboard.find((x: any) => x.name === r.name);
                    const spark = lb?.range30 ? miniSparkSvg(lb.range30) : '';
                    return (
                    <li class="pulse-row">
                      <div class="flex items-center justify-between gap-2">
                        <span class="pulse-name text-heading" title={r.name}>
                          {dispName}
                          {isNew && <span class="ml-1.5 text-[10px] font-semibold uppercase bg-amber-400/15 text-amber-400 px-1.5 py-0.5 rounded">new</span>}
                        </span>
                        <span class="pulse-delta tabular-nums font-semibold text-amber-400">
                          +{fmt.format(delta > 0 ? delta : curr)}
                        </span>
                      </div>
                      <div class="flex items-center justify-between gap-2 mt-0.5">
                        <span class="text-[11px] text-dim tabular-nums">
                          {isNew ? 'zero \u2192 active this week' : prev > 0 ? `from base of ${fmt.format(prev)}/wk` : 'first activity'}
                        </span>
                        <span class="text-[11px] text-dim tabular-nums">
                          {fmt.format(curr)}/wk
                          <Fragment set:html={spark} />
                        </span>
                      </div>
                    </li>
                    );
                  }) : (
                    <li class="text-xs text-dim">No emerging packages this week</li>
                  )}
                </ul>
              </div>
            </div>

            <div class="mt-5 text-[11px] text-dim">
              Movers computed from npm 30-day ranges (last 7 vs prior 7). Established = prior week &ge; 50 downloads. Inline sparklines show 7-day trend.
            </div>
          </div>

          {/* Data Health */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Data Health</h3>
              <div id="health-error-count" class="text-sm text-dim">
                Errors: <span class="font-medium text-muted">{data?.errors?.length ?? 0}</span>
              </div>
            </div>

            <div id="health-rows" class="mt-5 space-y-3">
              {data && Object.entries(data.manifestCounts ?? {}).map(([reg, expected]: [string, any]) => {
                const fetched = (data.fetchedCounts as any)?.[reg] ?? 0;
                const conf = (data.confidence as any)?.[reg] ?? 'missing';
                const badge = confidenceBadge(conf);
                const regErrors = (data.errorsByRegistry as any)?.[reg] ?? 0;
                return (
                  <div class="flex items-center justify-between gap-3 rounded-xl border border-edge px-4 py-3">
                    <div class="flex items-center gap-2">
                      <span>{badge}</span>
                      <span class="font-medium text-heading">{registryLabel(reg)}</span>
                    </div>
                    <div class="text-sm text-dim tabular-nums">
                      {fetched}/{expected} fetched
                      {regErrors > 0 && (
                        <span class="ml-2 text-amber-400">({regErrors} issues)</span>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>

            <div id="health-errors-detail">
              {data && (data.errors?.length ?? 0) > 0 && (
                <details class="mt-4 rounded-xl border border-edge p-4">
                  <summary class="cursor-pointer text-sm font-medium text-heading">View fetch issues</summary>
                  <ul class="mt-3 space-y-2 text-xs text-dim">
                    {(data.errors as any[]).slice(0, 12).map((e: any) => (
                      <li class="flex gap-2">
                        <code class="text-muted shrink-0">{e.scope}</code>
                        <span class="truncate">{e.message}</span>
                      </li>
                    ))}
                  </ul>
                  {(data.errors as any[]).length > 12 && (
                    <div class="mt-2 text-xs text-dim">Showing first 12. See stats.json for full list.</div>
                  )}
                </details>
              )}
            </div>

            <div id="health-freshness" class="mt-4 text-xs text-dim">
              {data && (<>Freshness: updated {relativeTime(data.fetchedAt)} &bull; {Object.values(data.confidence ?? {}).filter((c: any) => c === 'ok').length}/{Object.keys(data.confidence ?? {}).length} registries OK</>)}
            </div>
          </div>

        </div>
      </section>

      {/* ── Registry breakdown + sparkline ── */}
      <section id="breakdown" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Breakdown</h2>
        <p class="mt-1 text-sm text-dim">Per-registry weekly downloads and 30-day activity.</p>
        <div class="mt-4 grid gap-6 lg:grid-cols-3">
          <div class="lg:col-span-2 rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap">
              <h3 class="text-lg font-semibold text-heading">Per-registry (weekly)</h3>
              <div id="breakdown-max" class="text-sm text-dim">
                Max: <span class="font-medium text-muted">{fmtCompact.format(maxBar)}</span>
              </div>
            </div>

            <div id="breakdown-bars" class="mt-5 space-y-4">
              {Object.entries(registryTotals).map(([key, r]: [string, any]) => (
                <div>
                  <div class="flex items-center justify-between text-sm">
                    <div class="font-medium text-heading">
                      {registryLabel(key)}
                      {(key === 'vscode' || key === 'nuget') && (
                        <span class="ml-1.5 text-xs text-dim font-normal">(all-time installs)</span>
                      )}
                      {key === 'docker' && (
                        <span class="ml-1.5 text-xs text-dim font-normal">(all-time pulls)</span>
                      )}
                    </div>
                    <div class="text-dim">
                      <span class="text-muted font-medium">{fmtCompact.format(
                        ['vscode','nuget','docker'].includes(key) ? (r.total ?? r.week) : r.week
                      )}</span>
                      <span class="mx-2 text-edge">&bull;</span>
                      {fmt.format(r.packages)} pkg
                    </div>
                  </div>
                  <div class="mt-2 h-2 rounded-full bg-surface-strong overflow-hidden">
                    <div
                      class="h-2 rounded-full bg-accent"
                      style={`width:${Math.round((Number(
                        ['vscode','nuget','docker'].includes(key) ? (r.total ?? r.week) : r.week
                      ) / maxBar) * 100)}%`}
                    />
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <h3 class="text-lg font-semibold text-heading">30-day activity</h3>
            <p class="mt-1 text-sm text-dim">
              Aggregate npm daily downloads.
            </p>

            <div id="sparkline-agg" class="sparkline mt-5" aria-label="30-day sparkline">
              {sparkline30.map((n: number) => (
                <span
                  class="spark"
                  style={`height:${Math.max(2, Math.round((Number(n) / sparkMax) * 100))}%`}
                  title={`${fmt.format(n)} downloads`}
                />
              ))}
            </div>
          </div>
        </div>
      </section>

      </div>{/* close tab-home */}

      {/* ── Tab: Analytics ── */}
      <div id="tab-analytics" class="tab-panel hidden" role="tabpanel">

      {/* ── Executive Snapshot ── */}
      <div id="exec-snapshot" class:list={["mb-6 rounded-2xl border border-edge bg-surface-raised/50 p-5", { hidden: missing || !(data?.narrativeLines || data?.narrative) }]}>
        <div class="flex items-start justify-between gap-4 flex-wrap mb-3">
          <div class="text-xs font-medium tracking-wide uppercase text-dim">Executive snapshot</div>
          <div id="exec-meta" class="text-xs text-dim whitespace-nowrap text-right">
            {!missing && data && (<>Source: build-time fetch<br />{new Date(data.fetchedAt).toUTCString()}</>)}
          </div>
        </div>
        <div id="exec-metrics" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-4">
          <div class="rounded-xl border border-edge bg-surface p-3">
            <div class="text-[10px] text-dim uppercase tracking-wide">Health Score</div>
            <div class="mt-1 flex items-center gap-2">
              <span id="exec-health" class="text-2xl font-bold tabular-nums text-heading">{healthScore}</span>
              <div class="flex-1 h-2 rounded-full bg-surface-strong overflow-hidden">
                <div class="h-2 rounded-full transition-all" id="exec-health-bar" style={`width:${healthScore}%;background:${healthScore >= 70 ? 'var(--color-accent)' : healthScore >= 40 ? '#f59e0b' : '#ef4444'}`} />
              </div>
            </div>
          </div>
          <div class="rounded-xl border border-edge bg-surface p-3">
            <div class="text-[10px] text-dim uppercase tracking-wide">Weekly Δ (npm)</div>
            <div class="mt-1">
              <span id="exec-delta" class={`text-2xl font-bold tabular-nums ${weekDelta >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>
                {weekDelta >= 0 ? '+' : ''}{fmtCompact.format(weekDelta)}
              </span>
              <span id="exec-delta-pct" class={`ml-1 text-sm ${weekDeltaPct >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>
                ({weekDeltaPct >= 0 ? '+' : ''}{Math.round(weekDeltaPct * 10) / 10}%)
              </span>
            </div>
          </div>
          <div class="rounded-xl border border-edge bg-surface p-3">
            <div class="text-[10px] text-dim uppercase tracking-wide">Diversity Index</div>
            <div class="mt-1">
              <span id="exec-diversity" class="text-2xl font-bold tabular-nums text-heading">{diversityIndex.toFixed(2)}</span>
              <span class="ml-1 text-xs text-dim">Shannon (norm.)</span>
            </div>
          </div>
          <div class="rounded-xl border border-edge bg-surface p-3">
            <div class="text-[10px] text-dim uppercase tracking-wide">Registry Coverage</div>
            <div class="mt-1">
              <span id="exec-coverage" class="text-2xl font-bold tabular-nums text-heading">{okRegistries}/{totalRegistries}</span>
              <span class="ml-1 text-xs text-dim">OK</span>
            </div>
          </div>
        </div>
        <div id="exec-lines" class="space-y-2.5">
          {data?.narrativeLines ? data.narrativeLines.map((line: { icon: string; label: string; text: string }) => (
            <div class="flex items-start gap-3">
              <span class="text-lg leading-6 shrink-0">{line.icon}</span>
              <div>
                <span class="text-xs font-semibold uppercase tracking-wide text-accent">{line.label}</span>
                <span class="text-sm text-heading ml-2">{line.text}</span>
              </div>
            </div>
          )) : data?.narrative ? (
            <div class="text-base font-medium text-heading">{data.narrative}</div>
          ) : null}
        </div>
      </div>

      {/* ── Portfolio Intelligence ── */}
      <div class="mb-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-5">
        <div class="rounded-xl border border-edge bg-surface-raised p-4">
          <div class="text-[10px] text-dim uppercase tracking-wide">Weekly Downloads</div>
          <div class="mt-1 text-2xl font-bold tabular-nums text-heading">{totals ? fmtCompact.format(totals.week) : '\u2014'}</div>
          <div class={`mt-0.5 text-xs tabular-nums ${weekDeltaPct >= 0 ? 'text-emerald-400' : 'text-rose-400'}`}>
            {weekDeltaPct >= 0 ? '\u25B2' : '\u25BC'} {Math.abs(Math.round(weekDeltaPct * 10) / 10)}% vs prev week
          </div>
        </div>
        <div class="rounded-xl border border-edge bg-surface-raised p-4">
          <div class="text-[10px] text-dim uppercase tracking-wide">30-Day Total</div>
          <div class="mt-1 text-2xl font-bold tabular-nums text-heading">{fmtCompact.format(last30Sum)}</div>
          <div class="mt-0.5 text-xs text-dim">{n} packages tracked</div>
        </div>
        <div class="rounded-xl border border-edge bg-surface-raised p-4">
          <div class="text-[10px] text-dim uppercase tracking-wide">Concentration</div>
          <div class="mt-1 text-2xl font-bold tabular-nums text-heading">{top3Pct}%</div>
          <div class="mt-0.5 text-xs text-dim">from top 3 packages</div>
        </div>
        <div class="rounded-xl border border-edge bg-surface-raised p-4">
          <div class="text-[10px] text-dim uppercase tracking-wide">Gini Index</div>
          <div class="mt-1 text-2xl font-bold tabular-nums text-heading">{gini.toFixed(2)}</div>
          <div class="mt-0.5 text-xs text-dim">{gini > 0.7 ? 'High skew' : gini > 0.4 ? 'Moderate' : 'Well distributed'}</div>
        </div>
        <div class="rounded-xl border border-edge bg-surface-raised p-4">
          <div class="text-[10px] text-dim uppercase tracking-wide">npm Dependency</div>
          <div class="mt-1 text-2xl font-bold tabular-nums text-heading">{npmPctOfTotal}%</div>
          <div class="mt-0.5 text-xs text-dim">{npmPctOfTotal > 70 ? 'Consider diversifying' : 'Balanced mix'}</div>
        </div>
      </div>

      {/* ── Actionable Insights ── */}
      {insights.length > 0 && (
        <div class="mb-6 rounded-2xl border border-edge bg-surface-raised/50 p-5">
          <div class="text-xs font-medium tracking-wide uppercase text-dim mb-3">Actionable Insights</div>
          <div class="space-y-2">
            {insights.map((ins) => (
              <div class={`flex items-start gap-3 rounded-lg px-3 py-2 text-sm ${ins.type === 'warning' ? 'bg-amber-500/5 border border-amber-500/20' : ins.type === 'positive' ? 'bg-emerald-500/5 border border-emerald-500/20' : 'bg-blue-500/5 border border-blue-500/20'}`}>
                <span class="text-base shrink-0">{ins.icon}</span>
                <span class="text-heading">{ins.text}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* ── Packages Needing Attention ── */}
      {attentionPkgs.length > 0 && (
        <div class="mb-6 rounded-2xl border border-amber-500/20 bg-amber-500/5 p-5">
          <div class="text-xs font-medium tracking-wide uppercase text-amber-400 mb-3">{'\uD83D\uDD0D'} Needs Attention</div>
          <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
            {attentionPkgs.map((pkg) => (
              <div class="flex items-center justify-between rounded-lg border border-edge bg-surface px-3 py-2">
                <span class="text-sm font-medium text-heading truncate">{pkg.name}</span>
                <span class={`text-xs tabular-nums ${pkg.growthCls}`}>
                  {pkg.growthText}
                </span>
              </div>
            ))}
          </div>
        </div>
      )}

        <section class="mb-8">
          <h2 class="text-xl font-semibold text-heading">Charts</h2>
          <p class="mt-1 text-sm text-dim">Portfolio intelligence — from activity to insight.</p>

          {/* ── 1. 30-Day Trend (upgraded) ── */}
          <div class="mt-6 rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap mb-1">
              <div>
                <h3 class="text-lg font-semibold text-heading">30-Day Download Trend</h3>
                <p class="mt-0.5 text-sm text-dim">Registry split • anomaly flags • 7d moving average</p>
              </div>
              <div class="flex items-center gap-2" id="trend-toggles">
                <button class="trend-toggle active" data-mode="aggregate">Aggregate</button>
                <button class="trend-toggle" data-mode="registry">Per Registry</button>
                <button class="trend-toggle" data-mode="top5">Top 5</button>
              </div>
            </div>
            <div class="mt-2 flex items-center gap-4 text-xs text-dim flex-wrap" id="trend-summary"></div>
            <div class="mt-3" style="position:relative;height:280px;">
              <canvas id="chart-trend"></canvas>
            </div>
          </div>

          <div class="mt-6 grid gap-6 lg:grid-cols-2">

            {/* ── 2. Registry Share (upgraded → stacked bar + metrics) ── */}
            <div class="rounded-2xl border border-edge bg-surface-raised p-6">
              <h3 class="text-lg font-semibold text-heading">Registry Share</h3>
              <p class="mt-0.5 text-sm text-dim">Weekly distribution with absolute + delta.</p>
              <div id="registry-share-stats" class="mt-3 space-y-2"></div>
              <div class="mt-4" style="position:relative;height:220px;">
                <canvas id="chart-share"></canvas>
              </div>
            </div>

            {/* ── 3. Download Distribution (upgraded) ── */}
            <div class="rounded-2xl border border-edge bg-surface-raised p-6">
              <h3 class="text-lg font-semibold text-heading">Portfolio Risk Analysis</h3>
              <p class="mt-0.5 text-sm text-dim">Distribution • median/P90 • Gini concentration.</p>
              <div id="dist-metrics" class="mt-3 flex items-center gap-4 text-xs flex-wrap"></div>
              <div class="mt-3" style="position:relative;height:220px;">
                <canvas id="chart-distribution"></canvas>
              </div>
            </div>

            {/* ── 4. Top 10 Packages (upgraded → momentum) ── */}
            <div class="rounded-2xl border border-edge bg-surface-raised p-6">
              <h3 class="text-lg font-semibold text-heading">Top 10 — Momentum</h3>
              <p class="mt-0.5 text-sm text-dim">Downloads + velocity + rank movement.</p>
              <div class="mt-4" style="position:relative;height:300px;">
                <canvas id="chart-top10"></canvas>
              </div>
              <div id="momentum-legend" class="mt-3 grid gap-2 sm:grid-cols-2"></div>
            </div>

            {/* ── 5. Velocity Tracker ── */}
            <div class="rounded-2xl border border-edge bg-surface-raised p-6">
              <h3 class="text-lg font-semibold text-heading">Velocity Tracker</h3>
              <p class="mt-0.5 text-sm text-dim">7-day growth rate per package with trend sparklines.</p>
              <div id="velocity-list" class="mt-4 space-y-2 max-h-[300px] overflow-y-auto"></div>
            </div>
          </div>

          {/* ── 6. Heatmap (upgraded) ── */}
          <div class="mt-6 rounded-2xl border border-edge bg-surface-raised p-6">
            <div class="flex items-center justify-between gap-3 flex-wrap mb-1">
              <div>
                <h3 class="text-lg font-semibold text-heading">30-Day Heatmap</h3>
                <p class="mt-0.5 text-sm text-dim">Sorted by total. Hover for details. Anomalies flagged.</p>
              </div>
              <div class="flex items-center gap-2" id="heatmap-controls">
                <button class="trend-toggle active" data-heatmode="all">All</button>
                <button class="trend-toggle" data-heatmode="spikes">Spikes Only (&gt;2σ)</button>
              </div>
            </div>
            <div class="mt-4 overflow-x-auto relative">
              <canvas id="chart-heatmap"></canvas>
              <div id="heatmap-tooltip" class="absolute hidden rounded-lg border border-edge bg-surface-raised px-3 py-2 text-xs shadow-lg pointer-events-none" style="z-index:10"></div>
            </div>
          </div>
        </section>
      </div>

      {/* ── Tab: Leaderboard ── */}
      <div id="tab-leaderboard" class="tab-panel hidden" role="tabpanel">

      {/* ── Leaderboard ── */}
      <section id="leaderboard" class="mb-8">
        <h2 class="text-xl font-semibold text-heading">Leaderboard</h2>
        <p class="mt-1 text-sm text-dim">Sorted by downloads. npm/PyPI = weekly; VS Code/NuGet/Docker = all-time total. Trend = last 7 vs prior 7 (npm only).</p>
        <div class="mt-4 rounded-2xl border border-edge overflow-hidden">
          <div class="p-4 flex items-center justify-between gap-4 flex-wrap bg-surface-raised">
            <div class="text-sm text-dim">
              Showing <span id="leaderboard-count" class="font-medium text-muted">{leaderboard.length}</span> packages
            </div>
            <div class="text-xs text-dim">
              npm/PyPI = last 7d &bull; VS Code/NuGet/Docker = all-time
            </div>
          </div>

          <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
              <thead class="bg-surface-strong text-dim">
                <tr>
                  <th class="text-left font-medium px-5 py-3">#</th>
                  <th class="text-left font-medium px-5 py-3">Package</th>
                  <th class="text-left font-medium px-5 py-3">Registry</th>
                  <th class="text-right font-medium px-5 py-3">Downloads</th>
                  <th class="text-right font-medium px-5 py-3">Month</th>
                  <th class="text-center font-medium px-3 py-3">30d</th>
                  <th class="text-right font-medium px-5 py-3">Trend</th>
                </tr>
              </thead>
              <tbody id="leaderboard-body">
                {leaderboard.map((row: any, i: number) => {
                  const prevW = row.range30?.length === 30 ? row.range30.slice(-14, -7).reduce((a: number, b: number) => a + Number(b), 0) : null;
                  const currW = row.range30?.length === 30 ? row.range30.slice(-7).reduce((a: number, b: number) => a + Number(b), 0) : row.week;
                  const t = trendBadge(row.trendPct, prevW, currW);
                  const hasSparkline = row.range30 && row.range30.length === 30;
                  const rowSparkMax = hasSparkline ? Math.max(1, ...row.range30) : 1;
                  return (
                    <tr class="border-t border-edge-subtle hover:bg-surface-raised/50">
                      <td class="px-5 py-3 text-dim tabular-nums">{i + 1}</td>
                      <td class="px-5 py-3 font-medium text-heading">{row.name}</td>
                      <td class="px-5 py-3 text-dim">{registryLabel(row.registry)}</td>
                      <td class="px-5 py-3 text-right tabular-nums text-body">{fmt.format(['vscode','nuget','docker'].includes(row.registry) ? (row.total ?? row.week) : row.week)}</td>
                      <td class="px-5 py-3 text-right tabular-nums text-body">{fmt.format(row.month)}</td>
                      <td class="px-3 py-3">
                        {hasSparkline ? (
                          <div class="row-spark" title={`Peak: ${fmt.format(rowSparkMax)}/day`}>
                            {row.range30.map((n: number) => (
                              <span
                                class="rs"
                                style={`height:${Math.max(1, Math.round((n / rowSparkMax) * 100))}%`}
                              />
                            ))}
                          </div>
                        ) : (
                          <span class="text-dim text-xs">{'\u2014'}</span>
                        )}
                      </td>
                      <td class={`px-5 py-3 text-right tabular-nums ${t.cls}`}>{t.text}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>

          <div id="leaderboard-footer">
            {data && (data.errors?.length ?? 0) > 0 && (
              <div class="border-t border-edge bg-surface-raised px-5 py-3 text-xs text-dim">
                Some sources failed to fetch ({data.errors.length}). Data may be partial.
              </div>
            )}
          </div>
        </div>
      </section>

      </div>{/* close tab-leaderboard */}

      {/* ── Tab: Help ── */}
      <div id="tab-help" class="tab-panel hidden" role="tabpanel">
        <section class="mb-8 max-w-3xl">
          <h2 class="text-2xl font-bold text-heading flex items-center gap-2 mb-6">
            <span class="text-2xl">{"\uD83D\uDCD6"}</span> How to use this dashboard
          </h2>

          {/* Quick-start */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-3">Quick start</h3>
            <ol class="list-decimal list-inside space-y-2 text-sm text-body leading-relaxed">
              <li><strong class="text-heading">Set up your portfolio</strong> &mdash; go to the <a href={`${base}setup/`} class="text-accent underline underline-offset-2 hover:brightness-125">Setup</a> page, paste your package names (one per line), and save.</li>
              <li><strong class="text-heading">Wait for data</strong> &mdash; registry-stats fetches download counts from npm, PyPI, VS Code Marketplace, NuGet, and Docker Hub. The first snapshot takes about a minute.</li>
              <li><strong class="text-heading">Explore the tabs</strong> &mdash; <em>Home</em> has the AI chat assistant, <em>Analytics</em> shows charts and insights, and <em>Leaderboard</em> ranks every package.</li>
            </ol>
          </div>

          {/* Tabs explained */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-4">What each tab does</h3>
            <div class="space-y-4 text-sm text-body">
              <div>
                <h4 class="font-semibold text-heading flex items-center gap-2"><span>{"\uD83C\uDFE0"}</span> Home</h4>
                <p class="mt-1 leading-relaxed">The landing view with the executive snapshot (total downloads, weekly change, health score, diversity) and the <strong>Registry Assistant</strong> &mdash; an AI chat powered by a local Ollama model that can answer questions about your data.</p>
              </div>
              <div>
                <h4 class="font-semibold text-heading flex items-center gap-2"><span>{"\uD83D\uDCCA"}</span> Analytics</h4>
                <p class="mt-1 leading-relaxed">Six interactive charts: <strong>30-Day Trend</strong> (toggle between aggregate, per-registry, and top-5 views), <strong>Registry Share</strong> (polar area), <strong>Portfolio Risk</strong> (distribution histogram with Gini &amp; P90), <strong>Top 10 Momentum</strong> (bar chart colour-coded by velocity), <strong>Velocity Tracker</strong> (sparkline list sorted by growth rate), and <strong>30-Day Heatmap</strong> (per-package daily grid with spike detection).</p>
              </div>
              <div>
                <h4 class="font-semibold text-heading flex items-center gap-2"><span>{"\uD83C\uDFC6"}</span> Leaderboard</h4>
                <p class="mt-1 leading-relaxed">Every package ranked by weekly downloads with inline 30-day sparklines and a smart trend badge that avoids misleading percentages for low-volume packages.</p>
              </div>
            </div>
          </div>

          {/* Key concepts */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-4">Key concepts</h3>
            <dl class="space-y-3 text-sm text-body">
              <div>
                <dt class="font-semibold text-heading">Smart Growth Engine</dt>
                <dd class="mt-0.5 leading-relaxed">Percentages can be misleading when the previous count is tiny (e.g., 2 &rarr; 50 = +2,400%). When the prior period is below 20 downloads the badge shows <span class="text-amber-400 font-medium">{"\uD83D\uDE80"} Emerging</span> instead of a raw percentage. Growth above 500% is capped and the real delta is shown alongside.</dd>
              </div>
              <div>
                <dt class="font-semibold text-heading">Velocity Score</dt>
                <dd class="mt-0.5 leading-relaxed">A damped growth metric: <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">(curr &minus; prev) / &radic;(prev + k)</code>. It rewards genuine acceleration while keeping tiny-base packages from dominating. Used in Momentum, Velocity Tracker, and Leaderboard columns.</dd>
              </div>
              <div>
                <dt class="font-semibold text-heading">Spike detection (&gt;2&sigma;)</dt>
                <dd class="mt-0.5 leading-relaxed">On the heatmap, any day where a package&rsquo;s downloads are more than two standard deviations above its 30-day mean is flagged with an amber dot. The &ldquo;Spikes Only&rdquo; toggle dims everything else so anomalies stand out.</dd>
              </div>
              <div>
                <dt class="font-semibold text-heading">Health Score (0&ndash;100)</dt>
                <dd class="mt-0.5 leading-relaxed">A composite index combining registry coverage (how many sources responded), error count, week-over-week growth direction, and Shannon diversity (how evenly downloads spread across registries).</dd>
              </div>
              <div>
                <dt class="font-semibold text-heading">Confidence badges</dt>
                <dd class="mt-0.5 leading-relaxed">{"\u2705"} <strong>ok</strong> = fresh data, {"\u26A0\uFE0F"} <strong>partial</strong> = some endpoints failed, {"\u26D4"} <strong>error</strong> = provider unreachable. Shown on the home executive snapshot and the setup page.</dd>
              </div>
            </dl>
          </div>

          {/* AI assistant */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-3">Using the AI assistant</h3>
            <div class="text-sm text-body space-y-2 leading-relaxed">
              <p>The <strong>Registry Assistant</strong> on the Home tab talks to a local <a href="https://ollama.com" class="text-accent underline underline-offset-2 hover:brightness-125" target="_blank" rel="noopener">Ollama</a> instance on <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">localhost:11434</code>. It automatically injects a snapshot of your registry data into every prompt so the model can answer questions like:</p>
              <ul class="list-disc list-inside space-y-1 ml-2">
                <li>&ldquo;Which package grew the fastest this week?&rdquo;</li>
                <li>&ldquo;Summarise the npm vs PyPI split.&rdquo;</li>
                <li>&ldquo;Why did site-theme spike on day 27?&rdquo;</li>
              </ul>
              <p class="mt-2"><strong>Requirements:</strong> Ollama running locally with at least one model pulled (e.g., <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">ollama pull llama3.2</code>). If Ollama is offline the chat shows a friendly fallback message &mdash; everything else works normally.</p>
            </div>
          </div>

          {/* Companion tools */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-4">Companion tools</h3>
            <div class="space-y-3 text-sm text-body">
              <div class="flex items-start gap-3">
                <span class="text-lg shrink-0">{"\uD83D\uDCE6"}</span>
                <div>
                  <a href="https://www.npmjs.com/package/@mcptoolshop/registry-sync" class="font-semibold text-heading hover:text-accent" target="_blank" rel="noopener">registry-sync</a>
                  <p class="mt-0.5 leading-relaxed">Desired-state sync engine for multi-registry publishing. Detects drift, missing packages, and orphaned entries. Use <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">registry-sync audit</code> to check and <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">registry-sync plan</code> to preview changes.</p>
                </div>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-lg shrink-0">{"\uD83D\uDDA5\uFE0F"}</span>
                <div>
                  <span class="font-semibold text-heading">Desktop app (MAUI WebView2)</span>
                  <p class="mt-0.5 leading-relaxed">When served inside the .NET MAUI host the dashboard auto-refreshes from a local cache. The <code class="text-xs bg-surface-strong px-1 py-0.5 rounded">window.__registryStatsBridge</code> API lets the native layer push fresh snapshots.</p>
                </div>
              </div>
            </div>
          </div>

          {/* Data pipeline */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6 mb-6">
            <h3 class="text-lg font-semibold text-heading mb-3">How data flows</h3>
            <div class="text-sm text-body leading-relaxed">
              <p class="mb-3">The pipeline runs each time you build the site (or on a schedule in CI):</p>
              <div class="flex flex-wrap items-center gap-2 text-xs font-mono">
                <span class="rounded-md bg-surface-strong px-2 py-1 border border-edge">portfolio.txt</span>
                <span class="text-dim">&rarr;</span>
                <span class="rounded-md bg-surface-strong px-2 py-1 border border-edge">fetch providers</span>
                <span class="text-dim">&rarr;</span>
                <span class="rounded-md bg-surface-strong px-2 py-1 border border-edge">stats.json</span>
                <span class="text-dim">&rarr;</span>
                <span class="rounded-md bg-surface-strong px-2 py-1 border border-edge">Astro build</span>
                <span class="text-dim">&rarr;</span>
                <span class="rounded-md bg-surface-strong px-2 py-1 border border-edge">static HTML</span>
              </div>
              <p class="mt-3">The engine queries five registries in parallel: <strong>npm</strong> (weekly + 30-day range), <strong>PyPI</strong> (weekly), <strong>VS Code Marketplace</strong> (installs), <strong>NuGet</strong> (total), and <strong>Docker Hub</strong> (pulls). Each provider has retries with exponential back-off.</p>
            </div>
          </div>

          {/* Links */}
          <div class="rounded-2xl border border-edge bg-surface-raised p-6">
            <h3 class="text-lg font-semibold text-heading mb-3">Useful links</h3>
            <ul class="space-y-2 text-sm">
              <li><a href="https://github.com/mcp-tool-shop-org/registry-stats" class="text-accent underline underline-offset-2 hover:brightness-125" target="_blank" rel="noopener">registry-stats on GitHub</a> &mdash; source code, issues, CI config</li>
              <li><a href="https://github.com/mcp-tool-shop-org/registry-sync" class="text-accent underline underline-offset-2 hover:brightness-125" target="_blank" rel="noopener">registry-sync on GitHub</a> &mdash; multi-registry publishing sync</li>
              <li><a href="https://ollama.com" class="text-accent underline underline-offset-2 hover:brightness-125" target="_blank" rel="noopener">Ollama</a> &mdash; local LLM runtime for the chat assistant</li>
              <li><a href={`${base}setup/`} class="text-accent underline underline-offset-2 hover:brightness-125">Setup page</a> &mdash; portfolio editor, refresh, advanced settings</li>
              <li><a href={`${base}privacy/`} class="text-accent underline underline-offset-2 hover:brightness-125">Privacy policy</a></li>
            </ul>
          </div>
        </section>
      </div>{/* close tab-help */}

    </div>
  </div>

  {chartPayload && <div id="chart-data" class="hidden" data-json={chartPayload} />}
  {chatContext && <div id="chat-context" class="hidden" data-json={chatContext} />}
</AppShell>

<style>
  .sparkline {
    height: 88px;
    display: flex;
    align-items: flex-end;
    gap: 2px;
    padding: 10px;
    border-radius: 16px;
    background: var(--color-surface-strong);
    border: 1px solid var(--color-edge);
  }
  .spark {
    width: 100%;
    max-width: 10px;
    flex: 1 1 0;
    border-radius: 999px;
    background: var(--color-accent);
    opacity: 0.85;
    transition: transform 140ms ease, opacity 140ms ease;
  }
  .spark:hover {
    transform: translateY(-2px);
    opacity: 1;
  }
  .row-spark {
    display: inline-flex;
    align-items: flex-end;
    gap: 1px;
    height: 20px;
    width: 60px;
    vertical-align: middle;
  }
  .rs {
    flex: 1 1 0;
    min-width: 1px;
    border-radius: 1px;
    background: var(--color-accent);
    opacity: 0.7;
  }

  /* Tabs */
  .tab-btn {
    padding: 8px 16px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-muted);
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    cursor: pointer;
    transition: color 150ms, border-color 150ms;
  }
  .tab-btn:hover { color: var(--color-heading); }
  .tab-btn.tab-active {
    color: var(--color-heading);
    border-bottom-color: var(--color-accent);
  }
  .tab-panel.hidden { display: none; }

  /* Chart toggles */
  .trend-toggle {
    padding: 4px 12px;
    font-size: 11px;
    font-weight: 500;
    color: var(--color-muted);
    border: 1px solid var(--color-edge);
    border-radius: 6px;
    background: none;
    cursor: pointer;
    transition: all 150ms;
  }
  .trend-toggle:hover { color: var(--color-heading); border-color: var(--color-muted); }
  .trend-toggle.active {
    color: var(--color-action-text);
    background: var(--color-action);
    border-color: var(--color-action);
  }

  /* Pulse rows */
  .pulse-row {
    padding: 8px 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-edge) 40%, transparent);
  }
  .pulse-row:last-child { border-bottom: none; }
  .pulse-name {
    font-size: 13px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 60%;
  }
  .pulse-delta {
    font-size: 15px;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  /* Export dropdown */
  .export-wrap { position: relative; display: inline-block; }
  .export-menu {
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    z-index: 50;
    min-width: 260px;
    border-radius: 12px;
    border: 1px solid var(--color-edge);
    background: var(--color-surface-raised);
    box-shadow: 0 8px 24px rgba(0,0,0,.35);
    padding: 6px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .export-menu.hidden { display: none; }
  .export-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 10px 12px;
    border: none;
    border-radius: 8px;
    background: none;
    color: var(--color-muted);
    cursor: pointer;
    text-align: left;
    transition: background 120ms, color 120ms;
    width: 100%;
  }
  .export-item:hover {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    color: var(--color-heading);
  }
  .export-icon { font-size: 18px; line-height: 1; flex-shrink: 0; margin-top: 1px; }
  .export-label { display: flex; flex-direction: column; gap: 1px; }
  .export-label strong { font-size: 13px; font-weight: 600; color: var(--color-heading); }
  .export-desc { font-size: 11px; color: var(--color-dim); line-height: 1.3; }

  /* Chat */
  .chat-bubble-user {
    max-width: 80%;
    border-radius: 16px 16px 4px 16px;
    background: var(--color-action);
    color: var(--color-action-text);
    padding: 10px 16px;
    font-size: 14px;
    line-height: 1.5;
    word-break: break-word;
  }
  .chat-bubble-ai {
    max-width: 80%;
    border-radius: 16px 16px 16px 4px;
    background: var(--color-surface-strong);
    color: var(--color-heading);
    padding: 10px 16px;
    font-size: 14px;
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }
  .chat-typing {
    display: inline-flex;
    gap: 4px;
    align-items: center;
    padding: 10px 16px;
  }
  .chat-typing span {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--color-dim);
    animation: chatBounce 1.2s infinite;
  }
  .chat-typing span:nth-child(2) { animation-delay: 0.2s; }
  .chat-typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes chatBounce {
    0%, 80%, 100% { transform: translateY(0); }
    40% { transform: translateY(-6px); }
  }
  .chat-spinner {
    animation: chatSpin 0.8s linear infinite;
  }
  @keyframes chatSpin {
    to { transform: rotate(360deg); }
  }
  .chat-progress-bar {
    width: 0%;
    animation: chatProgressPulse 2.5s ease-in-out infinite;
  }
  @keyframes chatProgressPulse {
    0% { width: 5%; opacity: 0.7; }
    50% { width: 85%; opacity: 1; }
    100% { width: 5%; opacity: 0.7; }
  }

  .voice-speak-btn {
    flex-shrink: 0;
    padding: 4px;
    border-radius: 6px;
    opacity: 0.5;
    transition: opacity 0.15s;
  }
  .voice-speak-btn:hover { opacity: 1; }

  /* Fullscreen chat */
  .chat-fullscreen {
    position: fixed !important;
    inset: 0;
    z-index: 50;
    margin: 0 !important;
    border-radius: 0 !important;
    border: none !important;
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
  }
  .chat-fullscreen .rounded-2xl {
    border-radius: 0 !important;
    border: none !important;
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
  }
  .chat-fullscreen #chat-messages {
    flex: 1;
    max-height: none !important;
    min-height: 0 !important;
  }
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

<script is:inline>
  // Shared helper — cumulative registries show total instead of weekly
  var __CUMULATIVE = ['vscode', 'nuget', 'docker'];
  function regDisplayVal(key, r) {
    return __CUMULATIVE.indexOf(key) !== -1 ? Number((r || {}).total || (r || {}).week || 0) : Number((r || {}).week || 0);
  }
</script>

<script is:inline>
  // Tab switching (hash-based) + Chart.js initialization
  (function () {
    var tabs = document.querySelectorAll('[data-tab]');
    var panels = document.querySelectorAll('.tab-panel');
    var chartsInitialized = false;

    function switchTab(name) {
      tabs.forEach(function (btn) {
        var active = btn.getAttribute('data-tab') === name;
        btn.classList.toggle('tab-active', active);
        btn.setAttribute('aria-selected', String(active));
      });
      panels.forEach(function (p) {
        p.classList.toggle('hidden', p.id !== 'tab-' + name);
      });
      if (name === 'analytics' && !chartsInitialized) initCharts();
      history.replaceState(null, '', '#' + name);
    }

    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        switchTab(btn.getAttribute('data-tab'));
      });
    });

    // Restore from hash
    var hash = location.hash.replace('#', '');
    if (hash && document.getElementById('tab-' + hash)) {
      switchTab(hash);
    }

    var CHART_PALETTE = ['#059669', '#3b82f6', '#f59e0b', '#8b5cf6', '#ef4444', '#06b6d4'];
    var REG_NAMES = { npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' };

    function getThemeColors() {
      var s = getComputedStyle(document.documentElement);
      return {
        accent: s.getPropertyValue('--color-accent').trim() || '#059669',
        heading: s.getPropertyValue('--color-heading').trim() || '#e4e4e7',
        dim: s.getPropertyValue('--color-dim').trim() || '#71717a',
        edge: s.getPropertyValue('--color-edge').trim() || '#27272a',
      };
    }

    var fmtK = function (n) { return n >= 1000 ? (n / 1000).toFixed(1) + 'K' : String(n); };

    // Smart growth display — must live in this IIFE so initCharts() can use it
    var BASELINE_THRESHOLD_C = 20;
    var PCT_CAP_C = 500;
    var fmtCompactC = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });
    function formatGrowth(pct, prev, curr) {
      if (pct === null || pct === undefined) {
        if ((prev === 0 || prev === null || prev === undefined) && (curr || 0) > 0) {
          return { text: '\uD83D\uDE80 New (+' + fmtCompactC.format(curr || 0) + ')', cls: 'text-amber-400', isEmerging: true };
        }
        return { text: '\u2014', cls: 'text-dim', isEmerging: false };
      }
      var absDelta = (curr || 0) - (prev || 0);
      if ((prev || 0) < BASELINE_THRESHOLD_C) {
        return { text: '\uD83D\uDE80 Emerging (+' + fmtCompactC.format(Math.max(0, absDelta)) + ')', cls: 'text-amber-400', isEmerging: true };
      }
      var r = Math.round(pct * 10) / 10;
      var arrow = r > 0 ? '\u25B2' : r < 0 ? '\u25BC' : '';
      var absR = Math.abs(r);
      if (absR > PCT_CAP_C) {
        return { text: arrow + ' ' + PCT_CAP_C + '%+ (+' + fmtCompactC.format(Math.abs(absDelta)) + ')', cls: r > 0 ? 'text-emerald-400' : 'text-rose-400', isEmerging: false };
      }
      if (r > 0) return { text: arrow + ' ' + absR + '%', cls: 'text-emerald-400', isEmerging: false };
      if (r < 0) return { text: arrow + ' ' + absR + '%', cls: 'text-rose-400', isEmerging: false };
      return { text: '0%', cls: 'text-dim', isEmerging: false };
    }

    function initCharts() {
      if (typeof Chart === 'undefined') return;
      // Destroy existing Chart.js instances for clean re-init
      ['chart-trend', 'chart-share', 'chart-distribution', 'chart-top10'].forEach(function (id) {
        var c = document.getElementById(id);
        if (c && typeof Chart.getChart === 'function') { var ch = Chart.getChart(c); if (ch) ch.destroy(); }
      });

      // Strip old event listeners to prevent accumulation on re-init.
      // Clone-replace removes all listeners; fresh ones are added below.
      ['[data-mode]', '[data-heatmode]'].forEach(function (sel) {
        document.querySelectorAll(sel).forEach(function (btn) {
          var clone = btn.cloneNode(true);
          btn.parentNode.replaceChild(clone, btn);
        });
      });
      // Remove old heatmap tooltip handlers
      var hcPre = document.getElementById('chart-heatmap');
      if (hcPre && hcPre._heatHandlers) {
        hcPre.removeEventListener('mousemove', hcPre._heatHandlers.move);
        hcPre.removeEventListener('mouseleave', hcPre._heatHandlers.leave);
        hcPre._heatHandlers = null;
      }
      var dataEl = document.getElementById('chart-data');
      if (!dataEl) return;
      var cdata;
      try { cdata = JSON.parse(dataEl.getAttribute('data-json')); } catch { return; }
      if (!cdata) return;
      chartsInitialized = true;

      var tc = getThemeColors();
      Chart.defaults.color = tc.dim;
      Chart.defaults.borderColor = tc.edge;
      Chart.defaults.font.family = 'system-ui, -apple-system, sans-serif';

      var sp = cdata.sparkline30 || [];
      var lb = cdata.leaderboard || [];
      var labels30 = sp.map(function (_, i) { return 'D-' + (sp.length - i); });

      // Compute 7d moving average
      var ma7 = [];
      for (var i = 0; i < sp.length; i++) {
        if (i < 6) { ma7.push(null); continue; }
        var sum = 0;
        for (var j = i - 6; j <= i; j++) sum += Number(sp[j]);
        ma7.push(Math.round(sum / 7));
      }

      // Z-score for anomaly point markers
      var spMean = 0; for (var i = 0; i < sp.length; i++) spMean += Number(sp[i]);
      spMean = sp.length > 0 ? spMean / sp.length : 0;
      var spVar = 0; for (var i = 0; i < sp.length; i++) spVar += Math.pow(Number(sp[i]) - spMean, 2);
      var spStd = sp.length > 1 ? Math.sqrt(spVar / sp.length) : 1;
      var anomalyPoints = sp.map(function (v) {
        var z = spStd > 0 ? (Number(v) - spMean) / spStd : 0;
        return Math.abs(z) >= 2 ? Number(v) : null;
      });

      // ═══════════════════════════════════════════════
      // 1. 30-Day Trend — multi-mode with toggles
      // ═══════════════════════════════════════════════
      var trendChart = null;
      var trendMode = 'aggregate';

      // Trend summary bar
      var trendSummary = document.getElementById('trend-summary');
      if (trendSummary) {
        var last7 = sp.slice(-7).reduce(function (a, b) { return a + Number(b); }, 0);
        var prev7 = sp.slice(-14, -7).reduce(function (a, b) { return a + Number(b); }, 0);
        var chg = prev7 > 0 ? Math.round((last7 - prev7) / prev7 * 1000) / 10 : 0;
        var anomCount = (cdata.anomalies || []).length;
        trendSummary.innerHTML = '';
        var items = [
          ['Last 7d: ' + fmtK(last7), ''],
          [(chg >= 0 ? '\u25B2 ' : '\u25BC ') + Math.abs(chg) + '% vs prev', chg >= 0 ? 'color:#059669' : 'color:#ef4444'],
          [anomCount + ' anomal' + (anomCount === 1 ? 'y' : 'ies'), anomCount > 0 ? 'color:#f59e0b' : '']
        ];
        items.forEach(function (item) {
          var s = document.createElement('span');
          s.textContent = item[0];
          if (item[1]) s.style.cssText = item[1];
          s.className = 'inline-flex items-center gap-1 rounded-md bg-surface-strong px-2 py-0.5';
          trendSummary.appendChild(s);
        });
      }

      function buildTrendDatasets(mode) {
        if (mode === 'registry') {
          var prd = cdata.perRegistryDaily || {};
          var ds = [];
          var regIdx = 0;
          Object.keys(prd).forEach(function (reg) {
            ds.push({
              label: REG_NAMES[reg] || reg,
              data: prd[reg],
              borderColor: CHART_PALETTE[regIdx % CHART_PALETTE.length],
              backgroundColor: CHART_PALETTE[regIdx % CHART_PALETTE.length] + '15',
              fill: false, tension: 0.3, pointRadius: 0, borderWidth: 2
            });
            regIdx++;
          });
          return ds;
        }
        if (mode === 'top5') {
          var top5 = cdata.top5Daily || [];
          var ds = [];
          top5.forEach(function (pkg, idx) {
            ds.push({
              label: pkg.name,
              data: pkg.range30,
              borderColor: CHART_PALETTE[idx % CHART_PALETTE.length],
              fill: false, tension: 0.3, pointRadius: 0, borderWidth: 2
            });
          });
          return ds;
        }
        // aggregate
        return [
          { label: 'Daily', data: sp, borderColor: tc.accent, backgroundColor: tc.accent + '20', fill: true, tension: 0.3, pointRadius: 0, borderWidth: 2 },
          { label: '7d avg', data: ma7, borderColor: CHART_PALETTE[1], borderDash: [5, 3], tension: 0.3, pointRadius: 0, borderWidth: 2, fill: false },
          { label: 'Anomaly', data: anomalyPoints, pointStyle: 'triangle', pointRadius: 8, pointBackgroundColor: '#f59e0b', borderColor: 'transparent', showLine: false, fill: false }
        ];
      }

      trendChart = new Chart(document.getElementById('chart-trend'), {
        type: 'line',
        data: { labels: labels30, datasets: buildTrendDatasets('aggregate') },
        options: {
          responsive: true, maintainAspectRatio: false,
          interaction: { intersect: false, mode: 'index' },
          scales: { x: { display: false }, y: { beginAtZero: true, ticks: { maxTicksLimit: 5, callback: function (v) { return fmtK(v); } } } },
          plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12 } } }
        }
      });

      // Toggle wiring
      var toggleBtns = document.querySelectorAll('[data-mode]');
      toggleBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          toggleBtns.forEach(function (b) { b.classList.remove('active'); });
          btn.classList.add('active');
          trendMode = btn.getAttribute('data-mode');
          trendChart.data.datasets = buildTrendDatasets(trendMode);
          trendChart.update();
        });
      });

      // ═══════════════════════════════════════════════
      // 2. Registry Share — polar area + stat rows
      // ═══════════════════════════════════════════════
      var regKeys = Object.keys(cdata.registryTotals || {});
      var regVals = regKeys.map(function (k) { return regDisplayVal(k, cdata.registryTotals[k] || {}); });
      var regTotal = regVals.reduce(function (a, b) { return a + b; }, 0);

      // Stat rows
      var shareStats = document.getElementById('registry-share-stats');
      if (shareStats) {
        shareStats.innerHTML = '';
        regKeys.forEach(function (k, idx) {
          var v = regVals[idx];
          var pct = regTotal > 0 ? Math.round(v / regTotal * 1000) / 10 : 0;
          var row = document.createElement('div');
          row.className = 'flex items-center justify-between text-sm';
          var left = document.createElement('div');
          left.className = 'flex items-center gap-2';
          var dot = document.createElement('span');
          dot.className = 'inline-block w-2.5 h-2.5 rounded-full';
          dot.style.background = CHART_PALETTE[idx % CHART_PALETTE.length];
          var name = document.createTextNode(REG_NAMES[k] || k);
          left.appendChild(dot); left.appendChild(name);
          var right = document.createElement('div');
          right.className = 'tabular-nums text-heading';
          right.textContent = fmtK(v) + ' (' + pct + '%)';
          row.appendChild(left); row.appendChild(right);
          shareStats.appendChild(row);
        });
      }

      new Chart(document.getElementById('chart-share'), {
        type: 'polarArea',
        data: {
          labels: regKeys.map(function (k) { return REG_NAMES[k] || k; }),
          datasets: [{ data: regVals, backgroundColor: CHART_PALETTE.slice(0, regKeys.length).map(function (c) { return c + 'cc'; }), borderWidth: 0 }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: { r: { ticks: { display: false }, grid: { color: tc.edge } } }
        }
      });

      // ═══════════════════════════════════════════════
      // 3. Portfolio Risk Analysis (distribution + stats)
      // ═══════════════════════════════════════════════
      var distMetrics = document.getElementById('dist-metrics');
      if (distMetrics) {
        distMetrics.innerHTML = '';
        var pills = [
          { label: 'Median', value: fmtK(cdata.median || 0), color: '#3b82f6' },
          { label: 'P90', value: fmtK(cdata.p90 || 0), color: '#8b5cf6' },
          { label: 'Gini', value: (cdata.gini || 0).toFixed(2), color: cdata.gini > 0.7 ? '#ef4444' : '#f59e0b' },
          { label: 'Top-3 share', value: (cdata.top3Pct || 0) + '%', color: cdata.top3Pct > 60 ? '#ef4444' : '#059669' },
        ];
        pills.forEach(function (p) {
          var el = document.createElement('span');
          el.className = 'inline-flex items-center gap-1.5 rounded-md px-2 py-1';
          el.style.cssText = 'background:' + p.color + '12;border:1px solid ' + p.color + '40';
          var dot = document.createElement('span');
          dot.className = 'w-1.5 h-1.5 rounded-full';
          dot.style.background = p.color;
          el.appendChild(dot);
          el.appendChild(document.createTextNode(p.label + ': ' + p.value));
          distMetrics.appendChild(el);
        });
      }

      var bucketLabels = ['0\u201399', '100\u2013999', '1K\u20139.9K', '10K\u201399K', '100K+'];
      var dist = [0, 0, 0, 0, 0];
      lb.forEach(function (r) {
        var w = Number(r.week || 0);
        if (w >= 100000) dist[4]++;
        else if (w >= 10000) dist[3]++;
        else if (w >= 1000) dist[2]++;
        else if (w >= 100) dist[1]++;
        else dist[0]++;
      });

      var distChart = new Chart(document.getElementById('chart-distribution'), {
        type: 'bar',
        data: {
          labels: bucketLabels,
          datasets: [{ label: 'Packages', data: dist, backgroundColor: CHART_PALETTE.map(function (c) { return c + 'cc'; }), borderRadius: 4 }]
        },
        options: {
          responsive: true, maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            annotation: typeof Chart.registry && Chart.registry.plugins.get('annotation') ? {
              annotations: {
                median: { type: 'line', xMin: 1, xMax: 1, borderColor: '#3b82f6', borderDash: [4, 4], borderWidth: 2, label: { display: true, content: 'Median', position: 'start' } },
              }
            } : undefined
          },
          scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
        }
      });

      // ═══════════════════════════════════════════════
      // 4. Top 10 — Momentum Chart
      // ═══════════════════════════════════════════════
      var top10 = lb.slice(0, 10);
      var momentumLabels = top10.map(function (r) {
        if (r.isEmerging) return r.name + ' \uD83D\uDE80';
        var arrow = '';
        if (r.velocity !== null && r.velocity !== undefined) {
          arrow = r.velocity > 10 ? ' \uD83D\uDD3C' : r.velocity < -10 ? ' \uD83D\uDD3D' : '';
        }
        return r.name + arrow;
      });

      new Chart(document.getElementById('chart-top10'), {
        type: 'bar',
        data: {
          labels: momentumLabels,
          datasets: [{
            label: 'Weekly',
            data: top10.map(function (r) { return r.week; }),
            backgroundColor: top10.map(function (r) {
              if (r.isEmerging) return '#f59e0bcc'; // amber for emerging
              var v = r.velocity || 0;
              if (v > 5) return '#059669cc';
              if (v > 0) return '#059669' + '80';
              if (v > -5) return '#f59e0bcc';
              return '#ef4444cc';
            }),
            borderRadius: 4
          }]
        },
        options: {
          responsive: true, maintainAspectRatio: false, indexAxis: 'y',
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                afterLabel: function (ctx) {
                  var pkg = top10[ctx.dataIndex];
                  var prev = pkg.prevWeek;
                  var curr = (prev !== null && prev !== undefined) ? prev + (pkg.absDelta || 0) : null;
                  var sg = formatGrowth(pkg.trendPct, prev, curr);
                  var parts = ['Growth: ' + sg.text];
                  if (pkg.velocity !== null && pkg.velocity !== undefined) {
                    parts.push('Velocity score: ' + pkg.velocity);
                  } else if (pkg.isEmerging) {
                    parts.push('Velocity: Emerging');
                  }
                  return parts.join('\n');
                }
              }
            }
          },
          scales: { x: { beginAtZero: true, ticks: { callback: function (v) { return fmtK(v); } } } }
        }
      });

      // Momentum legend
      var momLegend = document.getElementById('momentum-legend');
      if (momLegend) {
        momLegend.innerHTML = '';
        top10.forEach(function (r, i) {
          var card = document.createElement('div');
          card.className = 'flex items-center justify-between rounded-lg border border-edge px-3 py-1.5 text-xs';
          var left = document.createElement('span');
          left.className = 'font-medium text-heading truncate';
          left.textContent = r.name;
          var right = document.createElement('span');
          // Use damped velocity score (not raw %) or smart growth badge
          if (r.isEmerging) {
            right.className = 'tabular-nums whitespace-nowrap ml-2 text-amber-400';
            right.textContent = '\uD83D\uDE80 Emerging (+' + fmtK(Math.max(0, r.absDelta || r.week || 0)) + ')';
          } else if (r.velocity !== null && r.velocity !== undefined) {
            right.className = 'tabular-nums whitespace-nowrap ml-2 ' + (r.velocity >= 0 ? 'text-emerald-400' : 'text-rose-400');
            right.textContent = 'vel: ' + (r.velocity >= 0 ? '+' : '') + r.velocity;
          } else {
            var prev = r.prevWeek;
            var curr = (prev !== null && prev !== undefined) ? prev + (r.absDelta || 0) : null;
            var sg = formatGrowth(r.trendPct, prev, curr);
            right.className = 'tabular-nums whitespace-nowrap ml-2 ' + sg.cls;
            right.textContent = sg.text;
          }
          card.appendChild(left); card.appendChild(right);
          momLegend.appendChild(card);
        });
      }

      // ═══════════════════════════════════════════════
      // 5. Velocity Tracker
      // ═══════════════════════════════════════════════
      var velList = document.getElementById('velocity-list');
      if (velList) {
        velList.innerHTML = '';
        var sorted = lb.slice().sort(function (a, b) { return Math.abs(b.velocity || b.trendPct || 0) - Math.abs(a.velocity || a.trendPct || 0); }).slice(0, 20);
        sorted.forEach(function (r) {
          var row = document.createElement('div');
          row.className = 'flex items-center gap-3 rounded-lg border border-edge bg-surface px-3 py-2';

          // Mini sparkline
          var miniSpark = document.createElement('div');
          miniSpark.className = 'flex items-end gap-px shrink-0';
          miniSpark.style.cssText = 'width:50px;height:16px';
          if (r.range30 && r.range30.length === 30) {
            var rMax = Math.max.apply(null, r.range30.concat([1]));
            r.range30.slice(-14).forEach(function (v) {
              var bar = document.createElement('span');
              bar.style.cssText = 'flex:1;min-width:1px;border-radius:1px;background:var(--color-accent);height:' + Math.max(2, Math.round(Number(v) / rMax * 100)) + '%';
              miniSpark.appendChild(bar);
            });
          } else {
            miniSpark.appendChild(document.createTextNode('\u2014'));
          }
          row.appendChild(miniSpark);

          var info = document.createElement('div');
          info.className = 'flex-1 min-w-0';
          var nameEl = document.createElement('div');
          nameEl.className = 'text-sm font-medium text-heading truncate';
          nameEl.textContent = r.name;
          var meta = document.createElement('div');
          meta.className = 'text-[10px] text-dim';
          meta.textContent = (REG_NAMES[r.registry] || r.registry) + ' \u2022 ' + fmtK(r.week) + '/wk';
          info.appendChild(nameEl); info.appendChild(meta);
          row.appendChild(info);

          var badge = document.createElement('div');
          // Smart growth display for velocity tracker
          if (r.isEmerging) {
            badge.className = 'text-xs font-medium tabular-nums whitespace-nowrap text-amber-400';
            badge.textContent = '\uD83D\uDE80 Emerging';
          } else if (r.velocity !== null && r.velocity !== undefined) {
            badge.className = 'text-xs font-medium tabular-nums whitespace-nowrap ' + (r.velocity >= 0 ? 'text-emerald-400' : 'text-rose-400');
            badge.textContent = 'vel: ' + (r.velocity >= 0 ? '+' : '') + r.velocity;
          } else {
            var prev = r.prevWeek;
            var curr = (prev !== null && prev !== undefined) ? prev + (r.absDelta || 0) : null;
            var sg = formatGrowth(r.trendPct, prev, curr);
            badge.className = 'text-xs font-medium tabular-nums whitespace-nowrap ' + sg.cls;
            badge.textContent = sg.text;
          }
          row.appendChild(badge);
          velList.appendChild(row);
        });
      }

      // ═══════════════════════════════════════════════
      // 6. Heatmap — sorted, tooltip, spike toggle
      // ═══════════════════════════════════════════════
      var heatCanvas = document.getElementById('chart-heatmap');
      var heatTooltip = document.getElementById('heatmap-tooltip');

      if (heatCanvas) {
        var withRange = lb.filter(function (r) { return r.range30 && r.range30.length === 30; });
        // Sort by total downloads (descending)
        withRange.sort(function (a, b) {
          var aSum = a.range30.reduce(function (s, v) { return s + Number(v); }, 0);
          var bSum = b.range30.reduce(function (s, v) { return s + Number(v); }, 0);
          return bSum - aSum;
        });
        withRange = withRange.slice(0, 20);

        // Compute per-package stats for spike detection
        withRange.forEach(function (pkg) {
          var sum = 0;
          pkg.range30.forEach(function (v) { sum += Number(v); });
          pkg._mean = sum / 30;
          var variance = 0;
          pkg.range30.forEach(function (v) { variance += Math.pow(Number(v) - pkg._mean, 2); });
          pkg._std = Math.sqrt(variance / 30);
        });

        var spikeMode = false;

        function drawHeatmap() {
          if (withRange.length === 0) {
            heatCanvas.parentElement.insertBefore(document.createTextNode('No 30-day range data available.'), heatCanvas);
            heatCanvas.style.display = 'none';
            return;
          }
          var ctx = heatCanvas.getContext('2d');
          var cellW = 20, cellH = 24, padLeft = 140, padTop = 24;
          heatCanvas.width = padLeft + 30 * cellW + 10;
          heatCanvas.height = padTop + withRange.length * cellH + 10;
          heatCanvas.style.width = heatCanvas.width + 'px';
          heatCanvas.style.height = heatCanvas.height + 'px';

          ctx.clearRect(0, 0, heatCanvas.width, heatCanvas.height);

          var globalMax = 1;
          withRange.forEach(function (r) { r.range30.forEach(function (v) { if (Number(v) > globalMax) globalMax = Number(v); }); });

          // Column headers
          ctx.fillStyle = tc.dim;
          ctx.font = '10px system-ui';
          ctx.textAlign = 'center';
          for (var d = 0; d < 30; d++) {
            if (d % 5 === 0) ctx.fillText('D-' + (30 - d), padLeft + d * cellW + cellW / 2, padTop - 6);
          }

          withRange.forEach(function (pkg, row) {
            // Row label + total
            ctx.fillStyle = tc.heading;
            ctx.font = '11px system-ui';
            ctx.textAlign = 'right';
            var totalSum = pkg.range30.reduce(function (s, v) { return s + Number(v); }, 0);
            ctx.fillText(pkg.name.substring(0, 14) + ' (' + fmtK(totalSum) + ')', padLeft - 6, padTop + row * cellH + cellH / 2 + 4);

            pkg.range30.forEach(function (val, col) {
              var v = Number(val);
              var isSpike = pkg._std > 0 && (v - pkg._mean) / pkg._std >= 2;

              if (spikeMode && !isSpike) {
                // Dim non-spike cells
                ctx.fillStyle = 'rgba(100, 100, 100, 0.08)';
              } else {
                var intensity = Math.min(1, v / globalMax);
                var g = Math.round(150 + intensity * 70);
                var b = Math.round(100 - intensity * 20);
                ctx.fillStyle = 'rgba(5, ' + g + ', ' + b + ', ' + (0.12 + intensity * 0.88).toFixed(2) + ')';
              }
              ctx.fillRect(padLeft + col * cellW + 1, padTop + row * cellH + 1, cellW - 2, cellH - 2);

              // Mark spikes with a dot
              if (isSpike && !spikeMode) {
                ctx.fillStyle = '#f59e0b';
                ctx.beginPath();
                ctx.arc(padLeft + col * cellW + cellW / 2, padTop + row * cellH + 3, 2, 0, Math.PI * 2);
                ctx.fill();
              }
            });
          });

          // Store layout for tooltip
          heatCanvas._layout = { cellW: cellW, cellH: cellH, padLeft: padLeft, padTop: padTop, data: withRange };
        }

        drawHeatmap();

        // Tooltip on hover — use named functions stored on the canvas
        // so they can be removed on re-init (prevents listener accumulation)
        if (heatTooltip) {
          var heatMoveHandler = function (e) {
            var lay = heatCanvas._layout;
            if (!lay) return;
            var rect = heatCanvas.getBoundingClientRect();
            var x = e.clientX - rect.left;
            var y = e.clientY - rect.top;
            var col = Math.floor((x - lay.padLeft) / lay.cellW);
            var row = Math.floor((y - lay.padTop) / lay.cellH);
            if (col < 0 || col >= 30 || row < 0 || row >= lay.data.length) {
              heatTooltip.classList.add('hidden');
              return;
            }
            var pkg = lay.data[row];
            var v = Number(pkg.range30[col]);
            var isSpike = pkg._std > 0 && (v - pkg._mean) / pkg._std >= 2;
            heatTooltip.innerHTML = '';
            var t1 = document.createElement('div');
            t1.className = 'font-medium text-heading';
            t1.textContent = pkg.name;
            var t2 = document.createElement('div');
            t2.textContent = 'D-' + (30 - col) + ': ' + v.toLocaleString() + ' downloads';
            heatTooltip.appendChild(t1);
            heatTooltip.appendChild(t2);
            if (isSpike) {
              var t3 = document.createElement('div');
              t3.className = 'text-amber-400 font-medium';
              t3.textContent = '\u26A1 Spike detected (>2\u03C3)';
              heatTooltip.appendChild(t3);
            }
            heatTooltip.classList.remove('hidden');
            heatTooltip.style.left = Math.min(x + 12, heatCanvas.width - 180) + 'px';
            heatTooltip.style.top = (y + 12) + 'px';
          };
          var heatLeaveHandler = function () {
            heatTooltip.classList.add('hidden');
          };
          heatCanvas._heatHandlers = { move: heatMoveHandler, leave: heatLeaveHandler };
          heatCanvas.addEventListener('mousemove', heatMoveHandler);
          heatCanvas.addEventListener('mouseleave', heatLeaveHandler);
        }

        // Spike toggle
        var heatBtns = document.querySelectorAll('[data-heatmode]');
        heatBtns.forEach(function (btn) {
          btn.addEventListener('click', function () {
            heatBtns.forEach(function (b) { b.classList.remove('active'); });
            btn.classList.add('active');
            spikeMode = btn.getAttribute('data-heatmode') === 'spikes';
            drawHeatmap();
          });
        });
      }
    }

    // Expose for runtime refresh
    window.__rpInitCharts = function () { chartsInitialized = false; initCharts(); };
  })();
</script>

<script is:inline>
  // Runtime data loading: fetches /data/stats.json and re-renders the dashboard.
  // On web (GitHub Pages) this is a harmless re-render with the same build-time data.
  // On desktop (MAUI WebView2) this loads fresh cached data, enabling startup refresh.
  (function () {
    var fmt = new Intl.NumberFormat('en-US');
    var fmtCompact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });

    var REG_LABELS = { npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' };
    function regLabel(k) { return REG_LABELS[k] || k; }

    var BASELINE_THRESHOLD = 20;
    var PCT_CAP = 500;

    // Smart growth display — handles small-denominator distortion
    function formatGrowth(pct, prev, curr) {
      if (pct === null || pct === undefined) {
        if ((prev === 0 || prev === null || prev === undefined) && (curr || 0) > 0) {
          return { text: '\uD83D\uDE80 New (+' + fmtCompact.format(curr || 0) + ')', cls: 'text-amber-400', isEmerging: true };
        }
        return { text: '\u2014', cls: 'text-dim', isEmerging: false };
      }
      var absDelta = (curr || 0) - (prev || 0);
      if ((prev || 0) < BASELINE_THRESHOLD) {
        return { text: '\uD83D\uDE80 Emerging (+' + fmtCompact.format(Math.max(0, absDelta)) + ')', cls: 'text-amber-400', isEmerging: true };
      }
      var r = Math.round(pct * 10) / 10;
      var arrow = r > 0 ? '\u25B2' : r < 0 ? '\u25BC' : '';
      var absR = Math.abs(r);
      if (absR > PCT_CAP) {
        return { text: arrow + ' ' + PCT_CAP + '%+ (+' + fmtCompact.format(Math.abs(absDelta)) + ')', cls: r > 0 ? 'text-emerald-400' : 'text-rose-400', isEmerging: false };
      }
      if (r > 0) return { text: arrow + ' ' + absR + '%', cls: 'text-emerald-400', isEmerging: false };
      if (r < 0) return { text: arrow + ' ' + absR + '%', cls: 'text-rose-400', isEmerging: false };
      return { text: '0%', cls: 'text-dim', isEmerging: false };
    }

    function trendBadge(pct, prev, curr) {
      return formatGrowth(pct, prev, curr);
    }

    function relTime(iso) {
      var d = Date.now() - new Date(iso).getTime();
      var m = Math.floor(d / 60000);
      if (m < 60) return m + 'm ago';
      var h = Math.floor(m / 60);
      if (h < 24) return h + 'h ago';
      return Math.floor(h / 24) + 'd ago';
    }

    function confBadge(c) {
      if (c === 'ok') return '\u2705';
      if (c === 'partial') return '\u26A0\uFE0F';
      return '\u26D4';
    }

    // Safe DOM builder: creates element with optional class and children (strings become text nodes)
    function el(tag, cls, children) {
      var e = document.createElement(tag);
      if (cls) e.className = cls;
      if (children != null) {
        var list = Array.isArray(children) ? children : [children];
        for (var i = 0; i < list.length; i++) {
          var c = list[i];
          e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
        }
      }
      return e;
    }

    // regDisplayVal is defined globally (above all IIFEs)

    // Lightweight schema check — rejects clearly malformed payloads
    function validateStats(data) {
      if (!data || typeof data !== 'object') return false;
      if (!data.totals || typeof data.totals !== 'object') return false;
      if (typeof data.totals.packages !== 'number') return false;
      if (typeof data.totals.week !== 'number') return false;
      if (typeof data.fetchedAt !== 'string') return false;
      if (data.leaderboard && !Array.isArray(data.leaderboard)) return false;
      if (data.sparkline30 && !Array.isArray(data.sparkline30)) return false;
      return true;
    }

    function renderDashboard(data) {
      if (!data || !data.totals) return;
      window.__rpCurrentData = data;
      var t = data.totals;
      var movers = data.movers || {};
      var concPct = Math.round(movers.concentrationTop5Pct || 0);

      var upd = document.getElementById('updated-at');
      if (upd) {
        upd.title = new Date(data.fetchedAt).toUTCString();
        upd.setAttribute('data-fetched', data.fetchedAt);
        upd.textContent = 'Updated ' + relTime(data.fetchedAt) + '.';
      }

      var e;
      e = document.getElementById('stat-packages'); if (e) e.textContent = fmt.format(t.packages);
      e = document.getElementById('stat-weekly'); if (e) e.textContent = fmtCompact.format(t.week);
      e = document.getElementById('stat-monthly'); if (e) e.textContent = fmtCompact.format(t.month);
      e = document.getElementById('stat-concentration'); if (e) e.textContent = concPct + '%';
      e = document.getElementById('pulse-conc'); if (e) e.textContent = concPct + '%';

      // Executive snapshot
      var snap = document.getElementById('exec-snapshot');
      if (snap) snap.classList.remove('hidden');
      var meta = document.getElementById('exec-meta');
      if (meta) {
        meta.textContent = '';
        meta.appendChild(document.createTextNode('Source: build-time fetch'));
        meta.appendChild(document.createElement('br'));
        meta.appendChild(document.createTextNode(new Date(data.fetchedAt).toUTCString()));
      }
      var lines = document.getElementById('exec-lines');
      if (lines && data.narrativeLines) {
        lines.textContent = '';
        data.narrativeLines.forEach(function (ln) {
          lines.appendChild(el('div', 'flex items-start gap-3', [
            el('span', 'text-lg leading-6 shrink-0', String(ln.icon)),
            el('div', '', [
              el('span', 'text-xs font-semibold uppercase tracking-wide text-accent', String(ln.label)),
              el('span', 'text-sm text-heading ml-2', String(ln.text))
            ])
          ]));
        });
      } else if (lines && data.narrative) {
        lines.textContent = '';
        lines.appendChild(el('div', 'text-base font-medium text-heading', String(data.narrative)));
      }

      var content = document.getElementById('dashboard-content');
      if (content) content.classList.remove('hidden');

      // ── Build categorized mover lists (established vs emerging) ──
      var ESTAB_FLOOR = 50;
      function mPrev(r) { return r.delta7 !== undefined ? (r.week || 0) - r.delta7 : 0; }
      function mCurr(r) { return r.week || 0; }
      function clipName(n) { return n.length > 22 ? n.slice(0, 20) + '\u2026' : n; }
      function sparkSvg(range30) {
        if (!range30 || range30.length < 7) return null;
        var v = range30.slice(-7);
        var mx = Math.max.apply(null, v.map(Number)) || 1;
        var pts = v.map(function (d, i) { return (i / 6 * 48) + ',' + (16 - Number(d) / mx * 14); }).join(' ');
        var s = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        s.setAttribute('viewBox', '0 0 48 18');
        s.setAttribute('class', 'inline-block w-12 h-4 ml-1 align-middle');
        s.setAttribute('fill', 'none');
        s.setAttribute('stroke', 'currentColor');
        s.setAttribute('stroke-width', '1.5');
        s.setAttribute('stroke-linecap', 'round');
        s.setAttribute('stroke-linejoin', 'round');
        var pl = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
        pl.setAttribute('points', pts);
        s.appendChild(pl);
        return s;
      }

      function renderPulseRow(parent, r, colorCls, isNew, lbData) {
        var name = String(r.name || '').replace('@mcptoolshop/', '');
        var curr = mCurr(r), prev = mPrev(r);
        var delta = curr - prev;
        var pct = r.trendPct;
        var pctR = pct !== null && pct !== undefined ? Math.round(Math.min(Math.abs(pct), 500) * 10) / 10 : null;
        var arrow = delta >= 0 ? '\u25B2' : '\u25BC';

        // Row 1: name + absolute delta
        var row1 = el('div', 'flex items-center justify-between gap-2', []);
        var nameSpan = el('span', 'pulse-name text-heading', '');
        nameSpan.title = r.name || name;
        nameSpan.appendChild(document.createTextNode(clipName(name)));
        if (isNew) {
          var badge = el('span', 'ml-1.5 text-[10px] font-semibold uppercase rounded', 'new');
          badge.style.cssText = 'background:rgba(251,191,36,0.15);color:#fbbf24;padding:1px 6px;';
          nameSpan.appendChild(badge);
        }
        row1.appendChild(nameSpan);
        var deltaStr = (delta >= 0 ? '+' : '') + fmt.format(delta);
        if (isNew) deltaStr = '+' + fmt.format(delta > 0 ? delta : curr);
        row1.appendChild(el('span', 'pulse-delta tabular-nums font-semibold ' + colorCls, deltaStr));

        // Row 2: percent + baseline + sparkline
        var row2 = el('div', 'flex items-center justify-between gap-2 mt-0.5', []);
        var leftTxt = '';
        if (isNew) leftTxt = prev === 0 ? 'zero \u2192 active this week' : 'first activity';
        else if (pctR !== null) leftTxt = arrow + ' ' + pctR + (Math.abs(pct || 0) > 500 ? '+' : '') + '% vs prior week';
        row2.appendChild(el('span', 'text-[11px] text-dim tabular-nums', leftTxt));

        var rightSpan = el('span', 'text-[11px] text-dim tabular-nums', '');
        if (isNew) {
          rightSpan.appendChild(document.createTextNode(fmt.format(curr) + '/wk'));
        } else {
          rightSpan.appendChild(document.createTextNode(fmt.format(prev) + ' \u2192 ' + fmt.format(curr)));
        }
        // Sparkline from leaderboard data
        var lbRow = lbData ? lbData.find(function (x) { return x.name === r.name || x.name === name; }) : null;
        var svg = lbRow ? sparkSvg(lbRow.range30) : null;
        if (svg) rightSpan.appendChild(svg);
        row2.appendChild(rightSpan);

        var li = el('li', 'pulse-row', [row1, row2]);
        parent.appendChild(li);
      }

      function renderPulsePanel(data, movers, lbData) {
        var allGainers = movers.topGainers || [];
        var allDecliners = movers.topDecliners || [];
        var newlyActive = movers.newlyActive || [];
        var concPctVal = Math.round(movers.concentrationTop5Pct || 0);

        var estGainers = allGainers.filter(function (r) { return mPrev(r) >= ESTAB_FLOOR; });
        var emGainers = allGainers.filter(function (r) { return mPrev(r) < ESTAB_FLOOR; });
        var estDecliners = allDecliners.filter(function (r) { return mPrev(r) >= ESTAB_FLOOR; });

        // Merge newly-active into emerging
        var emMap = {};
        emGainers.forEach(function (r) { emMap[r.name] = true; });
        var emAll = emGainers.concat(newlyActive.filter(function (a) { return !emMap[a.name]; }));
        emAll.sort(function (a, b) { return (b.week || 0) - (a.week || 0); });
        emAll = emAll.slice(0, 5);

        // Summary
        var accel = allGainers.filter(function (r) { return (r.trendPct || 0) > 10; }).length;
        var stabil = allGainers.length - accel;
        var sumEl = document.getElementById('pulse-summary');
        if (sumEl) sumEl.textContent = 'Top 5 packages drive ' + concPctVal + '% of weekly downloads. ' + accel + ' accelerating, ' + (stabil > 0 ? stabil + ' stabilizing' : '0 stabilizing') + '.';
        var concEl = document.getElementById('pulse-conc');
        if (concEl) { concEl.textContent = String(concPctVal); concEl.setAttribute('data-value', String(concPctVal)); }

        // Established column
        var estUl = document.getElementById('pulse-established');
        if (estUl) {
          estUl.textContent = '';
          if (estGainers.length === 0) {
            estUl.appendChild(el('li', 'text-xs text-dim', 'No established gainers this week'));
          } else {
            estGainers.forEach(function (r) { renderPulseRow(estUl, r, 'text-emerald-400', false, lbData); });
          }
        }

        // Established decliners
        var decUl = document.getElementById('pulse-decliners');
        if (decUl) {
          decUl.textContent = '';
          if (estDecliners.length > 0) {
            estDecliners.forEach(function (r) { renderPulseRow(decUl, r, 'text-rose-400', false, lbData); });
            decUl.parentElement.classList.remove('hidden');
          } else if (decUl.parentElement) {
            decUl.parentElement.classList.add('hidden');
          }
        }

        // Emerging column
        var emUl = document.getElementById('pulse-emerging');
        if (emUl) {
          emUl.textContent = '';
          if (emAll.length === 0) {
            emUl.appendChild(el('li', 'text-xs text-dim', 'No emerging packages this week'));
          } else {
            emAll.forEach(function (r) {
              var isN = r.trendPct === null && mPrev(r) === 0 && mCurr(r) > 0;
              renderPulseRow(emUl, r, 'text-amber-400', isN, lbData);
            });
          }
        }
      }
      renderPulsePanel(data, movers, data.leaderboard || []);

      var healthRows = document.getElementById('health-rows');
      if (healthRows && data.manifestCounts) {
        healthRows.textContent = '';
        Object.keys(data.manifestCounts).forEach(function (reg) {
          var expected = data.manifestCounts[reg] || 0;
          var fetched = (data.fetchedCounts || {})[reg] || 0;
          var conf = (data.confidence || {})[reg] || 'missing';
          var regErr = (data.errorsByRegistry || {})[reg] || 0;
          var badge = confBadge(conf);
          var infoChildren = [document.createTextNode(fetched + '/' + expected + ' fetched')];
          if (regErr > 0) {
            infoChildren.push(document.createTextNode(' '));
            infoChildren.push(el('span', 'ml-2 text-amber-400', '(' + regErr + ' issues)'));
          }
          healthRows.appendChild(el('div', 'flex items-center justify-between gap-3 rounded-xl border border-edge px-4 py-3', [
            el('div', 'flex items-center gap-2', [
              el('span', '', badge),
              el('span', 'font-medium text-heading', regLabel(reg))
            ]),
            el('div', 'text-sm text-dim tabular-nums', infoChildren)
          ]));
        });
      }
      var errCount = document.getElementById('health-error-count');
      if (errCount) {
        errCount.textContent = '';
        errCount.appendChild(document.createTextNode('Errors: '));
        errCount.appendChild(el('span', 'font-medium text-muted', String(data.errors ? data.errors.length : 0)));
      }
      var freshness = document.getElementById('health-freshness');
      if (freshness && data.confidence) {
        var ok = Object.values(data.confidence).filter(function (c) { return c === 'ok'; }).length;
        var total = Object.keys(data.confidence).length;
        freshness.textContent = 'Freshness: updated ' + relTime(data.fetchedAt) + ' \u2022 ' + ok + '/' + total + ' registries OK';
      }

      // Registry breakdown — uses total for cumulative registries (Docker/VS Code/NuGet)
      var regTotals = data.registryTotals || {};
      var maxB = 1;
      Object.keys(regTotals).forEach(function (k) {
        var v = regDisplayVal(k, regTotals[k]);
        if (v > maxB) maxB = v;
      });
      var bars = document.getElementById('breakdown-bars');
      if (bars) {
        bars.textContent = '';
        Object.keys(regTotals).forEach(function (key) {
          var r = regTotals[key];
          var displayVal = regDisplayVal(key, r);
          var pct = Math.round((displayVal / maxB) * 100);
          var labelChildren = [document.createTextNode(regLabel(key))];
          if (key === 'vscode' || key === 'nuget') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time installs)'));
          } else if (key === 'docker') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time pulls)'));
          }
          var barInner = document.createElement('div');
          barInner.className = 'h-2 rounded-full bg-accent';
          barInner.style.width = pct + '%';
          bars.appendChild(el('div', '', [
            el('div', 'flex items-center justify-between text-sm', [
              el('div', 'font-medium text-heading', labelChildren),
              el('div', 'text-dim', [
                el('span', 'text-muted font-medium', fmtCompact.format(displayVal)),
                el('span', 'mx-2 text-edge', '\u2022'),
                document.createTextNode(fmt.format(r.packages) + ' pkg')
              ])
            ]),
            el('div', 'mt-2 h-2 rounded-full bg-surface-strong overflow-hidden', [barInner])
          ]));
        });
      }
      var bmax = document.getElementById('breakdown-max');
      if (bmax) {
        bmax.textContent = '';
        bmax.appendChild(document.createTextNode('Max: '));
        bmax.appendChild(el('span', 'font-medium text-muted', fmtCompact.format(maxB)));
      }

      var sp30 = data.sparkline30 || [];
      var spMax = 1;
      for (var si = 0; si < sp30.length; si++) { var sv = Number(sp30[si]); if (sv > spMax) spMax = sv; }
      var spEl = document.getElementById('sparkline-agg');
      if (spEl) {
        spEl.textContent = '';
        sp30.forEach(function (n) {
          var h = Math.max(2, Math.round((Number(n) / spMax) * 100));
          var s = document.createElement('span');
          s.className = 'spark';
          s.style.height = h + '%';
          s.title = fmt.format(n) + ' downloads';
          spEl.appendChild(s);
        });
      }

      var lb = data.leaderboard || [];
      var lbCount = document.getElementById('leaderboard-count');
      if (lbCount) lbCount.textContent = String(lb.length);
      var tbody = document.getElementById('leaderboard-body');
      if (tbody) {
        tbody.textContent = '';
        lb.forEach(function (row, i) {
          var prev = row.range30 && row.range30.length === 30
            ? row.range30.slice(-14, -7).reduce(function (a, b) { return a + Number(b); }, 0) : null;
          var curr = row.range30 && row.range30.length === 30
            ? row.range30.slice(-7).reduce(function (a, b) { return a + Number(b); }, 0) : row.week;
          var tb = trendBadge(row.trendPct, prev, curr);
          var has30 = row.range30 && row.range30.length === 30;
          var sparkCell;
          if (has30) {
            var rm = 1;
            for (var ri = 0; ri < row.range30.length; ri++) { if (row.range30[ri] > rm) rm = row.range30[ri]; }
            sparkCell = document.createElement('div');
            sparkCell.className = 'row-spark';
            sparkCell.title = 'Peak: ' + fmt.format(rm) + '/day';
            row.range30.forEach(function (n) {
              var s = document.createElement('span');
              s.className = 'rs';
              s.style.height = Math.max(1, Math.round((n / rm) * 100)) + '%';
              sparkCell.appendChild(s);
            });
          } else {
            sparkCell = el('span', 'text-dim text-xs', '\u2014');
          }
          function td(cls, child) {
            var c = document.createElement('td');
            c.className = cls;
            c.appendChild(typeof child === 'string' ? document.createTextNode(child) : child);
            return c;
          }
          var tr = document.createElement('tr');
          tr.className = 'border-t border-edge-subtle hover:bg-surface-raised/50';
          tr.appendChild(td('px-5 py-3 text-dim tabular-nums', String(i + 1)));
          tr.appendChild(td('px-5 py-3 font-medium text-heading', String(row.name)));
          tr.appendChild(td('px-5 py-3 text-dim', regLabel(row.registry)));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(regDisplayVal(row.registry, row))));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(row.month)));
          tr.appendChild(td('px-3 py-3', sparkCell));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums ' + tb.cls, tb.text));
          tbody.appendChild(tr);
        });
      }

      // Leaderboard footer
      var lbFoot = document.getElementById('leaderboard-footer');
      if (lbFoot) {
        lbFoot.textContent = '';
        if (data.errors && data.errors.length > 0) {
          lbFoot.appendChild(el('div', 'border-t border-edge bg-surface-raised px-5 py-3 text-xs text-dim',
            'Some sources failed to fetch (' + data.errors.length + '). Data may be partial.'));
        }
      }
    }

    // Read base path from meta tag set by AppShell (avoids hardcoded path)
    var baseMeta = document.querySelector('meta[name="base-url"]');
    var basePath = (baseMeta ? baseMeta.getAttribute('content') : '/registry-stats') + '/';
    var statsUrl = basePath + 'data/stats.json';

    fetch(statsUrl).then(function (res) {
      if (!res.ok) throw new Error(res.status);
      return res.json();
    }).then(function (data) {
      if (!validateStats(data)) return;
      // Always seed __rpCurrentData so export works from build-time data
      if (!window.__rpCurrentData) window.__rpCurrentData = data;
      var existing = document.getElementById('updated-at');
      var buildTime = existing ? existing.getAttribute('data-fetched') : null;
      if (buildTime && data.fetchedAt === buildTime) return;
      renderDashboard(data);
    }).catch(function () {
      // Runtime fetch failed — build-time data is still displayed. Silent fallback.
    });

    // Expose refresh API for live data engine
    window.__rpRefresh = function (statsData, chartJson) {
      if (!validateStats(statsData)) return false;
      var chartEl = document.getElementById('chart-data');
      if (chartEl && chartJson) chartEl.setAttribute('data-json', chartJson);
      renderDashboard(statsData);
      if (typeof window.__rpInitCharts === 'function') window.__rpInitCharts();
      return true;
    };
  })();
</script>

<script is:inline>
  // ═══════════════════════════════════════════════════
  // Ollama Chat Engine — plug-and-play local LLM chat
  // ═══════════════════════════════════════════════════
  (function () {
    var OLLAMA_BASE = 'http://localhost:11434';
    var STORAGE_KEY = 'rp-chat-history';
    var STORAGE_MODEL = 'rp-chat-model';

    var dot = document.getElementById('ollama-dot');
    var statusLabel = document.getElementById('ollama-label');
    var modelSelect = document.getElementById('ollama-model');
    var msgContainer = document.getElementById('chat-messages');
    var chatInput = document.getElementById('chat-input');
    var chatSend = document.getElementById('chat-send');
    var chatClear = document.getElementById('chat-clear');
    var chatProgress = document.getElementById('chat-progress');
    var chatElapsed = document.getElementById('chat-elapsed');
    var chatProgressLabel = document.getElementById('chat-progress-label');
    var sendSpinner = document.getElementById('send-spinner');
    var sendLabel = document.getElementById('send-label');
    if (!dot || !msgContainer || !chatInput) return; // guard: chat not rendered

    var connected = false;
    var sending = false;
    var history = [];
    var elapsedTimer = null;

    // ── Build system prompt with full stats context ──
    var ctxEl = document.getElementById('chat-context');
    var rawCtx = '';
    if (ctxEl) { try { rawCtx = ctxEl.getAttribute('data-json') || ''; } catch (e) {} }

    var SYSTEM = 'You are Pulse — a sharp, friendly co-pilot for an open-source team shipping packages across npm, PyPI, NuGet, VS Code Marketplace, and Docker Hub.\n\n' +
      'Personality: direct, warm, concise. Talk like a smart teammate on a call — not a report generator. ' +
      'Lead with the insight, skip the preamble. Two to three sentences is your sweet spot. ' +
      'Use numbers from the data when they matter, but don\'t recite tables back. ' +
      'If you spot something worth flagging, just say it. ' +
      'If you don\'t know, say so — no filler.\n\n' +
      'You can also just chat. Not every question is about data.\n\n' +
      'CURRENT PORTFOLIO DATA:\n' + rawCtx;

    // ── localStorage persistence ──
    function loadHistory() {
      try { var s = localStorage.getItem(STORAGE_KEY); if (s) history = JSON.parse(s); } catch (e) { history = []; }
    }
    function saveHistory() {
      try {
        // Keep max 60 messages to avoid quota issues
        if (history.length > 60) history = history.slice(-60);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      } catch (e) {}
    }

    // ── DOM helpers ──
    function clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }

    function renderMessages() {
      clearEl(msgContainer);
      if (history.length === 0) {
        var ph = document.createElement('div');
        ph.className = 'text-sm text-dim text-center py-8';
        ph.textContent = 'Hey — ask me anything about your numbers, trends, or what to ship next.';
        msgContainer.appendChild(ph);
        return;
      }
      for (var i = 0; i < history.length; i++) {
        var msg = history[i];
        var row = document.createElement('div');
        row.className = msg.role === 'user' ? 'flex justify-end' : 'flex justify-start';
        var bubble = document.createElement('div');
        bubble.className = msg.role === 'user' ? 'chat-bubble-user' : 'chat-bubble-ai';
        bubble.textContent = msg.content;
        row.appendChild(bubble);
        if (msg.role === 'assistant' && voiceReady) {
          var speakBtn = document.createElement('button');
          speakBtn.className = 'voice-speak-btn ml-1 self-end text-dim hover:text-heading transition-colors';
          speakBtn.title = 'Speak this response';
          speakBtn.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M11 5L6 9H2v6h4l5 4V5z"></path></svg>';
          speakBtn.setAttribute('data-text', msg.content);
          speakBtn.addEventListener('click', function () { speakText(this.getAttribute('data-text')); });
          row.appendChild(speakBtn);
        }
        msgContainer.appendChild(row);
      }
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    // ── Connection check ──
    function checkOllama() {
      dot.className = 'inline-block w-2 h-2 rounded-full bg-zinc-500 animate-pulse';
      statusLabel.textContent = 'Checking\u2026';

      var ctrl = new AbortController();
      var tid = setTimeout(function () { ctrl.abort(); }, 4000);

      fetch(OLLAMA_BASE + '/api/tags', { signal: ctrl.signal })
        .then(function (r) { clearTimeout(tid); return r.json(); })
        .then(function (data) {
          connected = true;
          dot.className = 'inline-block w-2 h-2 rounded-full bg-emerald-400';
          statusLabel.textContent = 'Connected';

          var models = (data.models || []).map(function (m) { return m.name || m.model; });
          if (models.length > 0) {
            clearEl(modelSelect);
            var saved = '';
            try { saved = localStorage.getItem(STORAGE_MODEL) || ''; } catch (e) {}
            for (var i = 0; i < models.length; i++) {
              var opt = document.createElement('option');
              opt.value = models[i]; opt.textContent = models[i];
              if (models[i] === saved) opt.selected = true;
              modelSelect.appendChild(opt);
            }
            modelSelect.disabled = false;
            chatInput.disabled = false;
            chatSend.disabled = false;
            chatInput.focus();

            // Pre-warm: keep selected model loaded in VRAM for instant responses
            var warmModel = modelSelect.value;
            fetch(OLLAMA_BASE + '/api/generate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ model: warmModel, prompt: '', keep_alive: '30m', stream: false })
            }).catch(function () {});
          }
        })
        .catch(function () {
          clearTimeout(tid);
          connected = false;
          dot.className = 'inline-block w-2 h-2 rounded-full bg-rose-400';
          statusLabel.textContent = 'Offline';
          clearEl(msgContainer);
          var help = document.createElement('div');
          help.className = 'text-center py-6 space-y-2';
          var l1 = document.createElement('div');
          l1.className = 'text-sm text-dim';
          l1.textContent = 'Could not connect to Ollama at localhost:11434';
          var l2 = document.createElement('div');
          l2.className = 'text-xs text-dim';
          l2.textContent = 'Install from ollama.com \u2022 then run: ollama pull llama3.2';
          var retry = document.createElement('button');
          retry.className = 'mt-2 text-xs text-accent hover:underline cursor-pointer';
          retry.textContent = 'Retry connection';
          retry.addEventListener('click', checkOllama);
          help.appendChild(l1); help.appendChild(l2); help.appendChild(retry);
          msgContainer.appendChild(help);
        });
    }

    // ── Send message (streaming) ──
    function sendMessage() {
      if (!connected || sending) return;
      var text = chatInput.value.trim();
      if (!text) return;

      sending = true;
      chatInput.value = '';
      chatSend.disabled = true;
      chatInput.disabled = true;

      // Show loading UI
      if (sendSpinner) sendSpinner.classList.remove('hidden');
      if (sendLabel) sendLabel.textContent = 'Thinking…';
      if (chatProgress) chatProgress.classList.remove('hidden');
      if (chatProgressLabel) chatProgressLabel.textContent = 'Thinking…';
      var startTime = Date.now();
      if (elapsedTimer) clearInterval(elapsedTimer);
      elapsedTimer = setInterval(function () {
        var s = ((Date.now() - startTime) / 1000).toFixed(1);
        if (chatElapsed) chatElapsed.textContent = s + 's';
      }, 100);

      history.push({ role: 'user', content: text });
      renderMessages();

      // Typing indicator
      var typingRow = document.createElement('div');
      typingRow.className = 'flex justify-start';
      var typingBubble = document.createElement('div');
      typingBubble.className = 'chat-bubble-ai chat-typing';
      for (var d = 0; d < 3; d++) typingBubble.appendChild(document.createElement('span'));
      typingRow.appendChild(typingBubble);
      msgContainer.appendChild(typingRow);
      msgContainer.scrollTop = msgContainer.scrollHeight;

      // Build messages: system + last 20 turns
      var msgs = [{ role: 'system', content: SYSTEM + ghContext }].concat(history.slice(-20));

      var model = modelSelect.value;
      try { localStorage.setItem(STORAGE_MODEL, model); } catch (e) {}

      fetch(OLLAMA_BASE + '/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          model: model,
          messages: msgs,
          stream: true,
          keep_alive: '30m',
          options: {
            num_ctx: 8192,
            temperature: 0.7,
            num_predict: 512
          }
        })
      }).then(function (resp) {
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        // Switch progress label to streaming
        if (chatProgressLabel) chatProgressLabel.textContent = 'Streaming response…';
        // Replace typing with response bubble
        msgContainer.removeChild(typingRow);
        var aiRow = document.createElement('div');
        aiRow.className = 'flex justify-start';
        var aiBubble = document.createElement('div');
        aiBubble.className = 'chat-bubble-ai';
        aiBubble.textContent = '';
        aiRow.appendChild(aiBubble);
        msgContainer.appendChild(aiRow);

        var reader = resp.body.getReader();
        var decoder = new TextDecoder();
        var fullText = '';

        function pump() {
          return reader.read().then(function (result) {
            if (result.done) {
              if (fullText) {
                history.push({ role: 'assistant', content: fullText });
                saveHistory();
                if (voiceReady) {
                  var spk = document.createElement('button');
                  spk.className = 'voice-speak-btn ml-1 self-end text-dim hover:text-heading transition-colors';
                  spk.title = 'Speak this response';
                  spk.innerHTML = '<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.536 8.464a5 5 0 010 7.072M17.95 6.05a8 8 0 010 11.9M11 5L6 9H2v6h4l5 4V5z"></path></svg>';
                  spk.setAttribute('data-text', fullText);
                  spk.addEventListener('click', function () { speakText(this.getAttribute('data-text')); });
                  aiRow.appendChild(spk);
                  // Auto-speak when streaming completes
                  if (autoSpeak) speakText(fullText);
                }
              }
              sending = false;
              chatSend.disabled = false;
              chatInput.disabled = false;
              chatInput.focus();
              if (elapsedTimer) { clearInterval(elapsedTimer); elapsedTimer = null; }
              if (chatProgress) chatProgress.classList.add('hidden');
              if (sendSpinner) sendSpinner.classList.add('hidden');
              if (sendLabel) sendLabel.textContent = 'Send';
              return;
            }
            var lines = decoder.decode(result.value, { stream: true }).split('\n');
            for (var i = 0; i < lines.length; i++) {
              if (!lines[i].trim()) continue;
              try {
                var json = JSON.parse(lines[i]);
                if (json.message && json.message.content) {
                  fullText += json.message.content;
                  aiBubble.textContent = fullText;
                  msgContainer.scrollTop = msgContainer.scrollHeight;
                }
              } catch (e) {}
            }
            return pump();
          });
        }
        return pump();
      }).catch(function (err) {
        if (typingRow.parentNode) msgContainer.removeChild(typingRow);
        var errRow = document.createElement('div');
        errRow.className = 'flex justify-start';
        var errBubble = document.createElement('div');
        errBubble.className = 'chat-bubble-ai text-rose-400';
        errBubble.textContent = 'Error: ' + (err.message || 'Could not get a response. Is the model loaded?');
        errRow.appendChild(errBubble);
        msgContainer.appendChild(errRow);

        sending = false;
        chatSend.disabled = false;
        chatInput.disabled = false;
        if (elapsedTimer) { clearInterval(elapsedTimer); elapsedTimer = null; }
        if (chatProgress) chatProgress.classList.add('hidden');
        if (sendSpinner) sendSpinner.classList.add('hidden');
        if (sendLabel) sendLabel.textContent = 'Send';
      });
    }

    // ── Event listeners ──
    chatSend.addEventListener('click', sendMessage);
    chatInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
    chatClear.addEventListener('click', function () {
      history = [];
      saveHistory();
      renderMessages();
    });
    modelSelect.addEventListener('change', function () {
      try { localStorage.setItem(STORAGE_MODEL, modelSelect.value); } catch (e) {}
    });

    // ── Voice integration ──
    var VOICE_BASE = 'http://localhost:11435';
    var voiceReady = false;
    var voiceSessionId = null;
    var voiceControls = document.getElementById('voice-controls');
    var voiceSelect = document.getElementById('voice-select');
    var voiceDot = document.getElementById('voice-dot');
    var voiceStatusDot = document.getElementById('voice-status-dot');
    var voiceStatusLabel = document.getElementById('voice-status-label');
    var voiceInstallHint = document.getElementById('voice-install-hint');
    var voiceCheckBtn = document.getElementById('voice-check-btn');
    var voiceBanner = document.getElementById('voice-banner');
    var voiceBannerHelp = document.getElementById('voice-banner-help');
    var voiceAutoBtn = document.getElementById('voice-auto-btn');
    var voiceAutoOn = document.getElementById('voice-auto-on');
    var voiceAutoOff = document.getElementById('voice-auto-off');
    var autoSpeak = true;
    try { autoSpeak = localStorage.getItem('pulse-auto-speak') !== 'false'; } catch (e) {}

    function updateAutoSpeakUI() {
      if (voiceAutoOn) voiceAutoOn.classList.toggle('hidden', !autoSpeak);
      if (voiceAutoOff) voiceAutoOff.classList.toggle('hidden', autoSpeak);
      if (voiceAutoBtn) voiceAutoBtn.title = autoSpeak ? 'Auto-speak on (click to mute)' : 'Auto-speak off (click to unmute)';
    }
    updateAutoSpeakUI();
    if (voiceAutoBtn) voiceAutoBtn.addEventListener('click', function () {
      autoSpeak = !autoSpeak;
      try { localStorage.setItem('pulse-auto-speak', autoSpeak ? 'true' : 'false'); } catch (e) {}
      updateAutoSpeakUI();
    });

    if (voiceBannerHelp) voiceBannerHelp.addEventListener('click', function () {
      if (settingsPanel) settingsPanel.classList.remove('hidden');
    });

    function updateVoiceStatus(online) {
      // Update settings panel
      if (voiceStatusDot) {
        if (online) {
          voiceStatusDot.className = 'inline-block w-2 h-2 rounded-full bg-emerald-400';
          voiceStatusLabel.textContent = 'Connected';
          voiceStatusLabel.className = 'text-xs text-emerald-400';
          if (voiceInstallHint) voiceInstallHint.classList.add('hidden');
        } else {
          voiceStatusDot.className = 'inline-block w-2 h-2 rounded-full bg-zinc-500';
          voiceStatusLabel.textContent = 'Not running';
          voiceStatusLabel.className = 'text-xs text-dim';
          if (voiceInstallHint) voiceInstallHint.classList.remove('hidden');
        }
      }
      // Update banner
      if (voiceBanner) {
        if (online) {
          voiceBanner.classList.add('hidden');
        } else {
          voiceBanner.classList.remove('hidden');
        }
      }
    }

    function checkVoiceServer() {
      fetch(VOICE_BASE + '/health', { signal: AbortSignal.timeout(3000) })
        .then(function (r) { return r.json(); })
        .then(function () {
          if (!voiceReady) {
            voiceReady = true;
            if (voiceControls) voiceControls.classList.remove('hidden');
            initVoiceSession();
            renderMessages();
          }
          updateVoiceStatus(true);
        })
        .catch(function () {
          var wasReady = voiceReady;
          voiceReady = false;
          voiceSessionId = null;
          if (wasReady && voiceControls) voiceControls.classList.add('hidden');
          updateVoiceStatus(false);
        });
    }
    if (voiceCheckBtn) voiceCheckBtn.addEventListener('click', checkVoiceServer);
    // Retry every 15s so voice appears automatically when server starts
    setInterval(checkVoiceServer, 15000);

    var MCP_HEADERS = { 'Content-Type': 'application/json', 'Accept': 'application/json, text/event-stream' };

    // Parse MCP Streamable HTTP response (may be SSE or plain JSON)
    function parseMcpResponse(response) {
      var ct = response.headers.get('content-type') || '';
      if (ct.indexOf('text/event-stream') !== -1) {
        return response.text().then(function (text) {
          var lines = text.split('\n');
          for (var i = 0; i < lines.length; i++) {
            if (lines[i].indexOf('data:') === 0) {
              return JSON.parse(lines[i].substring(5).trim());
            }
          }
          return null;
        });
      }
      return response.json();
    }

    function initVoiceSession() {
      fetch(VOICE_BASE + '/mcp', {
        method: 'POST',
        headers: MCP_HEADERS,
        body: JSON.stringify({ jsonrpc: '2.0', id: 1, method: 'initialize', params: {
          protocolVersion: '2025-03-26',
          capabilities: {},
          clientInfo: { name: 'registry-pulse', version: '1.0.0' }
        }})
      }).then(function (r) {
        voiceSessionId = r.headers.get('mcp-session-id');
        console.log('[Pulse voice] Session initialized:', voiceSessionId);
        return parseMcpResponse(r);
      }).then(function () {
        var h = Object.assign({}, MCP_HEADERS, { 'mcp-session-id': voiceSessionId });
        return fetch(VOICE_BASE + '/mcp', {
          method: 'POST',
          headers: h,
          body: JSON.stringify({ jsonrpc: '2.0', method: 'notifications/initialized' })
        });
      }).catch(function (e) {
        console.error('[Pulse voice] Session init failed:', e);
        voiceReady = false;
        if (voiceControls) voiceControls.classList.add('hidden');
      });
    }

    // Shared AudioContext — unlocked on first user click
    var voiceAudioCtx = null;
    var voiceQueue = [];       // queued AudioBuffers
    var voicePlaying = false;  // true while a buffer is playing
    var voiceCancelled = false; // set true to stop queue

    function decodeBase64Audio(b64) {
      var byteStr = atob(b64);
      var bytes = new Uint8Array(byteStr.length);
      for (var j = 0; j < byteStr.length; j++) bytes[j] = byteStr.charCodeAt(j);
      if (!voiceAudioCtx) voiceAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
      return voiceAudioCtx.decodeAudioData(bytes.buffer.slice(0));
    }

    function playNextInQueue() {
      if (voiceCancelled || voiceQueue.length === 0) {
        voicePlaying = false;
        if (voiceDot) voiceDot.className = 'inline-block w-2 h-2 rounded-full bg-emerald-400';
        return;
      }
      voicePlaying = true;
      var buffer = voiceQueue.shift();
      var source = voiceAudioCtx.createBufferSource();
      source.buffer = buffer;
      source.connect(voiceAudioCtx.destination);
      source.onended = playNextInQueue;
      source.start(0);
    }

    function enqueueAudio(buffer) {
      voiceQueue.push(buffer);
      if (!voicePlaying) playNextInQueue();
    }

    // Map voice IDs to presets for enhanced prosody
    var VOICE_PRESETS = {
      'bm_george': 'narrator',
      'af_bella': 'assistant',
      'bf_emma': 'storyteller',
      'am_michael': 'announcer'
    };

    // Strip markdown for speech
    function cleanForSpeech(text) {
      return text
        .replace(/```[\s\S]*?```/g, '')          // code blocks
        .replace(/#{1,6}\s+/g, '')               // headings
        .replace(/\*\*([^*]+)\*\*/g, '$1')       // bold
        .replace(/\*([^*]+)\*/g, '$1')            // italic
        .replace(/`([^`]+)`/g, '$1')              // inline code
        .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')  // links
        .replace(/^[-*]\s+/gm, '')                // bullets
        .replace(/^\d+\.\s+/gm, '')               // numbered lists
        .replace(/\n{2,}/g, '. ')                  // paragraph breaks → pause
        .replace(/\n/g, ' ')                       // newlines → space
        .replace(/\s{2,}/g, ' ')                   // collapse whitespace
        .trim();
    }

    // Split text into sentences for chunked synthesis
    function splitSentences(text) {
      // Split on sentence-ending punctuation followed by space/end
      var parts = text.match(/[^.!?]*[.!?]+[\s]?|[^.!?]+$/g);
      if (!parts) return [text];
      return parts.map(function(s) { return s.trim(); }).filter(function(s) { return s.length > 0; });
    }

    // Synthesize one chunk and return decoded AudioBuffer
    function synthesizeChunk(text, preset) {
      var speakHeaders = Object.assign({}, MCP_HEADERS, { 'mcp-session-id': voiceSessionId });
      return fetch(VOICE_BASE + '/mcp', {
        method: 'POST',
        headers: speakHeaders,
        body: JSON.stringify({ jsonrpc: '2.0', id: Date.now(), method: 'tools/call', params: {
          name: 'voice_speak',
          arguments: { text: text, voice: preset, artifactMode: 'base64' }
        }})
      }).then(function (r) { return parseMcpResponse(r); })
        .then(function (data) {
          if (!data || data.error) return null;
          var content = data && data.result && data.result.content;
          if (!content) return null;
          for (var i = 0; i < content.length; i++) {
            var item = content[i];
            if (item.type === 'text' && item.text) {
              try {
                var parsed = JSON.parse(item.text);
                if (parsed.audioBytesBase64) return decodeBase64Audio(parsed.audioBytesBase64);
              } catch (e) {}
            }
            if (item.type === 'resource' && item.resource && item.resource.blob) {
              return decodeBase64Audio(item.resource.blob);
            }
          }
          return null;
        });
    }

    function speakText(text) {
      if (!voiceReady || !voiceSessionId) {
        console.warn('[Pulse voice] Not ready:', { voiceReady: voiceReady, voiceSessionId: voiceSessionId });
        return;
      }

      // Cancel any in-progress speech
      voiceCancelled = true;
      voiceQueue = [];
      setTimeout(function () { voiceCancelled = false; }, 50);

      var voiceId = voiceSelect ? voiceSelect.value : 'bm_george';
      var preset = VOICE_PRESETS[voiceId] || 'narrator';
      var cleaned = cleanForSpeech(text);
      var sentences = splitSentences(cleaned);
      if (voiceDot) voiceDot.className = 'inline-block w-2 h-2 rounded-full bg-amber-400 animate-pulse';

      // Unlock AudioContext on user gesture (before async fetch)
      if (!voiceAudioCtx) voiceAudioCtx = new (window.AudioContext || window.webkitAudioContext)();
      if (voiceAudioCtx.state === 'suspended') voiceAudioCtx.resume();

      // Fire all sentences in parallel — each enqueues its audio as soon as it's ready
      // But we need them to play IN ORDER, so we use a chain
      var chain = Promise.resolve();
      sentences.forEach(function (sentence) {
        // Start synthesis immediately (in parallel)
        var bufferPromise = synthesizeChunk(sentence, preset);
        // But enqueue in order via chain
        chain = chain.then(function () {
          return bufferPromise;
        }).then(function (buffer) {
          if (buffer && !voiceCancelled) enqueueAudio(buffer);
        });
      });
      chain.catch(function (e) {
        console.error('[Pulse voice] Speak failed:', e);
        if (voiceDot) voiceDot.className = 'inline-block w-2 h-2 rounded-full bg-rose-400';
        setTimeout(function () {
          if (voiceDot) voiceDot.className = 'inline-block w-2 h-2 rounded-full bg-emerald-400';
        }, 2000);
      });
    }

    checkVoiceServer();

    // ── GitHub connector ──
    var GH_PAT_KEY = 'rp-gh-pat';
    var GH_CTX_KEY = 'rp-gh-context';
    var ghContext = '';

    var settingsBtn = document.getElementById('chat-settings-btn');
    var settingsPanel = document.getElementById('chat-settings-panel');
    var settingsClose = document.getElementById('chat-settings-close');
    var ghPatInput = document.getElementById('gh-pat-input');
    var ghPatSave = document.getElementById('gh-pat-save');
    var ghPatStatus = document.getElementById('gh-pat-status');

    if (settingsBtn) settingsBtn.addEventListener('click', function () {
      settingsPanel.classList.toggle('hidden');
    });
    if (settingsClose) settingsClose.addEventListener('click', function () {
      settingsPanel.classList.add('hidden');
    });

    function fetchGitHubOrg(pat) {
      if (!pat) return;
      ghPatStatus.textContent = 'Fetching org data…';
      ghPatStatus.className = 'mt-1.5 text-xs text-dim';
      fetch('https://api.github.com/orgs/mcp-tool-shop-org/repos?per_page=100&sort=updated', {
        headers: { 'Authorization': 'token ' + pat, 'Accept': 'application/vnd.github.v3+json' }
      }).then(function (r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      }).then(function (repos) {
        var summary = repos.map(function (r) {
          return r.name + ' — ' + (r.description || 'no description') +
            ' | stars:' + r.stargazers_count + ' forks:' + r.forks_count +
            ' issues:' + r.open_issues_count + ' lang:' + (r.language || 'n/a');
        }).join('\n');
        ghContext = '\n\nGITHUB ORG DATA (mcp-tool-shop-org, ' + repos.length + ' repos):\n' + summary;
        try { localStorage.setItem(GH_CTX_KEY, ghContext); } catch (e) {}
        ghPatStatus.textContent = 'Connected — ' + repos.length + ' repos loaded.';
        ghPatStatus.className = 'mt-1.5 text-xs text-emerald-400';
      }).catch(function (err) {
        ghContext = '';
        try { localStorage.removeItem(GH_CTX_KEY); } catch (e) {}
        ghPatStatus.textContent = 'Error: ' + err.message;
        ghPatStatus.className = 'mt-1.5 text-xs text-rose-400';
      });
    }

    if (ghPatSave) ghPatSave.addEventListener('click', function () {
      var pat = ghPatInput.value.trim();
      if (!pat) return;
      try { localStorage.setItem(GH_PAT_KEY, pat); } catch (e) {}
      fetchGitHubOrg(pat);
    });

    // Load saved PAT + cached context on init
    (function () {
      var savedPat = '';
      try { savedPat = localStorage.getItem(GH_PAT_KEY) || ''; } catch (e) {}
      if (savedPat && ghPatInput) ghPatInput.value = savedPat;
      try { ghContext = localStorage.getItem(GH_CTX_KEY) || ''; } catch (e) {}
      if (savedPat) fetchGitHubOrg(savedPat);
    })();

    // ── Fullscreen toggle ──
    var chatSection = document.getElementById('chat-section');
    var fsBtn = document.getElementById('chat-fullscreen-btn');
    var expandIcon = document.getElementById('chat-expand-icon');
    var collapseIcon = document.getElementById('chat-collapse-icon');
    var isFullscreen = false;

    function toggleFullscreen() {
      isFullscreen = !isFullscreen;
      if (isFullscreen) {
        chatSection.classList.add('chat-fullscreen');
        expandIcon.classList.add('hidden');
        collapseIcon.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      } else {
        chatSection.classList.remove('chat-fullscreen');
        expandIcon.classList.remove('hidden');
        collapseIcon.classList.add('hidden');
        document.body.style.overflow = '';
      }
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    if (fsBtn) fsBtn.addEventListener('click', toggleFullscreen);
    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && isFullscreen) toggleFullscreen();
    });

    // ── Init ──
    loadHistory();
    renderMessages();
    checkOllama();
  })();
</script>

<script is:inline>
