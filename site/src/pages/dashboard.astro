<script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>

<script is:inline>
  // Tab switching (hash-based) + Chart.js initialization
  (function () {
    var tabs = document.querySelectorAll('[data-tab]');
    var panels = document.querySelectorAll('.tab-panel');
    var chartsInitialized = false;

    function switchTab(name) {
      tabs.forEach(function (btn) {
        var active = btn.getAttribute('data-tab') === name;
        btn.classList.toggle('tab-active', active);
        btn.setAttribute('aria-selected', String(active));
      });
      panels.forEach(function (p) {
        p.classList.toggle('hidden', p.id !== 'tab-' + name);
      });
      if (name === 'analytics' && !chartsInitialized) initCharts();
      history.replaceState(null, '', '#' + name);
    }

    tabs.forEach(function (btn) {
      btn.addEventListener('click', function () {
        switchTab(btn.getAttribute('data-tab'));
      });
    });

    // Restore from hash
    var hash = location.hash.replace('#', '');
    if (hash && document.getElementById('tab-' + hash)) {
      switchTab(hash);
    }

    var CHART_PALETTE = ['#059669', '#3b82f6', '#f59e0b', '#8b5cf6', '#ef4444', '#06b6d4'];
    var REG_NAMES = { npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' };

    function getThemeColors() {
      var s = getComputedStyle(document.documentElement);
      return {
        accent: s.getPropertyValue('--color-accent').trim() || '#059669',
        heading: s.getPropertyValue('--color-heading').trim() || '#e4e4e7',
        dim: s.getPropertyValue('--color-dim').trim() || '#71717a',
        edge: s.getPropertyValue('--color-edge').trim() || '#27272a',
      };
    }

    function initCharts() {
      if (typeof Chart === 'undefined') return;
      var dataEl = document.getElementById('chart-data');
      if (!dataEl) return;
      var cdata;
      try { cdata = JSON.parse(dataEl.getAttribute('data-json')); } catch { return; }
      if (!cdata) return;
      chartsInitialized = true;

      var tc = getThemeColors();
      Chart.defaults.color = tc.dim;
      Chart.defaults.borderColor = tc.edge;
      Chart.defaults.font.family = 'system-ui, -apple-system, sans-serif';

      // ── 30-day trend (line + 7d moving avg) ──
      var sp = cdata.sparkline30 || [];
      var labels30 = sp.map(function (_, i) { return 'D-' + (sp.length - i); });
      var ma7 = [];
      for (var i = 0; i < sp.length; i++) {
        if (i < 6) { ma7.push(null); continue; }
        var sum = 0;
        for (var j = i - 6; j <= i; j++) sum += Number(sp[j]);
        ma7.push(Math.round(sum / 7));
      }
      new Chart(document.getElementById('chart-trend'), {
        type: 'line',
        data: {
          labels: labels30,
          datasets: [
            { label: 'Daily', data: sp, borderColor: tc.accent, backgroundColor: tc.accent + '20', fill: true, tension: 0.3, pointRadius: 0, borderWidth: 2 },
            { label: '7d avg', data: ma7, borderColor: CHART_PALETTE[1], borderDash: [5, 3], tension: 0.3, pointRadius: 0, borderWidth: 2, fill: false },
          ]
        },
        options: { responsive: true, maintainAspectRatio: false, interaction: { intersect: false, mode: 'index' }, scales: { x: { display: false }, y: { beginAtZero: true, ticks: { maxTicksLimit: 5 } } }, plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12 } } } }
      });

      // ── Registry share (doughnut) ──
      var regKeys = Object.keys(cdata.registryTotals || {});
      var regVals = regKeys.map(function (k) { return Number((cdata.registryTotals[k] || {}).week || 0); });
      new Chart(document.getElementById('chart-share'), {
        type: 'doughnut',
        data: {
          labels: regKeys.map(function (k) { return REG_NAMES[k] || k; }),
          datasets: [{ data: regVals, backgroundColor: CHART_PALETTE.slice(0, regKeys.length), borderWidth: 0 }]
        },
        options: { responsive: true, maintainAspectRatio: false, cutout: '55%', plugins: { legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12 } } } }
      });

      // ── Download distribution histogram ──
      var lb = cdata.leaderboard || [];
      var bucketLabels = ['0\u201399', '100\u2013999', '1K\u20139.9K', '10K\u201399K', '100K+'];
      var dist = [0, 0, 0, 0, 0];
      lb.forEach(function (r) {
        var w = Number(r.week || 0);
        if (w >= 100000) dist[4]++;
        else if (w >= 10000) dist[3]++;
        else if (w >= 1000) dist[2]++;
        else if (w >= 100) dist[1]++;
        else dist[0]++;
      });
      new Chart(document.getElementById('chart-distribution'), {
        type: 'bar',
        data: {
          labels: bucketLabels,
          datasets: [{ label: 'Packages', data: dist, backgroundColor: CHART_PALETTE.map(function (c) { return c + 'cc'; }), borderRadius: 4 }]
        },
        options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
      });

      // ── Top 10 packages (horizontal bar) ──
      var top10 = lb.slice(0, 10);
      new Chart(document.getElementById('chart-top10'), {
        type: 'bar',
        data: {
          labels: top10.map(function (r) { return r.name; }),
          datasets: [{ label: 'Weekly', data: top10.map(function (r) { return r.week; }), backgroundColor: top10.map(function (r) { return (r.trendPct || 0) >= 0 ? CHART_PALETTE[0] + 'cc' : CHART_PALETTE[4] + 'cc'; }), borderRadius: 4 }]
        },
        options: { responsive: true, maintainAspectRatio: false, indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { beginAtZero: true } } }
      });

      // ── Heatmap (canvas-drawn) ──
      var heatCanvas = document.getElementById('chart-heatmap');
      if (heatCanvas) {
        var withRange = lb.filter(function (r) { return r.range30 && r.range30.length === 30; }).slice(0, 15);
        if (withRange.length > 0) {
          var ctx = heatCanvas.getContext('2d');
          var cellW = 18, cellH = 22, padLeft = 120, padTop = 20;
          heatCanvas.width = padLeft + 30 * cellW + 10;
          heatCanvas.height = padTop + withRange.length * cellH + 10;
          heatCanvas.style.width = heatCanvas.width + 'px';
          heatCanvas.style.height = heatCanvas.height + 'px';

          var globalMax = 1;
          withRange.forEach(function (r) { r.range30.forEach(function (v) { if (v > globalMax) globalMax = v; }); });

          ctx.fillStyle = tc.dim;
          ctx.font = '10px system-ui';
          ctx.textAlign = 'center';
          for (var d = 0; d < 30; d++) {
            if (d % 5 === 0) ctx.fillText('D-' + (30 - d), padLeft + d * cellW + cellW / 2, padTop - 4);
          }

          withRange.forEach(function (pkg, row) {
            ctx.fillStyle = tc.heading;
            ctx.font = '11px system-ui';
            ctx.textAlign = 'right';
            ctx.fillText(pkg.name.substring(0, 16), padLeft - 6, padTop + row * cellH + cellH / 2 + 4);

            pkg.range30.forEach(function (val, col) {
              var intensity = Math.min(1, Number(val) / globalMax);
              var g = Math.round(150 + intensity * 70);
              var b = Math.round(100 - intensity * 20);
              ctx.fillStyle = 'rgba(5, ' + g + ', ' + b + ', ' + (0.12 + intensity * 0.88).toFixed(2) + ')';
              ctx.fillRect(padLeft + col * cellW + 1, padTop + row * cellH + 1, cellW - 2, cellH - 2);
            });
          });
        } else {
          heatCanvas.parentElement.insertBefore(
            document.createTextNode('No 30-day range data available.'),
            heatCanvas
          );
          heatCanvas.style.display = 'none';
        }
      }
    }

    // Expose for runtime refresh
    window.__rpInitCharts = function () { chartsInitialized = false; initCharts(); };
  })();
</script>

<script is:inline>
  // Runtime data loading: fetches /data/stats.json and re-renders the dashboard.
  // On web (GitHub Pages) this is a harmless re-render with the same build-time data.
  // On desktop (MAUI WebView2) this loads fresh cached data, enabling startup refresh.
  (function () {
    var fmt = new Intl.NumberFormat('en-US');
    var fmtCompact = new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 });

    var REG_LABELS = { npm: 'npm', pypi: 'PyPI', vscode: 'VS Code', nuget: 'NuGet', docker: 'Docker Hub' };
    function regLabel(k) { return REG_LABELS[k] || k; }

    function trendBadge(pct) {
      if (pct === null || pct === undefined) return { text: '\u2014', cls: 'text-dim' };
      var r = Math.round(pct * 10) / 10;
      if (r > 0) return { text: '\u25B2 ' + r + '%', cls: 'text-emerald-400' };
      if (r < 0) return { text: '\u25BC ' + Math.abs(r) + '%', cls: 'text-rose-400' };
      return { text: '0%', cls: 'text-dim' };
    }

    function relTime(iso) {
      var d = Date.now() - new Date(iso).getTime();
      var m = Math.floor(d / 60000);
      if (m < 60) return m + 'm ago';
      var h = Math.floor(m / 60);
      if (h < 24) return h + 'h ago';
      return Math.floor(h / 24) + 'd ago';
    }

    function confBadge(c) {
      if (c === 'ok') return '\u2705';
      if (c === 'partial') return '\u26A0\uFE0F';
      return '\u26D4';
    }

    // Safe DOM builder: creates element with optional class and children (strings become text nodes)
    function el(tag, cls, children) {
      var e = document.createElement(tag);
      if (cls) e.className = cls;
      if (children != null) {
        var list = Array.isArray(children) ? children : [children];
        for (var i = 0; i < list.length; i++) {
          var c = list[i];
          e.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
        }
      }
      return e;
    }

    var CUMULATIVE = ['vscode', 'nuget', 'docker'];
    function regDisplayVal(key, r) {
      return CUMULATIVE.indexOf(key) !== -1 ? Number(r.total || r.week || 0) : Number(r.week || 0);
    }

    // Lightweight schema check — rejects clearly malformed payloads
    function validateStats(data) {
      if (!data || typeof data !== 'object') return false;
      if (!data.totals || typeof data.totals !== 'object') return false;
      if (typeof data.totals.packages !== 'number') return false;
      if (typeof data.totals.week !== 'number') return false;
      if (typeof data.fetchedAt !== 'string') return false;
      if (data.leaderboard && !Array.isArray(data.leaderboard)) return false;
      if (data.sparkline30 && !Array.isArray(data.sparkline30)) return false;
      return true;
    }

    function renderDashboard(data) {
      if (!data || !data.totals) return;
      var t = data.totals;
      var movers = data.movers || {};
      var concPct = Math.round(movers.concentrationTop5Pct || 0);

      var upd = document.getElementById('updated-at');
      if (upd) {
        upd.title = new Date(data.fetchedAt).toUTCString();
        upd.setAttribute('data-fetched', data.fetchedAt);
        upd.textContent = 'Updated ' + relTime(data.fetchedAt) + '.';
      }

      var e;
      e = document.getElementById('stat-packages'); if (e) e.textContent = fmt.format(t.packages);
      e = document.getElementById('stat-weekly'); if (e) e.textContent = fmtCompact.format(t.week);
      e = document.getElementById('stat-monthly'); if (e) e.textContent = fmtCompact.format(t.month);
      e = document.getElementById('stat-concentration'); if (e) e.textContent = concPct + '%';
      e = document.getElementById('pulse-conc'); if (e) e.textContent = concPct + '%';

      // Executive snapshot
      var snap = document.getElementById('exec-snapshot');
      if (snap) snap.classList.remove('hidden');
      var meta = document.getElementById('exec-meta');
      if (meta) {
        meta.textContent = '';
        meta.appendChild(document.createTextNode('Source: build-time fetch'));
        meta.appendChild(document.createElement('br'));
        meta.appendChild(document.createTextNode(new Date(data.fetchedAt).toUTCString()));
      }
      var lines = document.getElementById('exec-lines');
      if (lines && data.narrativeLines) {
        lines.textContent = '';
        data.narrativeLines.forEach(function (ln) {
          lines.appendChild(el('div', 'flex items-start gap-3', [
            el('span', 'text-lg leading-6 shrink-0', String(ln.icon)),
            el('div', '', [
              el('span', 'text-xs font-semibold uppercase tracking-wide text-accent', String(ln.label)),
              el('span', 'text-sm text-heading ml-2', String(ln.text))
            ])
          ]));
        });
      } else if (lines && data.narrative) {
        lines.textContent = '';
        lines.appendChild(el('div', 'text-base font-medium text-heading', String(data.narrative)));
      }

      var content = document.getElementById('dashboard-content');
      if (content) content.classList.remove('hidden');

      function renderMoverList(id, items, colorCls, arrow, suffix) {
        var ul = document.getElementById(id);
        if (!ul) return;
        ul.textContent = '';
        if (!items || items.length === 0) {
          ul.appendChild(el('li', 'text-xs text-dim', 'No data this week'));
          return;
        }
        items.forEach(function (r) {
          var name = String(r.name || '').replace('@mcptoolshop/', '');
          var val = suffix === '/wk'
            ? fmt.format(r.week) + '/wk'
            : arrow + ' ' + (Math.round(Math.abs(r.trendPct || 0) * 10) / 10) + '%';
          ul.appendChild(el('li', 'flex items-center justify-between gap-2 text-sm', [
            el('span', 'truncate text-heading', name),
            el('span', colorCls + ' tabular-nums whitespace-nowrap', val)
          ]));
        });
      }
      renderMoverList('pulse-gainers', movers.topGainers, 'text-emerald-400', '\u25B2', '%');
      renderMoverList('pulse-decliners', movers.topDecliners, 'text-rose-400', '\u25BC', '%');
      renderMoverList('pulse-new', movers.newlyActive, 'text-amber-400', '', '/wk');

      var healthRows = document.getElementById('health-rows');
      if (healthRows && data.manifestCounts) {
        healthRows.textContent = '';
        Object.keys(data.manifestCounts).forEach(function (reg) {
          var expected = data.manifestCounts[reg] || 0;
          var fetched = (data.fetchedCounts || {})[reg] || 0;
          var conf = (data.confidence || {})[reg] || 'missing';
          var regErr = (data.errorsByRegistry || {})[reg] || 0;
          var badge = confBadge(conf);
          var infoChildren = [document.createTextNode(fetched + '/' + expected + ' fetched')];
          if (regErr > 0) {
            infoChildren.push(document.createTextNode(' '));
            infoChildren.push(el('span', 'ml-2 text-amber-400', '(' + regErr + ' issues)'));
          }
          healthRows.appendChild(el('div', 'flex items-center justify-between gap-3 rounded-xl border border-edge px-4 py-3', [
            el('div', 'flex items-center gap-2', [
              el('span', '', badge),
              el('span', 'font-medium text-heading', regLabel(reg))
            ]),
            el('div', 'text-sm text-dim tabular-nums', infoChildren)
          ]));
        });
      }
      var errCount = document.getElementById('health-error-count');
      if (errCount) {
        errCount.textContent = '';
        errCount.appendChild(document.createTextNode('Errors: '));
        errCount.appendChild(el('span', 'font-medium text-muted', String(data.errors ? data.errors.length : 0)));
      }
      var freshness = document.getElementById('health-freshness');
      if (freshness && data.confidence) {
        var ok = Object.values(data.confidence).filter(function (c) { return c === 'ok'; }).length;
        var total = Object.keys(data.confidence).length;
        freshness.textContent = 'Freshness: updated ' + relTime(data.fetchedAt) + ' \u2022 ' + ok + '/' + total + ' registries OK';
      }

      // Registry breakdown — uses total for cumulative registries (Docker/VS Code/NuGet)
      var regTotals = data.registryTotals || {};
      var maxB = 1;
      Object.keys(regTotals).forEach(function (k) {
        var v = regDisplayVal(k, regTotals[k]);
        if (v > maxB) maxB = v;
      });
      var bars = document.getElementById('breakdown-bars');
      if (bars) {
        bars.textContent = '';
        Object.keys(regTotals).forEach(function (key) {
          var r = regTotals[key];
          var displayVal = regDisplayVal(key, r);
          var pct = Math.round((displayVal / maxB) * 100);
          var labelChildren = [document.createTextNode(regLabel(key))];
          if (key === 'vscode' || key === 'nuget') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time installs)'));
          } else if (key === 'docker') {
            labelChildren.push(document.createTextNode(' '));
            labelChildren.push(el('span', 'ml-1.5 text-xs text-dim font-normal', '(all-time pulls)'));
          }
          var barInner = document.createElement('div');
          barInner.className = 'h-2 rounded-full bg-accent';
          barInner.style.width = pct + '%';
          bars.appendChild(el('div', '', [
            el('div', 'flex items-center justify-between text-sm', [
              el('div', 'font-medium text-heading', labelChildren),
              el('div', 'text-dim', [
                el('span', 'text-muted font-medium', fmtCompact.format(displayVal)),
                el('span', 'mx-2 text-edge', '\u2022'),
                document.createTextNode(fmt.format(r.packages) + ' pkg')
              ])
            ]),
            el('div', 'mt-2 h-2 rounded-full bg-surface-strong overflow-hidden', [barInner])
          ]));
        });
      }
      var bmax = document.getElementById('breakdown-max');
      if (bmax) {
        bmax.textContent = '';
        bmax.appendChild(document.createTextNode('Max: '));
        bmax.appendChild(el('span', 'font-medium text-muted', fmtCompact.format(maxB)));
      }

      var sp30 = data.sparkline30 || [];
      var spMax = 1;
      for (var si = 0; si < sp30.length; si++) { var sv = Number(sp30[si]); if (sv > spMax) spMax = sv; }
      var spEl = document.getElementById('sparkline-agg');
      if (spEl) {
        spEl.textContent = '';
        sp30.forEach(function (n) {
          var h = Math.max(2, Math.round((Number(n) / spMax) * 100));
          var s = document.createElement('span');
          s.className = 'spark';
          s.style.height = h + '%';
          s.title = fmt.format(n) + ' downloads';
          spEl.appendChild(s);
        });
      }

      var lb = data.leaderboard || [];
      var lbCount = document.getElementById('leaderboard-count');
      if (lbCount) lbCount.textContent = String(lb.length);
      var tbody = document.getElementById('leaderboard-body');
      if (tbody) {
        tbody.textContent = '';
        lb.forEach(function (row, i) {
          var tb = trendBadge(row.trendPct);
          var has30 = row.range30 && row.range30.length === 30;
          var sparkCell;
          if (has30) {
            var rm = 1;
            for (var ri = 0; ri < row.range30.length; ri++) { if (row.range30[ri] > rm) rm = row.range30[ri]; }
            sparkCell = document.createElement('div');
            sparkCell.className = 'row-spark';
            sparkCell.title = 'Peak: ' + fmt.format(rm) + '/day';
            row.range30.forEach(function (n) {
              var s = document.createElement('span');
              s.className = 'rs';
              s.style.height = Math.max(1, Math.round((n / rm) * 100)) + '%';
              sparkCell.appendChild(s);
            });
          } else {
            sparkCell = el('span', 'text-dim text-xs', '\u2014');
          }
          function td(cls, child) {
            var c = document.createElement('td');
            c.className = cls;
            c.appendChild(typeof child === 'string' ? document.createTextNode(child) : child);
            return c;
          }
          var tr = document.createElement('tr');
          tr.className = 'border-t border-edge-subtle hover:bg-surface-raised/50';
          tr.appendChild(td('px-5 py-3 text-dim tabular-nums', String(i + 1)));
          tr.appendChild(td('px-5 py-3 font-medium text-heading', String(row.name)));
          tr.appendChild(td('px-5 py-3 text-dim', regLabel(row.registry)));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(row.week)));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums text-body', fmt.format(row.month)));
          tr.appendChild(td('px-3 py-3', sparkCell));
          tr.appendChild(td('px-5 py-3 text-right tabular-nums ' + tb.cls, tb.text));
          tbody.appendChild(tr);
        });
      }

      // Leaderboard footer
      var lbFoot = document.getElementById('leaderboard-footer');
      if (lbFoot) {
        lbFoot.textContent = '';
        if (data.errors && data.errors.length > 0) {
          lbFoot.appendChild(el('div', 'border-t border-edge bg-surface-raised px-5 py-3 text-xs text-dim',
            'Some sources failed to fetch (' + data.errors.length + '). Data may be partial.'));
        }
      }
    }

    // Read base path from meta tag set by AppShell (avoids hardcoded path)
    var baseMeta = document.querySelector('meta[name="base-url"]');
    var basePath = (baseMeta ? baseMeta.getAttribute('content') : '/registry-stats') + '/';
    var statsUrl = basePath + 'data/stats.json';

    fetch(statsUrl).then(function (res) {
      if (!res.ok) throw new Error(res.status);
      return res.json();
    }).then(function (data) {
      if (!validateStats(data)) return;
      var existing = document.getElementById('updated-at');
      var buildTime = existing ? existing.getAttribute('data-fetched') : null;
      if (buildTime && data.fetchedAt === buildTime) return;
      renderDashboard(data);
    }).catch(function () {
      // Runtime fetch failed — build-time data is still displayed. Silent fallback.
    });
  })();
</script>

<script is:inline>
  // ═══════════════════════════════════════════════════
  // Ollama Chat Engine — plug-and-play local LLM chat
  // ═══════════════════════════════════════════════════
  (function () {
    var OLLAMA_BASE = 'http://localhost:11434';
    var STORAGE_KEY = 'rp-chat-history';
    var STORAGE_MODEL = 'rp-chat-model';

    var dot = document.getElementById('ollama-dot');
    var statusLabel = document.getElementById('ollama-label');
    var modelSelect = document.getElementById('ollama-model');
    var msgContainer = document.getElementById('chat-messages');
    var chatInput = document.getElementById('chat-input');
    var chatSend = document.getElementById('chat-send');
    var chatClear = document.getElementById('chat-clear');
    if (!dot || !msgContainer || !chatInput) return; // guard: chat not rendered

    var connected = false;
    var sending = false;
    var history = [];

    // ── Build system prompt with full stats context ──
    var ctxEl = document.getElementById('chat-context');
    var rawCtx = '';
    if (ctxEl) { try { rawCtx = ctxEl.getAttribute('data-json') || ''; } catch (e) {} }

    var SYSTEM = 'You are Registry Pulse Assistant, an expert analyst for software package registry statistics across npm, PyPI, NuGet, VS Code Marketplace, and Docker Hub.\n\n' +
      'Your expertise covers:\n' +
      '- Download trend analysis, forecasting, and anomaly detection\n' +
      '- Multi-registry distribution strategy and portfolio planning\n' +
      '- Growth tactics for open-source packages (SEO, keywords, README optimization)\n' +
      '- Release timing, versioning strategy, and changelog best practices\n' +
      '- Competitive positioning and market sizing\n' +
      '- Health scoring interpretation and improvement recommendations\n\n' +
      'CURRENT PORTFOLIO DATA (live from the user\'s snapshot):\n' + rawCtx + '\n\n' +
      'Guidelines:\n' +
      '- Reference specific numbers from the data when answering.\n' +
      '- Flag concerning trends proactively.\n' +
      '- Suggest actionable, prioritized strategies.\n' +
      '- Keep responses concise but insightful. Use bullet points for lists.\n' +
      '- If the user asks something outside your data, say so honestly.';

    // ── localStorage persistence ──
    function loadHistory() {
      try { var s = localStorage.getItem(STORAGE_KEY); if (s) history = JSON.parse(s); } catch (e) { history = []; }
    }
    function saveHistory() {
      try {
        // Keep max 60 messages to avoid quota issues
        if (history.length > 60) history = history.slice(-60);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(history));
      } catch (e) {}
    }

    // ── DOM helpers ──
    function clearEl(el) { while (el.firstChild) el.removeChild(el.firstChild); }

    function renderMessages() {
      clearEl(msgContainer);
      if (history.length === 0) {
        var ph = document.createElement('div');
        ph.className = 'text-sm text-dim text-center py-8';
        ph.textContent = 'Ask anything about your registry stats, package trends, or release strategy.';
        msgContainer.appendChild(ph);
        return;
      }
      for (var i = 0; i < history.length; i++) {
        var msg = history[i];
        var row = document.createElement('div');
        row.className = msg.role === 'user' ? 'flex justify-end' : 'flex justify-start';
        var bubble = document.createElement('div');
        bubble.className = msg.role === 'user' ? 'chat-bubble-user' : 'chat-bubble-ai';
        bubble.textContent = msg.content;
        row.appendChild(bubble);
        msgContainer.appendChild(row);
      }
      msgContainer.scrollTop = msgContainer.scrollHeight;
    }

    // ── Connection check ──
    function checkOllama() {
      dot.className = 'inline-block w-2 h-2 rounded-full bg-zinc-500 animate-pulse';
      statusLabel.textContent = 'Checking\u2026';

      var ctrl = new AbortController();
      var tid = setTimeout(function () { ctrl.abort(); }, 4000);

      fetch(OLLAMA_BASE + '/api/tags', { signal: ctrl.signal })
        .then(function (r) { clearTimeout(tid); return r.json(); })
        .then(function (data) {
          connected = true;
          dot.className = 'inline-block w-2 h-2 rounded-full bg-emerald-400';
          statusLabel.textContent = 'Connected';

          var models = (data.models || []).map(function (m) { return m.name || m.model; });
          if (models.length > 0) {
            clearEl(modelSelect);
            var saved = '';
            try { saved = localStorage.getItem(STORAGE_MODEL) || ''; } catch (e) {}
            for (var i = 0; i < models.length; i++) {
              var opt = document.createElement('option');
              opt.value = models[i]; opt.textContent = models[i];
              if (models[i] === saved) opt.selected = true;
              modelSelect.appendChild(opt);
            }
            modelSelect.disabled = false;
            chatInput.disabled = false;
            chatSend.disabled = false;
            chatInput.focus();
          }
        })
        .catch(function () {
          clearTimeout(tid);
          connected = false;
          dot.className = 'inline-block w-2 h-2 rounded-full bg-rose-400';
          statusLabel.textContent = 'Offline';
          clearEl(msgContainer);
          var help = document.createElement('div');
          help.className = 'text-center py-6 space-y-2';
          var l1 = document.createElement('div');
          l1.className = 'text-sm text-dim';
          l1.textContent = 'Could not connect to Ollama at localhost:11434';
          var l2 = document.createElement('div');
          l2.className = 'text-xs text-dim';
          l2.textContent = 'Install from ollama.com \u2022 then run: ollama pull llama3.2';
          var retry = document.createElement('button');
          retry.className = 'mt-2 text-xs text-accent hover:underline cursor-pointer';
          retry.textContent = 'Retry connection';
          retry.addEventListener('click', checkOllama);
          help.appendChild(l1); help.appendChild(l2); help.appendChild(retry);
          msgContainer.appendChild(help);
        });
    }

    // ── Send message (streaming) ──
    function sendMessage() {
      if (!connected || sending) return;
      var text = chatInput.value.trim();
      if (!text) return;

      sending = true;
      chatInput.value = '';
      chatSend.disabled = true;
      chatInput.disabled = true;

      history.push({ role: 'user', content: text });
      renderMessages();

      // Typing indicator
      var typingRow = document.createElement('div');
      typingRow.className = 'flex justify-start';
      var typingBubble = document.createElement('div');
      typingBubble.className = 'chat-bubble-ai chat-typing';
      for (var d = 0; d < 3; d++) typingBubble.appendChild(document.createElement('span'));
      typingRow.appendChild(typingBubble);
      msgContainer.appendChild(typingRow);
      msgContainer.scrollTop = msgContainer.scrollHeight;

      // Build messages: system + last 20 turns
      var msgs = [{ role: 'system', content: SYSTEM }].concat(history.slice(-20));

      var model = modelSelect.value;
      try { localStorage.setItem(STORAGE_MODEL, model); } catch (e) {}

      fetch(OLLAMA_BASE + '/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ model: model, messages: msgs, stream: true })
      }).then(function (resp) {
        if (!resp.ok) throw new Error('HTTP ' + resp.status);
        // Replace typing with response bubble
        msgContainer.removeChild(typingRow);
        var aiRow = document.createElement('div');
        aiRow.className = 'flex justify-start';
        var aiBubble = document.createElement('div');
        aiBubble.className = 'chat-bubble-ai';
        aiBubble.textContent = '';
        aiRow.appendChild(aiBubble);
        msgContainer.appendChild(aiRow);

        var reader = resp.body.getReader();
        var decoder = new TextDecoder();
        var fullText = '';

        function pump() {
          return reader.read().then(function (result) {
            if (result.done) {
              if (fullText) {
                history.push({ role: 'assistant', content: fullText });
                saveHistory();
              }
              sending = false;
              chatSend.disabled = false;
              chatInput.disabled = false;
              chatInput.focus();
              return;
            }
            var lines = decoder.decode(result.value, { stream: true }).split('\n');
            for (var i = 0; i < lines.length; i++) {
              if (!lines[i].trim()) continue;
              try {
                var json = JSON.parse(lines[i]);
                if (json.message && json.message.content) {
                  fullText += json.message.content;
                  aiBubble.textContent = fullText;
                  msgContainer.scrollTop = msgContainer.scrollHeight;
                }
              } catch (e) {}
            }
            return pump();
          });
        }
        return pump();
      }).catch(function (err) {
        msgContainer.removeChild(typingRow);
        var errRow = document.createElement('div');
        errRow.className = 'flex justify-start';
        var errBubble = document.createElement('div');
        errBubble.className = 'chat-bubble-ai text-rose-400';
        errBubble.textContent = 'Error: ' + (err.message || 'Could not get a response. Is the model loaded?');
        errRow.appendChild(errBubble);
        msgContainer.appendChild(errRow);

        sending = false;
        chatSend.disabled = false;
        chatInput.disabled = false;
      });
    }

    // ── Event listeners ──
    chatSend.addEventListener('click', sendMessage);
    chatInput.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
    });
    chatClear.addEventListener('click', function () {
      history = [];
      saveHistory();
      renderMessages();
    });
    modelSelect.addEventListener('change', function () {
      try { localStorage.setItem(STORAGE_MODEL, modelSelect.value); } catch (e) {}
    });

    // ── Init ──
    loadHistory();
    renderMessages();
    checkOllama();
  })();
</script>
